        <tr><td>CHURCH (SKU-008)</td><td>Prayer Recovery, Body As Temple, Restorative Justice</td><td>Partial</td></tr>
        <tr><td>WELLNESS (SKU-009)</td><td>Prayer Recovery, Body As Temple</td><td>Partial</td></tr>
        <tr><td>SOCIAL (SKU-021)</td><td>Cultural Sovereignty Filter</td><td>No</td></tr>
