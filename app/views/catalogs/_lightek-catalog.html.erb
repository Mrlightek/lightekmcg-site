  {sku:'SKU-031',name:'REPARATIONS FUND',dept:'Treasury · Constitutional',icon:'⚖️',color:'#D82020',price:240,retail:600,desc:'Article VII implementation module. Automated 2% allocation, distribution tracking, Legacy Endowment management, quarterly reporting.',me:true,stock:true,isNew:true},
];

let cart = {};
let activeSort = 'sku';

function renderGrid(products) {
  const grid = document.getElementById('prod-grid');
  grid.innerHTML = '';
  document.getElementById('prod-count').textContent = `SHOWING ${products.length} OF 31 SKUs · LIGHTEK MCG AUTHORIZED CATALOG`;

  products.forEach(p => {
    const inCart = !!cart[p.sku];
    const div = document.createElement('div');
    div.className = 'prod-card' + (inCart ? ' in-cart' : '');
    div.id = 'card-' + p.sku;
    div.style.setProperty('--stripe', p.color);
    div.innerHTML = `
      <div style="position:absolute;top:0;left:0;right:0;height:2px;background:${p.color};"></div>
      ${p.me ? '<div class="pc-me-badge">⚖ MINISTRY ENGINE</div>' : ''}
      ${p.isNew ? '<div class="pc-new-badge">NEW</div>' : ''}
      <div class="pc-top">
        <div class="pc-sku">${p.sku}</div>
        <div class="pc-stock">
          <div class="pcs-dot" style="background:${p.stock?'#28D870':'#D82020'};animation:blink 1s infinite;"></div>
          <span style="font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:${p.stock?'#28D870':'#D82020'};">${p.stock?'IN STOCK':'WAITLIST'}</span>
        </div>
      </div>
      <span class="pc-icon">${p.icon}</span>
      <div class="pc-name">${p.name}</div>
      <div class="pc-dept" style="color:${p.color};">${p.dept}</div>
      <div class="pc-desc">${p.desc}</div>
      <div class="pc-bottom">
        <div class="pc-pricing">
          <span class="pcp-wholesale" style="color:${p.color};">$${p.price.toLocaleString()}</span>
          <span class="pcp-retail">Retail: ~$${p.retail.toLocaleString()}/mo</span>
        </div>
        <button class="pc-add-btn"
          style="border-color:${inCart?'var(--cyan)':'rgba(238,244,252,.18)'};color:${inCart?'var(--cyan)':'rgba(238,244,252,.4)'};"
          onclick="toggleCart('${p.sku}',event)">${inCart ? '✓ IN CART' : '+ ADD'}</button>
      </div>`;
    div.addEventListener('mouseenter',()=>{cur.style.width='10px';cur.style.height='10px';cur2.style.width='32px';cur2.style.height='32px';});
    div.addEventListener('mouseleave',()=>{cur.style.width='6px';cur.style.height='6px';cur2.style.width='26px';cur2.style.height='26px';});
    grid.appendChild(div);
  });
}

function toggleCart(sku, e) {
  if(e) e.stopPropagation();
  const p = PRODUCTS.find(x=>x.sku===sku);
  if(cart[sku]) {
    delete cart[sku];
  } else {
    cart[sku] = p;
  }
  updateCart();
  renderGrid(getCurrentProducts());
}

function updateCart() {
  const count = Object.keys(cart).length;
  document.getElementById('cart-badge').textContent = count;
  document.getElementById('cart-count').textContent = count;

  const itemsEl = document.getElementById('cart-items');
  const emptyEl = document.getElementById('cart-empty');

  if(count === 0) {
    itemsEl.innerHTML = '<div class="cart-empty" id="cart-empty"><span class="ce-icon">🛒</span><div class="ce-text">Your order is empty.<br>Add SKUs from the catalog to build your deployment order.</div></div>';
  } else {
    const items = Object.values(cart).map(p => `
      <div class="cart-item">
        <div class="ci-icon">${p.icon}</div>
        <div class="ci-body">
          <div class="cib-name">${p.name}</div>
          <div class="cib-sku">${p.sku}</div>
          <div class="cib-price">$${p.price.toLocaleString()}/mo wholesale</div>
        </div>
        <div class="ci-remove" onclick="toggleCart('${p.sku}')">✕</div>
      </div>`).join('');
    itemsEl.innerHTML = items;
  }

  const wholesale = Object.values(cart).reduce((s,p)=>s+p.price,0);
  const retail = wholesale * 2;
  const margin = retail - wholesale;
  document.getElementById('wholesale-total').textContent = '$' + wholesale.toLocaleString();
  document.getElementById('retail-total').textContent = '$' + retail.toLocaleString();
  document.getElementById('order-total').textContent = '$' + wholesale.toLocaleString();
  document.getElementById('module-count').textContent = count;
  document.getElementById('margin-display').textContent = '$' + margin.toLocaleString();
  document.getElementById('margin-label').textContent = count > 0 ? `/ month recurring · ${count} module${count>1?'s':''} deployed` : '/ month · recurring';
}

function getCurrentProducts() {
  let products = [...PRODUCTS];
  if(activeSort === 'price') products.sort((a,b)=>a.price-b.price);
  else if(activeSort === 'dept') products.sort((a,b)=>a.dept.localeCompare(b.dept));
  else if(activeSort === 'margin') products.sort((a,b)=>(b.retail-b.price)-(a.retail-a.price));
  return products;
}

function sortBy(btn, type) {
  activeSort = type;
  document.querySelectorAll('.sort-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  renderGrid(getCurrentProducts());
}

function filterProducts(q) {
  if(!q) { renderGrid(getCurrentProducts()); return; }
  const filtered = PRODUCTS.filter(p =>
    p.name.toLowerCase().includes(q.toLowerCase()) ||
    p.sku.toLowerCase().includes(q.toLowerCase()) ||
    p.dept.toLowerCase().includes(q.toLowerCase())
  );
  renderGrid(filtered);
}

function toggleFilter(el) {
  el.querySelector('.fo-box').classList.toggle('checked');
}

function addBundle(type) {
  const bundles = {
    'church-bundle': ['SKU-008','SKU-009','SKU-020'],
    'hbcu-bundle': ['SKU-003','SKU-001','SKU-015','SKU-020'],
    'media-bundle': ['SKU-014','SKU-015','SKU-016','SKU-018'],
    'full-stack': PRODUCTS.map(p=>p.sku)
  };
  (bundles[type]||[]).forEach(sku=>{
    const p = PRODUCTS.find(x=>x.sku===sku);
    if(p) cart[sku] = p;
  });
  updateCart();
  renderGrid(getCurrentProducts());
}

function checkout() {
  if(!Object.keys(cart).length) return;
  const btn = document.querySelector('.os-checkout');
  btn.textContent = '✓ ORDER SUBMITTED — LIGHTEK WILL CONFIRM';
  btn.style.background = 'var(--green2)';
}

function saveQuote() {
  const btn = document.querySelector('.os-save');
  btn.textContent = '✓ QUOTE SAVED';
  setTimeout(()=>btn.textContent='SAVE AS QUOTE',2500);
}

// Init
renderGrid(PRODUCTS);
</script>
