<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lightek MCG — Internal Operations Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;cursor:none;}
:root{
  /* foundation */
  --bg:#020508;--bg2:#040810;--bg3:#060B14;
  --panel:#08101C;--card:#0A1422;--lift:#0D1A2C;--border:#0F2040;
  /* brand */
  --cyan:#00B8D4;--cyan2:#00D4F4;--cyan3:#40E8FF;
  --gold:#C0900A;--gold2:#D4A818;--gold3:#ECC030;
  /* departments */
  --sales:#0A7840;--sales2:#10A858;--sales3:#18D870;
  --deploy:#0848B8;--deploy2:#0A60E0;--deploy3:#2880FF;
  --channel:#6010A0;--channel2:#8018CC;--channel3:#A030F0;
  --finance:#884400;--finance2:#B05808;--finance3:#D87010;
  --comms:#007088;--comms2:#009CB8;--comms3:#00C0E0;
  --compliance:#880020;--compliance2:#B00030;--compliance3:#D80040;
  --support:#405800;--support2:#587800;--support3:#70A000;
  --exec:#402808;--exec2:#604010;--exec3:#805818;
  /* status */
  --green:#18D870;--yellow:#E8C020;--red:#E82020;--orange:#E86020;
  /* text */
  --white:#E8F0F8;--muted:#3A5070;--dim:#1A2840;--ghost:#0E1828;
  /* fonts */
  --fm:'IBM Plex Mono',monospace;
  --fc:'Barlow Condensed',sans-serif;
  --fb:'IBM Plex Sans',sans-serif;
}
html{font-size:13px;}
body{background:var(--bg);color:var(--white);font-family:var(--fm);height:100vh;overflow:hidden;display:flex;flex-direction:column;}

/* micro circuit bg */
body::before{content:'';position:fixed;inset:0;background-image:
  linear-gradient(rgba(0,184,212,.006) 1px,transparent 1px),
  linear-gradient(90deg,rgba(0,184,212,.006) 1px,transparent 1px);
  background-size:20px 20px;pointer-events:none;z-index:0;}

/* cursor — crosshair */
#cx1{position:fixed;width:1px;height:16px;background:rgba(0,184,212,.7);z-index:9999;pointer-events:none;transform:translate(-50%,-50%);}
#cx2{position:fixed;width:16px;height:1px;background:rgba(0,184,212,.7);z-index:9999;pointer-events:none;transform:translate(-50%,-50%);}
#cxdot{position:fixed;width:3px;height:3px;background:var(--cyan2);z-index:9999;pointer-events:none;transform:translate(-50%,-50%);}

/* animations */
@keyframes blink{0%,100%{opacity:1}50%{opacity:.08}}
@keyframes pulse{0%,100%{opacity:.5}50%{opacity:1}}
@keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes slideIn{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:none}}
.slide-in{animation:slideIn .4s cubic-bezier(.16,1,.3,1) forwards;}

/* ═══════════════════════════════════════════
   SYSTEM BAR — top 28px
═══════════════════════════════════════════ */
.sysbar{
  height:28px;flex-shrink:0;
  background:rgba(2,5,8,1);
  border-bottom:1px solid rgba(0,184,212,.06);
  display:flex;align-items:center;
  justify-content:space-between;
  padding:0 16px;
  position:relative;z-index:200;
}
.sb-left{display:flex;align-items:center;gap:10px;}
.sb-logo{font-family:var(--fc);font-size:11px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;color:var(--cyan);}
.sb-sep{width:1px;height:12px;background:rgba(0,184,212,.12);}
.sb-label{font-size:8px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);}
.sb-env{font-size:7px;letter-spacing:.14em;text-transform:uppercase;color:var(--red);display:flex;align-items:center;gap:3px;}
.sb-env-dot{width:4px;height:4px;border-radius:50%;background:var(--red);animation:blink .6s infinite;}
.sb-center{display:flex;align-items:center;gap:12px;}
.sb-stat{display:flex;align-items:center;gap:4px;}
.sbst-val{font-size:9px;font-weight:700;letter-spacing:.04em;}
.sbst-lbl{font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.sb-pipe{width:1px;height:10px;background:rgba(0,184,212,.08);}
.sb-right{display:flex;align-items:center;gap:10px;}
.sb-clock{font-size:10px;font-weight:600;color:rgba(232,240,248,.4);letter-spacing:.04em;}
.sb-user{display:flex;align-items:center;gap:5px;}
.sbu-dept{font-size:7px;letter-spacing:.12em;text-transform:uppercase;padding:2px 6px;border:1px solid;}
.sbu-name{font-size:8px;font-weight:700;letter-spacing:.06em;color:rgba(232,240,248,.5);}
/* alert ticker */
.alert-ticker{
  height:22px;flex-shrink:0;
  background:var(--ghost);
  border-bottom:1px solid rgba(0,184,212,.05);
  display:flex;align-items:center;
  overflow:hidden;
  position:relative;z-index:190;
}
.at-badge{font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:var(--bg);background:var(--cyan);padding:0 10px;height:100%;display:flex;align-items:center;font-weight:700;flex-shrink:0;}
.at-scroll{white-space:nowrap;animation:tickerScroll 60s linear infinite;display:inline-block;}
.at-item{font-size:7px;letter-spacing:.08em;color:rgba(0,184,212,.5);padding:0 30px;}
.at-item.alert{color:rgba(232,32,32,.7);}
.at-item.good{color:rgba(24,216,112,.6);}
.at-item.warn{color:rgba(232,192,32,.6);}

/* ═══════════════════════════════════════════
   DEPT TAB BAR
═══════════════════════════════════════════ */
.dept-bar{
  height:38px;flex-shrink:0;
  background:rgba(4,8,16,.98);
  border-bottom:1px solid rgba(0,184,212,.06);
  display:flex;align-items:center;
  padding:0 0 0 8px;
  position:relative;z-index:180;
}
.dept-tab{
  height:38px;
  display:flex;align-items:center;gap:5px;
  padding:0 14px;
  border-bottom:2px solid transparent;
  border-top:none;border-left:none;border-right:none;
  background:transparent;
  font-family:var(--fm);font-size:7px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  color:var(--muted);cursor:pointer;transition:all .15s;
  position:relative;
}
.dept-tab:hover{color:rgba(232,240,248,.7);}
.dept-tab.active{color:var(--white);}
.dt-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.dt-count{font-size:6px;font-weight:700;opacity:.7;}
.dept-bar-right{margin-left:auto;display:flex;align-items:center;gap:6px;padding-right:14px;}
.dbr-role{font-size:7px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);}
.dbr-switch{font-size:7px;letter-spacing:.12em;text-transform:uppercase;border:1px solid rgba(0,184,212,.12);padding:3px 8px;color:var(--cyan);background:rgba(0,184,212,.04);cursor:pointer;transition:all .18s;}
.dbr-switch:hover{background:rgba(0,184,212,.08);}

/* ═══════════════════════════════════════════
   MAIN LAYOUT
═══════════════════════════════════════════ */
.main-wrap{display:grid;grid-template-columns:180px 1fr 220px;flex:1;overflow:hidden;position:relative;z-index:1;}

/* ─ LEFT NAV ─ */
.leftnav{background:rgba(4,8,16,.99);border-right:1px solid rgba(0,184,212,.05);overflow-y:auto;padding:0;}
.leftnav::-webkit-scrollbar{width:0;}
.ln-section{padding:10px 0 2px;}
.ln-hdr{font-size:7px;letter-spacing:.22em;text-transform:uppercase;color:rgba(58,80,112,.8);padding:0 12px;margin-bottom:4px;}
.ln-item{display:flex;align-items:center;gap:7px;padding:6px 10px;border-left:2px solid transparent;cursor:pointer;transition:all .12s;position:relative;}
.ln-item:hover{background:rgba(0,184,212,.03);}
.ln-item.active{background:rgba(0,184,212,.05);border-left-color:var(--cyan);}
.ln-item.active .ln-label{color:var(--cyan);}
.ln-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.ln-label{font-size:8px;letter-spacing:.06em;color:rgba(232,240,248,.38);flex:1;text-transform:uppercase;}
.ln-badge{font-size:6px;font-weight:700;color:rgba(232,240,248,.2);padding:1px 4px;border:1px solid rgba(232,240,248,.08);}
.ln-badge.live{color:var(--red);border-color:rgba(232,32,32,.2);animation:blink .8s infinite;}
.ln-badge.good{color:var(--green);border-color:rgba(24,216,112,.2);}
.ln-badge.warn{color:var(--yellow);border-color:rgba(232,192,32,.2);}
.ln-divider{height:1px;background:rgba(0,184,212,.05);margin:6px 0;}

/* ─ CENTER CONTENT ─ */
.center-content{overflow-y:auto;padding:12px;background:var(--bg);}
.center-content::-webkit-scrollbar{width:3px;}
.center-content::-webkit-scrollbar-track{background:rgba(0,184,212,.02);}
.center-content::-webkit-scrollbar-thumb{background:rgba(0,184,212,.1);}

/* ─ RIGHT RAIL ─ */
.right-rail{background:rgba(4,8,16,.99);border-left:1px solid rgba(0,184,212,.05);overflow-y:auto;padding:10px 0;}
.right-rail::-webkit-scrollbar{width:0;}

/* ═══════════════════════════════════════════
   SHARED WIDGET COMPONENTS
═══════════════════════════════════════════ */
.widget{background:var(--panel);border:1px solid rgba(0,184,212,.06);margin-bottom:4px;position:relative;overflow:hidden;}
.widget-hdr{display:flex;justify-content:space-between;align-items:center;padding:7px 10px;border-bottom:1px solid rgba(0,184,212,.05);}
.wh-title{font-size:8px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;display:flex;align-items:center;gap:5px;}
.wh-title-dot{width:4px;height:4px;border-radius:50%;}
.wh-action{font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--cyan);cursor:pointer;opacity:.6;transition:opacity .15s;}
.wh-action:hover{opacity:1;}
.wh-badge{font-size:6px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:1px 5px;}
.widget-body{padding:8px 10px;}
.widget-stripe{position:absolute;top:0;left:0;right:0;height:2px;}

/* stat row */
.stat-row{display:grid;gap:4px;margin-bottom:4px;}
.stat-cell{background:var(--card);border:1px solid rgba(0,184,212,.05);padding:8px 10px;position:relative;}
.sc-lbl{font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;}
.sc-val{font-family:var(--fc);font-size:clamp(18px,2.5vw,28px);font-weight:900;letter-spacing:.03em;display:block;line-height:1;}
.sc-sub{font-size:7px;letter-spacing:.06em;margin-top:2px;}
.sc-delta-up{color:var(--green);}
.sc-delta-down{color:var(--red);}
.sc-delta-flat{color:var(--yellow);}
.sc-bar{position:absolute;bottom:0;left:0;right:0;height:2px;}

/* table */
.data-table{width:100%;}
.dt-head{display:grid;padding:4px 0;border-bottom:1px solid rgba(0,184,212,.07);margin-bottom:2px;}
.dt-th{font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);}
.dt-row{display:grid;padding:5px 0;border-bottom:1px solid rgba(0,184,212,.04);align-items:center;transition:background .12s;cursor:pointer;}
.dt-row:hover{background:rgba(0,184,212,.025);}
.dt-row:last-child{border-bottom:none;}
.dt-cell{font-size:8px;letter-spacing:.04em;color:rgba(232,240,248,.55);}
.dt-cell.strong{color:rgba(232,240,248,.82);font-weight:600;}
.dt-cell.mono{font-family:var(--fm);font-size:7px;}

/* status pills */
.status-pill{font-size:6px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:1px 5px;display:inline-block;}
.sp-active{border-color:rgba(24,216,112,.25);color:var(--green);}
.sp-live{border-color:rgba(232,32,32,.3);color:var(--red);animation:blink .9s infinite;}
.sp-warn{border-color:rgba(232,192,32,.25);color:var(--yellow);}
.sp-pending{border-color:rgba(0,184,212,.2);color:var(--cyan);}
.sp-closed{border-color:rgba(58,80,112,.3);color:var(--muted);}

/* progress bar */
.prog-bar{height:3px;background:rgba(232,240,248,.05);position:relative;margin-top:4px;}
.prog-fill{position:absolute;top:0;left:0;height:100%;transition:width .8s ease;}

/* feed item */
.feed-item{display:flex;gap:7px;align-items:flex-start;padding:5px 0;border-bottom:1px solid rgba(0,184,212,.04);}
.feed-item:last-child{border-bottom:none;}
.fi-time{font-size:7px;font-weight:700;color:var(--muted);flex-shrink:0;min-width:32px;padding-top:1px;}
.fi-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0;margin-top:3px;}
.fi-text{font-size:8px;color:rgba(232,240,248,.48);line-height:1.45;flex:1;}
.fi-text strong{color:rgba(232,240,248,.75);font-weight:600;}

/* mini bar chart */
.minibars{display:flex;align-items:flex-end;gap:2px;height:40px;}
.mb-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;}
.mb-bar{width:100%;border-radius:1px 1px 0 0;min-height:2px;}
.mb-lbl{font-size:5px;letter-spacing:.04em;color:var(--muted);}

/* right rail widgets */
.rr-section{padding:0 10px 10px;border-bottom:1px solid rgba(0,184,212,.05);margin-bottom:2px;}
.rrs-title{font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);padding:8px 0 5px;display:flex;align-items:center;gap:5px;}
.rrs-title::before{content:'◈';color:var(--cyan);font-size:8px;}
.rr-item{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid rgba(0,184,212,.04);}
.rr-item:last-child{border-bottom:none;}
.rri-label{font-size:8px;color:rgba(232,240,248,.4);}
.rri-val{font-size:8px;font-weight:700;}

/* pipeline stage */
.pipeline-stage{display:flex;align-items:center;gap:3px;margin-bottom:5px;}
.ps-name{font-size:7px;letter-spacing:.08em;text-transform:uppercase;color:rgba(232,240,248,.35);min-width:72px;}
.ps-bar{flex:1;height:5px;background:rgba(232,240,248,.04);}
.ps-fill{height:100%;}
.ps-count{font-size:7px;font-weight:700;min-width:18px;text-align:right;}
.ps-val{font-size:7px;color:var(--muted);min-width:42px;text-align:right;}

/* person card in nav */
.ln-person{display:flex;gap:6px;align-items:center;padding:6px 10px;cursor:pointer;transition:background .12s;border-left:2px solid transparent;}
.ln-person:hover{background:rgba(0,184,212,.025);}
.lnp-avatar{width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0;}
.lnp-name{font-size:8px;letter-spacing:.04em;color:rgba(232,240,248,.45);flex:1;}
.lnp-status{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
</style>
</head>
<body>
<div id="cx1"></div><div id="cx2"></div><div id="cxdot"></div>

<!-- SYSTEM BAR -->
<div class="sysbar">
  <div class="sb-left">
    <div class="sb-logo">LIGHTEK MCG</div>
    <div class="sb-sep"></div>
    <div class="sb-label">INTERNAL OPERATIONS PLATFORM</div>
    <div class="sb-sep"></div>
    <div class="sb-env"><div class="sb-env-dot"></div>LIVE · v2.4.1</div>
  </div>
  <div class="sb-center">
    <div class="sb-stat"><span class="sbst-val" style="color:var(--green);" id="sys-mrr">$84,600</span><span class="sbst-lbl">MRR</span></div>
    <div class="sb-pipe"></div>
    <div class="sb-stat"><span class="sbst-val" style="color:var(--cyan);">8</span><span class="sbst-lbl">DEPLOYMENTS</span></div>
    <div class="sb-pipe"></div>
    <div class="sb-stat"><span class="sbst-val" style="color:var(--yellow);" id="sys-tickets">14</span><span class="sbst-lbl">OPEN TICKETS</span></div>
    <div class="sb-pipe"></div>
    <div class="sb-stat"><span class="sbst-val" style="color:var(--green);">99.97%</span><span class="sbst-lbl">UPTIME</span></div>
    <div class="sb-pipe"></div>
    <div class="sb-stat"><span class="sbst-val" style="color:var(--cyan);">31</span><span class="sbst-lbl">SKUS LIVE</span></div>
  </div>
  <div class="sb-right">
    <div class="sb-clock" id="sys-clock">09:41:00</div>
    <div class="sb-sep"></div>
    <div class="sb-user">
      <div class="sbu-dept" style="border-color:rgba(0,120,64,.3);color:var(--sales2);">SALES</div>
      <div class="sbu-name">EMPLOYEE NAME</div>
    </div>
  </div>
</div>

<!-- ALERT TICKER -->
<div class="alert-ticker">
  <div class="at-badge">◉ OPS</div>
  <div class="at-scroll">
    <span class="at-item good">MILES COLLEGE DEPLOYMENT — All 5 modules live · SLA nominal</span>
    <span class="at-item warn">TICKET LT-2841 — City of Compton onboarding · Bank module pending auth · Assigned: @darius.m</span>
    <span class="at-item">RESELLER CERTIFICATION — Crown City Media · Training complete · Awaiting first deployment</span>
    <span class="at-item good">Q1 COMMISSION RUN — $90,840 processed · All resellers paid · 0 disputes</span>
    <span class="at-item alert">MINISTRY ENGINE ALERT — Violation flagged on Reseller A4 deployment · Compliance team notified</span>
    <span class="at-item">LIGHTEK SUMMIT — Annual partner meeting · June 14-16, 2026 · 240 resellers invited</span>
    <span class="at-item good">NEW PROPOSAL — Xavier University of LA · $18K MRR · Demo set for Thursday</span>
    <span class="at-item">DYMOND EMPIRE — Module update v3.1.4 · Deploying to all instances tonight 2:00 AM EST</span>
    <span class="at-item good">MILES COLLEGE DEPLOYMENT — All 5 modules live · SLA nominal</span>
    <span class="at-item warn">TICKET LT-2841 — City of Compton onboarding · Bank module pending auth · Assigned: @darius.m</span>
    <span class="at-item">RESELLER CERTIFICATION — Crown City Media · Training complete · Awaiting first deployment</span>
    <span class="at-item good">Q1 COMMISSION RUN — $90,840 processed · All resellers paid · 0 disputes</span>
  </div>
</div>

<!-- DEPT TAB BAR -->
<div class="dept-bar">
  <button class="dept-tab active" onclick="switchDept('sales',this)" id="tab-sales">
    <div class="dt-dot" style="background:var(--sales2);"></div>SALES<span class="dt-count">8 DEALS</span>
  </button>
  <button class="dept-tab" onclick="switchDept('deploy',this)" id="tab-deploy">
    <div class="dt-dot" style="background:var(--deploy2);"></div>DEPLOYMENT<span class="dt-count">8 LIVE</span>
  </button>
  <button class="dept-tab" onclick="switchDept('channel',this)" id="tab-channel">
    <div class="dt-dot" style="background:var(--channel2);"></div>CHANNEL MGMT<span class="dt-count">6 PARTNERS</span>
  </button>
  <button class="dept-tab" onclick="switchDept('finance',this)" id="tab-finance">
    <div class="dt-dot" style="background:var(--finance2);"></div>FINANCE<span class="dt-count">Q1 2026</span>
  </button>
  <button class="dept-tab" onclick="switchDept('compliance',this)" id="tab-compliance">
    <div class="dt-dot" style="background:var(--compliance2);animation:blink .9s infinite;"></div>COMPLIANCE<span class="dt-count" style="color:var(--red);">1 ALERT</span>
  </button>
  <button class="dept-tab" onclick="switchDept('support',this)" id="tab-support">
    <div class="dt-dot" style="background:var(--support2);"></div>SUPPORT<span class="dt-count">14 OPEN</span>
  </button>
  <button class="dept-tab" onclick="switchDept('executive',this)" id="tab-executive">
    <div class="dt-dot" style="background:var(--gold2);"></div>EXECUTIVE<span class="dt-count">OVERVIEW</span>
  </button>
  <div class="dept-bar-right">
    <div class="dbr-role">ROLE: SALES REP</div>
    <button class="dbr-switch" onclick="cycleRole(this)">SWITCH ROLE</button>
  </div>
</div>

<!-- MAIN WRAP -->
<div class="main-wrap">

  <!-- ─ LEFT NAV ─ -->
  <nav class="leftnav" id="leftnav">
    <!-- Populated by JS per dept -->
  </nav>

  <!-- ─ CENTER CONTENT ─ -->
  <div class="center-content" id="center">
    <!-- Populated by JS per dept -->
  </div>

  <!-- ─ RIGHT RAIL ─ -->
  <aside class="right-rail" id="right-rail">
    <!-- Populated by JS per dept -->
  </aside>

</div>

<script>
// ── CURSOR ─────────────────────────────────
const cx1=document.getElementById('cx1');
const cx2=document.getElementById('cx2');
const cxd=document.getElementById('cxdot');
document.addEventListener('mousemove',e=>{
  const {clientX:x,clientY:y}=e;
  cx1.style.left=x+'px';cx1.style.top=y+'px';
  cx2.style.left=x+'px';cx2.style.top=y+'px';
  cxd.style.left=x+'px';cxd.style.top=y+'px';
});

// ── CLOCK ──────────────────────────────────
function tick(){
  const n=new Date();
  const t=`${String(n.getHours()).padStart(2,'0')}:${String(n.getMinutes()).padStart(2,'0')}:${String(n.getSeconds()).padStart(2,'0')}`;
  document.getElementById('sys-clock').textContent=t;
}
tick();setInterval(tick,1000);

// ── LIVE MRR FLICKER ───────────────────────
let mrr=84600;
setInterval(()=>{mrr+=Math.floor(Math.random()*300);document.getElementById('sys-mrr').textContent='$'+mrr.toLocaleString();},9000);

// ── DEPT DATA ──────────────────────────────
const DEPTS={

  // ════════════════════════════════════════
  // SALES
  // ════════════════════════════════════════
  sales:{
