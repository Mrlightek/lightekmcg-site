// ── DEPT SWITCHER ──────────────────────────
let currentDept = 'sales';
const DEPT_COLORS = {
  sales:'var(--sales2)',deploy:'var(--deploy2)',channel:'var(--channel2)',
  finance:'var(--finance2)',compliance:'var(--compliance2)',support:'var(--support2)',executive:'var(--gold2)'
};

function switchDept(id, btn){
  currentDept = id;
  document.querySelectorAll('.dept-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  const d = DEPTS[id];
  if(!d) return;
  document.getElementById('leftnav').innerHTML = d.nav;
  document.getElementById('center').innerHTML = d.center;
  document.getElementById('right-rail').innerHTML = d.rail;
  // channel bars
  if(id==='channel'){
    const b=document.getElementById('chan-bars');
    if(b){const v=[8,12,18,22,28,36,44,52,68,84,120,240];v.forEach((val,i)=>{const c=document.createElement('div');c.className='mb-col';c.innerHTML=`<div class="mb-bar" style="height:${Math.round(val/240*100)}%;background:${i===v.length-1?'var(--channel2)':'rgba(128,24,204,.4)'}"></div><div class="mb-lbl">${['A','M','J','J','A','S','O','N','D','J','F','M'][i]}</div>`;b.appendChild(c);});}
  }
  addHoverFX();
}

function addHoverFX(){
  document.querySelectorAll('.ln-item,.ln-person,.dt-row,.feed-item,.rr-item,.stat-cell').forEach(el=>{
    el.addEventListener('mouseenter',()=>{cx1.style.opacity='1';cxd.style.width='5px';cxd.style.height='5px';});
    el.addEventListener('mouseleave',()=>{cx1.style.opacity='.7';cxd.style.width='3px';cxd.style.height='3px';});
  });
}

const ROLES=['SALES REP','DEPLOY ENG','CHANNEL MGR','FINANCE LEAD','COMPLIANCE','SUPPORT LEAD','EXECUTIVE'];
let roleIdx=0;
function cycleRole(btn){
  roleIdx=(roleIdx+1)%ROLES.length;
  btn.textContent=ROLES[roleIdx];
  document.querySelector('.sbu-dept').textContent=ROLES[roleIdx].split(' ')[0];
}

// init
switchDept('sales',document.getElementById('tab-sales'));
</script>
