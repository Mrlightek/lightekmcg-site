<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lightek Media Communications Group — Infrastructure for the Sovereign Economy</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;cursor:none;}
:root{
  --steel:#040C18;--steel2:#07121F;--steel3:#0A1628;--steel4:#0E1E36;
  --panel:#0C1830;--card:#101E38;--lift:#152440;
  --cyan:#00C8E8;--cyan2:#00E0FF;--cyan3:#60EEFF;
  --gold:#C49820;--gold2:#DEB030;--gold3:#F0C840;
  --signal:#0070C8;--signal2:#0090E8;--signal3:#20AEFF;
  --red:#D82020;--red2:#F03030;
  --lime:#28C040;--lime2:#40E058;
  --white:#EEF4FC;--off:#C8D8EC;--muted:#5A7090;--dim:#1A2840;
  --fc:'Barlow Condensed',sans-serif;
  --fb:'IBM Plex Sans',sans-serif;
  --fm:'Space Mono',monospace;
}
html{scroll-behavior:smooth;}
body{background:var(--steel);color:var(--white);font-family:var(--fb);}

/* circuit-board grid */
body::before{
  content:'';position:fixed;inset:0;
  background-image:
    linear-gradient(rgba(0,200,232,.015) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,200,232,.015) 1px,transparent 1px),
    linear-gradient(rgba(0,200,232,.006) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,200,232,.006) 1px,transparent 1px);
  background-size:80px 80px,80px 80px,16px 16px,16px 16px;
  pointer-events:none;z-index:0;
}

/* cursor */
#cur{width:6px;height:6px;background:var(--cyan);position:fixed;z-index:9999;pointer-events:none;transform:translate(-50%,-50%);box-shadow:0 0 12px rgba(0,200,232,.9);transition:width .15s,height .15s;}
#cur2{width:28px;height:28px;border:1px solid rgba(0,200,232,.2);position:fixed;z-index:9998;pointer-events:none;transform:translate(-50%,-50%);transition:left .1s cubic-bezier(.16,1,.3,1),top .1s cubic-bezier(.16,1,.3,1),width .2s,height .2s;}

@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
@keyframes pulse{0%,100%{opacity:.6;transform:scale(1)}50%{opacity:1;transform:scale(1.01)}}
@keyframes shimmer{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes scanH{from{left:-100%}to{left:200%}}
@keyframes rise{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
@keyframes countUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.fade-up{opacity:0;transform:translateY(24px);transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1);}
.fade-up.vis{opacity:1;transform:none;}

/* ═══════════════════════════════════════════════
   TOPNAV
═══════════════════════════════════════════════ */
.topnav{
  position:fixed;top:0;left:0;right:0;height:60px;
  background:rgba(4,12,24,.98);
  border-bottom:1px solid rgba(0,200,232,.08);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 48px;z-index:200;
}
.topnav::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(0,200,232,.3),rgba(0,200,232,.5),rgba(0,200,232,.3),transparent);}

.nav-logo{display:flex;align-items:center;gap:12px;}
.nl-mark{width:32px;height:32px;border:1.5px solid rgba(0,200,232,.4);display:flex;align-items:center;justify-content:center;font-family:var(--fc);font-size:18px;font-weight:800;letter-spacing:.06em;color:var(--cyan);position:relative;}
.nl-mark::before{content:'';position:absolute;inset:-3px;border:1px solid rgba(0,200,232,.1);}
.nl-text{}
.nl-name{font-family:var(--fc);font-size:15px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--white);line-height:1;}
.nl-sub{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
.nav-links{display:flex;gap:0;align-items:center;}
.nav-link{font-family:var(--fm);font-size:7px;letter-spacing:.18em;text-transform:uppercase;color:rgba(238,244,252,.38);padding:0 18px;height:60px;display:flex;align-items:center;border-bottom:2px solid transparent;cursor:pointer;transition:all .2s;background:transparent;border-top:none;border-left:none;border-right:none;}
.nav-link:hover{color:rgba(238,244,252,.8);}
.nav-link.active{color:var(--cyan);border-bottom-color:var(--cyan);}
.nav-right{display:flex;align-items:center;gap:10px;}
.nav-tag{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);}
.nav-cta{font-family:var(--fc);font-size:14px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:var(--cyan);color:var(--steel);border:none;padding:9px 22px;cursor:pointer;transition:all .2s;}
.nav-cta:hover{background:var(--cyan2);}

/* ═══════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════ */
.hero{
  min-height:100vh;padding:120px 80px 80px;
  display:flex;flex-direction:column;justify-content:center;
  position:relative;z-index:1;overflow:hidden;
}
/* scan line */
.hero-scan{position:absolute;top:0;bottom:0;width:120px;background:linear-gradient(to right,transparent,rgba(0,200,232,.025),transparent);animation:scanH 12s linear infinite;pointer-events:none;}
.hero-vignette{position:absolute;inset:0;background:radial-gradient(ellipse 80% 70% at 75% 50%,rgba(0,200,232,.06) 0%,transparent 60%),radial-gradient(ellipse 60% 50% at 20% 80%,rgba(196,152,32,.05) 0%,transparent 60%);pointer-events:none;}

.hero-content{max-width:1000px;position:relative;z-index:2;}
.hero-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:20px;}
.he-tag{font-family:var(--fm);font-size:6px;letter-spacing:.32em;text-transform:uppercase;color:var(--cyan);border:1px solid rgba(0,200,232,.2);padding:4px 14px;background:rgba(0,200,232,.04);}
.he-sep{width:1px;height:14px;background:rgba(0,200,232,.2);}
.he-dymond{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:rgba(196,152,32,.7);}

.hero-headline{
  font-family:var(--fc);
  font-size:clamp(52px,10vw,144px);
  font-weight:900;
  letter-spacing:.02em;
  line-height:.85;
  margin-bottom:16px;
}
.hh-1{display:block;color:var(--white);}
.hh-2{display:block;color:var(--cyan);position:relative;}
.hh-2::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:3px;background:var(--cyan);animation:expandLine 1.5s 1s cubic-bezier(.16,1,.3,1) forwards;}
@keyframes expandLine{from{width:0}to{width:100%}}
.hh-3{display:block;color:transparent;-webkit-text-stroke:1px rgba(238,244,252,.07);}

.hero-body{
  font-family:var(--fb);font-weight:300;
  font-size:clamp(15px,1.5vw,20px);
  color:rgba(238,244,252,.45);
  max-width:680px;
  line-height:2;
  margin-bottom:32px;
}
.hero-body strong{color:var(--white);font-weight:500;}
.hero-body em{color:var(--cyan);font-style:normal;}

/* what lightek is */
.inception-diagram{
  display:flex;align-items:center;gap:0;
  margin-bottom:36px;
  flex-wrap:wrap;
  gap:6px;
}
.id-node{
  background:var(--card);
  border:1px solid rgba(0,200,232,.1);
  padding:10px 16px;
  position:relative;
}
.id-node.active{border-color:rgba(0,200,232,.4);background:rgba(0,200,232,.07);}
.id-node.gold-node{border-color:rgba(196,152,32,.3);background:rgba(196,152,32,.06);}
.idn-label{font-family:var(--fm);font-size:5px;letter-spacing:.2em;text-transform:uppercase;margin-bottom:3px;}
.idn-name{font-family:var(--fc);font-size:clamp(12px,1.8vw,18px);font-weight:700;letter-spacing:.06em;line-height:1;}
.id-arrow{font-family:var(--fc);font-size:22px;font-weight:700;color:var(--cyan);opacity:.4;padding:0 4px;}

.hero-ctas{display:flex;gap:8px;flex-wrap:wrap;}
.hero-btn-primary{font-family:var(--fc);font-size:16px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:var(--cyan);color:var(--steel);border:none;padding:14px 32px;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;}
.hero-btn-primary::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transform:translateX(-100%);transition:transform .5s;}
.hero-btn-primary:hover{background:var(--cyan2);}
.hero-btn-primary:hover::before{transform:translateX(100%);}
.hero-btn-secondary{font-family:var(--fc);font-size:16px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:transparent;color:rgba(238,244,252,.55);border:1px solid rgba(238,244,252,.15);padding:14px 32px;cursor:pointer;transition:all .22s;}
.hero-btn-secondary:hover{border-color:rgba(238,244,252,.4);color:var(--white);}

/* live ticker */
.hero-ticker{
  position:absolute;bottom:0;left:0;right:0;height:36px;
  background:rgba(0,200,232,.07);
  border-top:1px solid rgba(0,200,232,.12);
  display:flex;align-items:center;overflow:hidden;
}
.ht-badge{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--steel);background:var(--cyan);padding:0 16px;height:100%;display:flex;align-items:center;flex-shrink:0;font-weight:700;}
.ht-scroll{display:flex;animation:tickerScroll 50s linear infinite;white-space:nowrap;}
@keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.ht-item{font-family:var(--fm);font-size:7px;letter-spacing:.1em;color:rgba(0,200,232,.7);padding:0 40px;}

/* ═══════════════════════════════════════════════
   SECTION CHROME
═══════════════════════════════════════════════ */
.section{padding:84px 80px;position:relative;z-index:1;}
.section.alt{background:rgba(7,12,22,.95);}
.section.dark{background:rgba(3,6,12,.98);}
.sec-eyebrow{font-family:var(--fm);font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:var(--cyan);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.sec-eyebrow::before{content:'◈';}
.sec-title{font-family:var(--fc);font-size:clamp(36px,6vw,88px);font-weight:900;letter-spacing:.03em;line-height:.87;margin-bottom:12px;}
.sec-title .cc{color:var(--cyan);}
.sec-title .cg{color:var(--gold2);}
.sec-title .cs{color:var(--signal2);}
.sec-sub{font-family:var(--fb);font-weight:300;font-size:clamp(14px,1.4vw,18px);color:rgba(238,244,252,.38);max-width:640px;line-height:2;margin-bottom:48px;}

/* ═══════════════════════════════════════════════
   THE ARCHITECTURE — 4-LAYER DIAGRAM
═══════════════════════════════════════════════ */
.arch-diagram{max-width:1100px;margin:0 auto;}
.arch-layers{display:flex;flex-direction:column;gap:3px;}
.arch-layer{
  display:grid;grid-template-columns:180px 1fr;gap:0;
  border:1px solid rgba(0,200,232,.08);
  position:relative;overflow:hidden;
  transition:border-color .25s;
  cursor:pointer;
}
.arch-layer:hover{border-color:rgba(0,200,232,.25);}
.arch-layer::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;}
.al-num{background:rgba(0,200,232,.06);border-right:1px solid rgba(0,200,232,.08);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;text-align:center;}
.al-num-val{font-family:var(--fc);font-size:40px;font-weight:900;line-height:1;margin-bottom:4px;}
.al-num-lbl{font-family:var(--fm);font-size:5px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
.al-content{padding:20px 28px;display:flex;gap:24px;align-items:center;}
.alc-main{flex:1;}
.alc-name{font-family:var(--fc);font-size:clamp(18px,2.5vw,28px);font-weight:800;letter-spacing:.06em;margin-bottom:4px;}
.alc-entity{font-family:var(--fm);font-size:7px;letter-spacing:.16em;text-transform:uppercase;margin-bottom:6px;}
.alc-desc{font-family:var(--fb);font-weight:300;font-size:clamp(12px,1.2vw,14px);color:rgba(238,244,252,.45);line-height:1.7;}
.alc-right{text-align:right;flex-shrink:0;}
.alcr-arrow{font-family:var(--fc);font-size:28px;font-weight:900;color:rgba(0,200,232,.15);}
.alcr-tag{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-top:4px;}
/* flow arrows between layers */
.arch-connector{height:28px;display:flex;align-items:center;justify-content:center;position:relative;}
.arch-connector::before{content:'↓';font-family:var(--fc);font-size:18px;font-weight:900;color:rgba(0,200,232,.2);}
.arch-connector-line{position:absolute;left:50%;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,rgba(0,200,232,.15),rgba(0,200,232,.06));transform:translateX(-50%);}

/* ═══════════════════════════════════════════════
   PRODUCT CATALOG PREVIEW
═══════════════════════════════════════════════ */
.catalog-preview{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;max-width:1100px;margin:0 auto;}
@media(max-width:1000px){.catalog-preview{grid-template-columns:repeat(2,1fr);}}
.cat-card{background:var(--card);border:1px solid rgba(0,200,232,.06);padding:20px 18px;position:relative;overflow:hidden;cursor:pointer;transition:all .25s;}
.cat-card:hover{border-color:rgba(0,200,232,.22);transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,0,0,.5);}
.cat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.cc-sku{font-family:var(--fm);font-size:5px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;display:flex;justify-content:space-between;}
.cc-icon{font-size:24px;display:block;margin-bottom:9px;}
.cc-name{font-family:var(--fc);font-size:clamp(15px,1.8vw,20px);font-weight:700;letter-spacing:.06em;line-height:1.1;margin-bottom:4px;}
.cc-category{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;margin-bottom:8px;}
.cc-desc{font-family:var(--fb);font-weight:300;font-size:11px;color:rgba(238,244,252,.38);line-height:1.6;margin-bottom:10px;}
.cc-price-row{display:flex;justify-content:space-between;align-items:baseline;}
.cc-price{font-family:var(--fc);font-size:clamp(16px,2vw,22px);font-weight:700;}
.cc-period{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.cc-add{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--cyan);border:1px solid rgba(0,200,232,.2);padding:4px 9px;background:rgba(0,200,232,.04);cursor:pointer;transition:all .2s;}
.cc-add:hover{background:rgba(0,200,232,.1);}

/* ═══════════════════════════════════════════════
   REVENUE MODEL DIAGRAM
═══════════════════════════════════════════════ */
.rev-model{max-width:1100px;margin:0 auto;}
.rm-flow{display:grid;grid-template-columns:1fr 40px 1fr 40px 1fr 40px 1fr;gap:0;align-items:center;margin-bottom:32px;}
@media(max-width:900px){.rm-flow{grid-template-columns:1fr;gap:8px;}}
.rmf-node{background:var(--card);border:1px solid rgba(0,200,232,.08);padding:18px;text-align:center;position:relative;}
.rmf-node::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.rmfn-tier{font-family:var(--fm);font-size:5px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;}
.rmfn-name{font-family:var(--fc);font-size:clamp(14px,2vw,20px);font-weight:800;letter-spacing:.06em;margin-bottom:4px;}
.rmfn-take{font-family:var(--fc);font-size:clamp(18px,2.5vw,28px);font-weight:900;}
.rmfn-sub{font-family:var(--fm);font-size:6px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-top:2px;}
.rm-arrow{font-family:var(--fc);font-size:24px;font-weight:900;color:rgba(0,200,232,.2);text-align:center;}

/* totals */
.rm-totals{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;}
.rmt-cell{background:var(--panel);border:1px solid rgba(0,200,232,.07);padding:18px;text-align:center;}
.rmtc-label{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
.rmtc-val{font-family:var(--fc);font-size:clamp(20px,3vw,36px);font-weight:900;letter-spacing:.04em;display:block;line-height:1;}
.rmtc-sub{font-family:var(--fm);font-size:6px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-top:3px;}

/* ═══════════════════════════════════════════════
   RESELLER TIERS
═══════════════════════════════════════════════ */
.tier-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;max-width:1100px;margin:0 auto;}
@media(max-width:800px){.tier-grid{grid-template-columns:1fr;}}
.tier-card{background:var(--card);border:1px solid rgba(0,200,232,.07);padding:28px 26px;position:relative;overflow:hidden;transition:all .28s;}
.tier-card:hover{border-color:rgba(0,200,232,.22);}
.tier-card.featured{border-color:rgba(0,200,232,.25);background:linear-gradient(180deg,rgba(0,200,232,.05) 0%,var(--card) 50%);}
.tier-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.tc2-badge{display:inline-block;font-family:var(--fm);font-size:5px;letter-spacing:.2em;text-transform:uppercase;background:var(--cyan);color:var(--steel);padding:3px 9px;margin-bottom:8px;}
.tc2-tier{font-family:var(--fm);font-size:6px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
.tc2-name{font-family:var(--fc);font-size:clamp(24px,3vw,36px);font-weight:900;letter-spacing:.05em;margin-bottom:5px;}
.tc2-tagline{font-family:var(--fb);font-weight:300;font-style:italic;font-size:12px;color:rgba(238,244,252,.35);margin-bottom:18px;line-height:1.6;}
.tc2-price-block{margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid rgba(0,200,232,.08);}
.tc2p-buy{font-family:var(--fc);font-size:clamp(14px,1.8vw,18px);font-weight:700;letter-spacing:.06em;display:block;margin-bottom:3px;}
.tc2p-sell{font-family:var(--fc);font-size:clamp(20px,2.5vw,28px);font-weight:900;letter-spacing:.04em;display:block;margin-bottom:3px;}
.tc2p-margin{font-family:var(--fm);font-size:8px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.tc2-benefits{display:flex;flex-direction:column;gap:6px;margin-bottom:18px;}
.tc2b-item{display:flex;gap:8px;align-items:flex-start;font-family:var(--fb);font-weight:300;font-size:12px;color:rgba(238,244,252,.5);line-height:1.4;}
.tc2b-item.yes::before{content:'◈';color:var(--cyan);flex-shrink:0;font-size:9px;margin-top:2px;}
.tc2b-item.no::before{content:'—';color:rgba(238,244,252,.2);flex-shrink:0;font-size:9px;margin-top:2px;}
.tc2b-item.no{opacity:.4;}
.tc2-cta{display:block;width:100%;font-family:var(--fc);font-size:15px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;border:1px solid;padding:12px;cursor:pointer;transition:all .22s;text-align:center;}

/* ═══════════════════════════════════════════════
   SOCIAL PROOF / LOGOS
═══════════════════════════════════════════════ */
.social-proof{max-width:1100px;margin:0 auto;text-align:center;}
.sp-label{font-family:var(--fm);font-size:7px;letter-spacing:.28em;text-transform:uppercase;color:var(--muted);margin-bottom:24px;}
.sp-logos{display:grid;grid-template-columns:repeat(5,1fr);gap:3px;}
@media(max-width:700px){.sp-logos{grid-template-columns:repeat(3,1fr);}}
.spl-card{background:var(--card);border:1px solid rgba(238,244,252,.04);padding:20px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;cursor:pointer;transition:all .2s;}
.spl-card:hover{border-color:rgba(0,200,232,.15);}
.spl-icon{font-size:22px;}
.spl-name{font-family:var(--fc);font-size:13px;font-weight:700;letter-spacing:.08em;text-align:center;}
.spl-type{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-align:center;}

/* ═══════════════════════════════════════════════
   FINAL CTA SECTION
═══════════════════════════════════════════════ */
.final-cta{
  padding:100px 80px;
  text-align:center;
  background:linear-gradient(135deg,rgba(0,200,232,.04),rgba(0,112,200,.06),rgba(196,152,32,.04));
  border-top:1px solid rgba(0,200,232,.1);
  border-bottom:1px solid rgba(0,200,232,.1);
  position:relative;overflow:hidden;
  z-index:1;
}
