<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STORYLINE — The Arena</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Barlow+Condensed:wght@200;300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;cursor:none;}
:root{
  --void:#020108;--deep:#06040E;--mid:#0A0814;--panel:#0F0C1C;--card:#131020;--lift:#181428;
  --white:#F2EEE6;--off:#C4BAB0;--muted:#524C64;--dim:#181428;
  /* arena accent palette */
  --gold:#D4A010;--gold2:#ECC020;--gold3:#FCD840;--gold4:#FEE870;
  --blood:#C01828;--blood2:#E02030;--blood3:#FF3848;
  --cyan:#00B8D8;--cyan2:#00D4F8;
  --arena:#A03010;--arena2:#C84018;--arena3:#F05020;
  /* faction colors */
  --fac-a:#CC2830;--fac-b:#2858C8;--fac-c:#18A860;--fac-d:#9820C8;
  /* status */
  --live:#E02030;--win:#20C870;--loss:#5A5468;--tbd:#C89010;
  --fb:'Bebas Neue',sans-serif;
  --fg:'EB Garamond',serif;
  --fc:'Barlow Condensed',sans-serif;
  --fp:'Playfair Display',serif;
  --fm:'Space Mono',monospace;
}
html{scroll-behavior:smooth;}
body{background:var(--void);color:var(--white);font-family:var(--fg);overflow-x:hidden;}

/* grain overlay */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");background-size:200px;pointer-events:none;z-index:0;opacity:.6;}

/* cursor — crosshair for arena */
#cur{width:10px;height:10px;position:fixed;z-index:9999;pointer-events:none;transform:translate(-50%,-50%);}
#cur::before{content:'';position:absolute;left:50%;top:0;bottom:0;width:1px;background:var(--gold2);transform:translateX(-50%);}
#cur::after{content:'';position:absolute;top:50%;left:0;right:0;height:1px;background:var(--gold2);transform:translateY(-50%);}
#cur-dot{width:4px;height:4px;background:var(--gold2);position:fixed;z-index:9999;pointer-events:none;transform:translate(-50%,-50%);box-shadow:0 0 8px var(--gold);}
#cur2{width:36px;height:36px;border:1px solid rgba(212,160,16,.2);position:fixed;z-index:9998;pointer-events:none;transform:translate(-50%,-50%);transition:left .1s cubic-bezier(.16,1,.3,1),top .1s,width .2s,height .2s;}

@keyframes blink{0%,100%{opacity:1}50%{opacity:.1}}
@keyframes pulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.02)}}
@keyframes scanLine{from{top:-3%}to{top:103%}}
@keyframes goldShimmer{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes arenaGlow{0%,100%{box-shadow:0 0 20px rgba(212,160,16,.2)}50%{box-shadow:0 0 40px rgba(212,160,16,.4),0 0 80px rgba(212,160,16,.1)}}
@keyframes bracketDraw{from{stroke-dashoffset:1000}to{stroke-dashoffset:0}}
@keyframes voteCount{from{transform:scale(.95);opacity:.5}to{transform:scale(1);opacity:1}}
@keyframes waveBar{0%,100%{transform:scaleY(.3)}50%{transform:scaleY(1)}}
@keyframes slideIn{from{opacity:0;transform:translateX(-16px)}to{opacity:1;transform:none}}
@keyframes chatIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
@keyframes countdownPulse{0%,100%{color:var(--gold2)}50%{color:var(--gold4)}}
.fade-up{opacity:0;transform:translateY(20px);transition:opacity .85s cubic-bezier(.16,1,.3,1),transform .85s cubic-bezier(.16,1,.3,1);}
.fade-up.vis{opacity:1;transform:none;}

/* VIEWS */
.view{display:none;}.view.active{display:block;}

/* ═══════════════════════════════════════════════
   TOPNAV
═══════════════════════════════════════════════ */
.topnav{
  position:fixed;top:0;left:0;right:0;z-index:400;
  height:56px;background:rgba(2,1,8,.98);
  border-bottom:1px solid rgba(212,160,16,.1);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;
}
.topnav::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),var(--gold2),var(--gold),transparent);opacity:.35;}
.tn-left{display:flex;align-items:center;gap:14px;}
.tn-logo{font-family:var(--fb);font-size:20px;letter-spacing:.14em;cursor:pointer;color:var(--white);}
.tn-logo span{background:linear-gradient(to right,var(--gold),var(--gold2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.tn-arena-badge{display:flex;align-items:center;gap:6px;padding:4px 12px;background:rgba(212,160,16,.08);border:1px solid rgba(212,160,16,.22);animation:arenaGlow 4s infinite;}
.tnab-icon{font-size:12px;}
.tnab-text{font-family:var(--fm);font-size:6px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold2);}
.tn-season{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);}
.tn-sep{width:1px;height:18px;background:rgba(212,160,16,.12);}
.tn-tabs{display:flex;gap:0;}
.tn-tab{font-family:var(--fm);font-size:7px;letter-spacing:.15em;text-transform:uppercase;color:rgba(242,238,230,.3);padding:0 16px;height:56px;display:flex;align-items:center;border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;}
.tn-tab:hover{color:rgba(242,238,230,.7);}
.tn-tab.on{color:var(--gold2);border-bottom-color:var(--gold2);}
.tn-tab.live-tab{color:rgba(224,32,48,.7);}
.tn-tab.live-tab.on{color:var(--live);border-bottom-color:var(--live);}
.tn-right{display:flex;align-items:center;gap:8px;}
.tn-live-pill{display:flex;align-items:center;gap:5px;padding:5px 12px;background:rgba(224,32,48,.1);border:1px solid rgba(224,32,48,.3);cursor:pointer;animation:arenaGlow 3s infinite;}
.tnlp-dot{width:5px;height:5px;border-radius:50%;background:var(--live);animation:blink .5s infinite;}
.tnlp-text{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:var(--live);}
.tn-codex-btn{font-family:var(--fc);font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(212,160,16,.25);color:var(--gold2);background:rgba(212,160,16,.06);padding:7px 16px;cursor:pointer;transition:all .2s;}
.tn-codex-btn:hover{background:rgba(212,160,16,.12);}

/* ═══════════════════════════════════════════════
   SHARED COMPONENTS
═══════════════════════════════════════════════ */
.section-label{font-family:var(--fm);font-size:7px;letter-spacing:.26em;text-transform:uppercase;color:var(--gold2);display:flex;align-items:center;gap:6px;margin-bottom:6px;}
.section-label::before{content:'◈';}
.section-title{font-family:var(--fb);font-size:clamp(28px,4vw,56px);letter-spacing:.05em;line-height:.88;margin-bottom:6px;}
.section-sub{font-family:var(--fg);font-style:italic;font-size:clamp(13px,1.4vw,16px);color:rgba(242,238,230,.38);line-height:2;}
.gold-stripe{position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--gold),var(--gold2),var(--gold));}
.blood-stripe{position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--blood),var(--blood2),var(--blood));}
.card-base{background:var(--panel);border:1px solid rgba(212,160,16,.07);position:relative;overflow:hidden;transition:all .22s;}
.card-base:hover{border-color:rgba(212,160,16,.2);}

/* stat cell */
.stat-cell{background:var(--card);border:1px solid rgba(212,160,16,.07);padding:12px 16px;position:relative;}
.sc-val{font-family:var(--fb);font-size:clamp(22px,3vw,40px);letter-spacing:.04em;display:block;line-height:1;}
.sc-lbl{font-family:var(--fm);font-size:5px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);display:block;margin-top:3px;}
.sc-delta{font-family:var(--fm);font-size:6px;margin-top:2px;}
.delta-up{color:var(--win);}
.delta-down{color:var(--blood2);}

/* ═══════════════════════════════════════════════
   VIEW 1: ARENA HOME
═══════════════════════════════════════════════ */
#view-home{padding-top:56px;}

/* championship hero */
.arena-hero{
  min-height:88vh;display:flex;flex-direction:column;justify-content:flex-end;
  padding:48px;position:relative;overflow:hidden;
}
.ah-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 30%,rgba(192,24,40,.08) 0%,transparent 50%),radial-gradient(ellipse at 20% 80%,rgba(212,160,16,.06) 0%,transparent 50%),linear-gradient(to bottom,rgba(2,1,8,.3),rgba(2,1,8,.95));}
/* arena grid lines - stadium feel */
.ah-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(212,160,16,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(212,160,16,.018) 1px,transparent 1px);background-size:60px 60px;}
/* spotlight effect */
.ah-spotlight{position:absolute;top:-20%;left:50%;transform:translateX(-50%);width:60%;height:80%;background:radial-gradient(ellipse at center,rgba(212,160,16,.06) 0%,transparent 70%);pointer-events:none;}
.ah-scan{position:absolute;left:0;right:0;height:2px;background:linear-gradient(to right,transparent,rgba(212,160,16,.04),transparent);animation:scanLine 18s linear infinite;pointer-events:none;}
.ah-content{position:relative;z-index:2;max-width:800px;}
.ah-season{font-family:var(--fm);font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold2);margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.ah-season::before{content:'◈';}
.ah-title{font-family:var(--fb);font-size:clamp(60px,12vw,160px);letter-spacing:.04em;line-height:.82;margin-bottom:8px;background:linear-gradient(160deg,var(--white),var(--gold3),var(--white));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.ah-sub{font-family:var(--fg);font-style:italic;font-size:clamp(14px,1.6vw,19px);color:rgba(242,238,230,.45);max-width:560px;line-height:2;margin-bottom:22px;}
/* featured matchup teaser in hero */
.ah-matchup-teaser{display:flex;align-items:center;gap:0;max-width:680px;margin-bottom:24px;}
.ahmt-side{flex:1;padding:14px 20px;background:rgba(242,238,230,.04);border:1px solid rgba(242,238,230,.07);}
.ahmt-side.left{border-right:none;}
.ahmt-side.right{border-left:none;text-align:right;}
.ahmts-label{font-family:var(--fm);font-size:5px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;}
.ahmts-project{font-family:var(--fb);font-size:clamp(16px,2.5vw,26px);letter-spacing:.06em;}
.ahmts-creator{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:rgba(242,238,230,.4);}
.ahmts-pct{font-family:var(--fc);font-size:clamp(28px,4vw,44px);font-weight:900;line-height:1;margin-top:5px;}
.ahmt-vs{padding:0 16px;display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0;}
.ahmtv-vs{font-family:var(--fb);font-size:28px;letter-spacing:.06em;background:linear-gradient(to bottom,var(--gold),var(--blood2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.ahmtv-countdown{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold2);animation:countdownPulse 1s infinite;}
.ah-actions{display:flex;gap:6px;}
.ah-btn-primary{font-family:var(--fc);font-size:15px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;background:linear-gradient(135deg,var(--gold),var(--gold2));color:var(--void);border:none;padding:13px 32px;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;}
.ah-btn-primary::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.2),transparent);transform:translateX(-100%);transition:transform .5s;}
.ah-btn-primary:hover::before{transform:translateX(100%);}
.ah-btn-outline{font-family:var(--fc);font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:transparent;color:rgba(242,238,230,.45);border:1px solid rgba(242,238,230,.15);padding:13px 24px;cursor:pointer;transition:all .22s;}
.ah-btn-outline:hover{border-color:rgba(242,238,230,.38);color:var(--white);}
/* arena stats strip */
.arena-stats{display:grid;grid-template-columns:repeat(5,1fr);gap:3px;padding:0 48px;background:rgba(2,1,8,.95);border-top:1px solid rgba(212,160,16,.1);border-bottom:1px solid rgba(212,160,16,.07);}
/* section padding */
.arena-section{padding:36px 48px;}

/* season standings */
.standings-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
@media(max-width:900px){.standings-grid{grid-template-columns:1fr;}}
.standing-row{display:flex;align-items:center;gap:12px;padding:11px 14px;background:var(--card);border:1px solid rgba(212,160,16,.06);transition:all .2s;cursor:pointer;}
.standing-row:hover{border-color:rgba(212,160,16,.2);}
.standing-row.champion{border-color:rgba(212,160,16,.3);background:rgba(212,160,16,.05);}
.sr-rank{font-family:var(--fb);font-size:22px;letter-spacing:.04em;min-width:36px;text-align:right;}
.sr-rank.gold{color:var(--gold2);}
.sr-rank.silver{color:rgba(200,195,190,.6);}
.sr-rank.bronze{color:rgba(180,110,60,.6);}
.sr-info{flex:1;}
.sri-name{font-family:var(--fb);font-size:clamp(14px,2vw,19px);letter-spacing:.06em;}
.sri-creator{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.sr-record{text-align:right;}
.srr-wins{font-family:var(--fc);font-size:clamp(18px,2.5vw,26px);font-weight:900;line-height:1;}
.srr-pts{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.sr-crown{font-size:14px;flex-shrink:0;}

/* faction power bar */
.faction-powers{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;}
.fp-card{background:var(--card);border:1px solid rgba(242,238,230,.05);padding:14px;position:relative;overflow:hidden;cursor:pointer;transition:all .22s;}
.fp-card:hover{border-color:rgba(242,238,230,.15);}
.fpc-bar{position:absolute;bottom:0;left:0;right:0;transition:height .8s ease;}
.fpc-top{position:relative;z-index:1;display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;}
.fpct-name{font-family:var(--fb);font-size:clamp(12px,1.8vw,17px);letter-spacing:.06em;}
.fpct-seal{font-size:18px;}
.fpc-pct{font-family:var(--fc);font-size:clamp(28px,4vw,44px);font-weight:900;position:relative;z-index:1;line-height:1;}
.fpc-label{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);position:relative;z-index:1;margin-top:2px;}

/* ═══════════════════════════════════════════════
   VIEW 2: THE BATTLE BRACKET
═══════════════════════════════════════════════ */
#view-bracket{padding-top:56px;}
.bracket-wrap{padding:32px 40px;overflow-x:auto;}
.bracket-hdr{text-align:center;margin-bottom:28px;}
/* bracket layout */
.bracket-container{display:flex;gap:0;min-width:1100px;position:relative;}
.bracket-round{display:flex;flex-direction:column;flex:1;min-width:220px;}
.br-label{font-family:var(--fm);font-size:7px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);text-align:center;padding-bottom:10px;border-bottom:1px solid rgba(212,160,16,.08);margin-bottom:0;}
.br-matches{display:flex;flex-direction:column;justify-content:space-around;flex:1;padding:8px 0;}
/* matchup card */
.matchup{background:var(--panel);border:1px solid rgba(242,238,230,.06);margin:6px 8px;position:relative;overflow:hidden;cursor:pointer;transition:all .25s;}
.matchup:hover{border-color:rgba(212,160,16,.25);}
.matchup.featured{border-color:rgba(212,160,16,.3);animation:arenaGlow 4s infinite;}
.matchup.completed{opacity:.85;}
.mu-round-stripe{position:absolute;top:0;left:0;right:0;height:2px;}
.mu-competitor{display:flex;align-items:center;gap:9px;padding:10px 12px;border-bottom:1px solid rgba(242,238,230,.04);position:relative;transition:background .15s;}
.mu-competitor:last-child{border-bottom:none;}
.mu-competitor.winner{background:rgba(32,200,112,.06);}
.mu-competitor.loser{opacity:.45;}
.muc-icon{font-size:16px;flex-shrink:0;}
.muc-info{flex:1;}
.muci-name{font-family:var(--fb);font-size:clamp(11px,1.5vw,14px);letter-spacing:.05em;line-height:1;}
.muci-creator{font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);}
.muc-score{font-family:var(--fc);font-size:clamp(16px,2vw,22px);font-weight:900;line-height:1;}
.muc-score.leading{color:var(--gold2);}
.muc-score.winning{color:var(--win);}
.muc-score.losing{color:var(--muted);}
.muc-badge{position:absolute;right:8px;top:50%;transform:translateY(-50%);font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:2px 6px;}
.mu-badge-canon{border-color:rgba(32,200,112,.3);color:var(--win);}
.mu-badge-disputed{border-color:rgba(200,144,12,.3);color:var(--tbd);}
.mu-badge-live{border-color:rgba(224,32,48,.35);color:var(--live);animation:blink .8s infinite;}
.mu-badge-tbd{border-color:rgba(82,76,100,.3);color:var(--muted);}
/* vote bar at bottom of matchup */
.mu-vote-bar{height:4px;display:flex;}
.muvb-a{transition:width .8s ease;}
.muvb-b{transition:width .8s ease;}
/* bracket connector lines SVG */
.bracket-connectors{position:absolute;inset:0;pointer-events:none;}
/* championship match */
.championship-slot{background:rgba(212,160,16,.07);border:2px solid rgba(212,160,16,.3);margin:6px 8px;padding:18px;text-align:center;position:relative;animation:arenaGlow 3s infinite;}
.cs-label{font-family:var(--fm);font-size:7px;letter-spacing:.24em;text-transform:uppercase;color:var(--gold2);margin-bottom:6px;}
.cs-trophy{font-size:32px;display:block;margin-bottom:8px;}
.cs-title{font-family:var(--fb);font-size:clamp(18px,2.5vw,28px);letter-spacing:.07em;color:var(--gold2);margin-bottom:4px;}
.cs-sub{font-family:var(--fg);font-style:italic;font-size:11px;color:rgba(242,238,230,.38);}

/* ═══════════════════════════════════════════════
   VIEW 3: CHARACTER DRAFT
═══════════════════════════════════════════════ */
#view-draft{padding-top:56px;}
.draft-layout{display:grid;grid-template-columns:1fr 320px;min-height:calc(100vh - 56px);}
/* draft board */
.draft-board{padding:28px 32px;overflow-y:auto;}
.db-my-roster{margin-bottom:24px;}
.dbmr-title{font-family:var(--fc);font-size:18px;font-weight:800;letter-spacing:.07em;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;}
.dbmrt-score{font-family:var(--fb);font-size:22px;letter-spacing:.05em;color:var(--gold2);}
/* roster slots */
.roster-slots{display:grid;grid-template-columns:repeat(5,1fr);gap:4px;margin-bottom:14px;}
@media(max-width:1000px){.roster-slots{grid-template-columns:repeat(3,1fr);}}
.roster-slot{background:var(--card);border:1px solid rgba(212,160,16,.08);padding:12px 10px;text-align:center;position:relative;min-height:100px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .22s;}
.roster-slot.filled{border-color:rgba(212,160,16,.25);background:rgba(212,160,16,.05);}
.roster-slot.empty{border-style:dashed;border-color:rgba(242,238,230,.08);opacity:.6;}
.roster-slot:hover{border-color:rgba(212,160,16,.3);}
.rs-icon{font-size:22px;display:block;margin-bottom:5px;}
.rs-name{font-family:var(--fb);font-size:clamp(10px,1.4vw,13px);letter-spacing:.05em;line-height:1.1;}
.rs-pts{font-family:var(--fc);font-size:clamp(16px,2vw,22px);font-weight:900;color:var(--gold2);line-height:1;}
.rs-pts-lbl{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.rs-trend{font-family:var(--fm);font-size:6px;font-weight:700;margin-top:2px;}
/* available characters */
.db-available{margin-bottom:24px;}
.dba-filters{display:flex;gap:4px;margin-bottom:12px;flex-wrap:wrap;}
.dbaf-pill{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;border:1px solid rgba(242,238,230,.1);background:transparent;color:rgba(242,238,230,.35);padding:5px 12px;cursor:pointer;transition:all .18s;}
.dbaf-pill.on{border-color:var(--gold);color:var(--gold2);background:rgba(212,160,16,.08);}
/* character draft card */
.char-draft-card{display:grid;grid-template-columns:auto 1fr auto auto;gap:12px;align-items:center;padding:11px 14px;background:var(--card);border:1px solid rgba(242,238,230,.05);margin-bottom:3px;cursor:pointer;transition:all .22s;}
.char-draft-card:hover{border-color:rgba(212,160,16,.2);background:rgba(212,160,16,.04);}
.char-draft-card.drafted{opacity:.4;pointer-events:none;}
.cdc-icon{font-size:22px;}
.cdc-info{}
.cdci-name{font-family:var(--fb);font-size:clamp(14px,2vw,18px);letter-spacing:.06em;line-height:1;}
.cdci-role{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.cdci-projects{font-family:var(--fg);font-style:italic;font-size:11px;color:rgba(242,238,230,.38);margin-top:1px;}
.cdc-stats{text-align:right;}
.cdcs-pts{font-family:var(--fc);font-size:clamp(18px,2.5vw,26px);font-weight:900;color:var(--gold2);line-height:1;}
.cdcs-rank{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.cdc-draft-btn{font-family:var(--fc);font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(212,160,16,.3);color:var(--gold2);background:rgba(212,160,16,.06);padding:7px 14px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.cdc-draft-btn:hover{background:rgba(212,160,16,.14);}
/* draft sidebar — league standings */
.draft-sidebar{background:rgba(6,5,14,.98);border-left:1px solid rgba(212,160,16,.07);overflow-y:auto;padding:16px;}
.draft-sidebar::-webkit-scrollbar{width:0;}
.ds-section{margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid rgba(212,160,16,.06);}
.ds-section:last-child{border-bottom:none;}
.dss-title{font-family:var(--fm);font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:9px;display:flex;align-items:center;gap:5px;}
.dss-title::before{content:'◈';color:var(--gold2);}
.league-row{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:1px solid rgba(212,160,16,.04);cursor:pointer;}
.league-row:last-child{border-bottom:none;}
.lr-rank{font-family:var(--fb);font-size:16px;letter-spacing:.04em;min-width:24px;}
.lr-info{flex:1;}
.lri-name{font-family:var(--fm);font-size:7px;font-weight:700;letter-spacing:.06em;}
.lri-roster{font-family:var(--fm);font-size:5px;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);}
.lr-score{font-family:var(--fc);font-size:clamp(16px,2vw,20px);font-weight:900;color:var(--gold2);}
.lr-me{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(212,160,16,.25);color:var(--gold2);padding:1px 5px;flex-shrink:0;}

/* ═══════════════════════════════════════════════
   VIEW 4: THE COLOSSEUM (LIVE)
═══════════════════════════════════════════════ */
#view-colosseum{padding-top:56px;height:100vh;display:flex;flex-direction:column;overflow:hidden;}
.colosseum-layout{flex:1;display:grid;grid-template-columns:1fr 340px;overflow:hidden;}
/* performance stage */
.colo-stage{position:relative;overflow:hidden;display:flex;flex-direction:column;background:var(--mid);}
/* dramatic bg */
.cs-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 20%,rgba(192,24,40,.1) 0%,transparent 60%);}
.cs-scan{position:absolute;left:0;right:0;height:2px;background:linear-gradient(to right,transparent,rgba(224,32,48,.04),transparent);animation:scanLine 10s linear infinite;pointer-events:none;z-index:2;}
.cs-spotlights{position:absolute;inset:0;pointer-events:none;}
.cs-spotlight{position:absolute;top:0;width:200px;height:300px;border-radius:0 0 50% 50%;opacity:.04;}
/* creator performance area */
.cs-performance{position:relative;z-index:3;padding:28px 36px;flex:1;display:flex;flex-direction:column;}
.csp-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;}
/* live indicator */
.csp-live{display:flex;align-items:center;gap:7px;}
.cspl-dot{width:8px;height:8px;border-radius:50%;background:var(--live);animation:blink .5s infinite;}
.cspl-text{font-family:var(--fm);font-size:7px;letter-spacing:.22em;text-transform:uppercase;color:var(--live);}
.cspl-count{font-family:var(--fm);font-size:7px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
/* creator card */
.csp-creator{display:flex;gap:14px;align-items:center;margin-bottom:16px;}
.cspc-avatar{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px;border:2px solid rgba(212,160,16,.35);flex-shrink:0;}
.cspc-info{}
.cspci-name{font-family:var(--fb);font-size:clamp(16px,2.5vw,26px);letter-spacing:.07em;display:flex;align-items:center;gap:8px;}
.cspci-badge{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;border:1px solid rgba(224,32,48,.3);color:var(--live);padding:2px 7px;animation:blink .9s infinite;}
.cspci-ep{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:rgba(242,238,230,.4);}
.cspci-project{font-family:var(--fg);font-style:italic;font-size:13px;color:rgba(242,238,230,.55);}
/* waveform */
.csp-waveform{height:72px;display:flex;align-items:center;gap:2px;margin-bottom:14px;padding:10px 0;border-top:1px solid rgba(242,238,230,.05);border-bottom:1px solid rgba(242,238,230,.05);}
.cspw-bar{flex:1;border-radius:1px;min-height:3px;transition:height .2s;}
/* current narrative moment */
.csp-narrative{flex:1;margin-bottom:16px;}
.cspn-label{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
.cspn-text{font-family:var(--fg);font-style:italic;font-size:clamp(16px,2vw,21px);color:rgba(242,238,230,.82);line-height:1.9;max-width:720px;}
/* live branch point */
.csp-branch{background:rgba(2,1,8,.7);border:1px solid rgba(212,160,16,.25);padding:18px 20px;backdrop-filter:blur(8px);}
.cspb-label{font-family:var(--fm);font-size:7px;letter-spacing:.24em;text-transform:uppercase;color:var(--gold2);margin-bottom:4px;display:flex;align-items:center;gap:5px;}
.cspb-label::before{content:'⬡';}
.cspb-question{font-family:var(--fg);font-style:italic;font-size:clamp(14px,1.6vw,17px);color:rgba(242,238,230,.8);line-height:1.75;margin-bottom:12px;}
/* live choice buttons */
.cspb-choices{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:10px;}
.cspbc-btn{padding:12px 14px;background:rgba(242,238,230,.03);border:1px solid rgba(242,238,230,.08);cursor:pointer;text-align:left;transition:all .22s;position:relative;overflow:hidden;}
.cspbc-btn:hover{border-color:var(--gold);background:rgba(212,160,16,.08);}
.cspbc-btn.leading{border-color:rgba(212,160,16,.3);background:rgba(212,160,16,.07);}
.cspbc-btn.voted{border-color:var(--gold2);}
/* live vote fill */
.cspbcb-fill{position:absolute;top:0;left:0;bottom:0;background:rgba(212,160,16,.1);pointer-events:none;transition:width 1s ease;}
.cspbcb-content{position:relative;z-index:1;}
.cspbcbc-choice{font-family:var(--fg);font-style:italic;font-size:13px;color:rgba(242,238,230,.75);margin-bottom:3px;line-height:1.5;}
.cspbcbc-pct{font-family:var(--fc);font-size:clamp(20px,2.5vw,28px);font-weight:900;line-height:1;}
.cspbcbc-votes{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
/* colosseum sidebar */
.colo-sidebar{background:rgba(6,5,14,.98);border-left:1px solid rgba(212,160,16,.07);overflow:hidden;display:flex;flex-direction:column;}
.colo-sb-hdr{padding:12px 14px;border-bottom:1px solid rgba(212,160,16,.07);flex-shrink:0;}
.colsbh-title{font-family:var(--fc);font-size:15px;font-weight:800;letter-spacing:.08em;margin-bottom:3px;}
.colsbh-sub{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
/* chat feed — in-universe only */
.colo-chat{flex:1;overflow-y:auto;padding:0;}
.colo-chat::-webkit-scrollbar{width:0;}
.cc-item{padding:9px 12px;border-bottom:1px solid rgba(242,238,230,.04);animation:chatIn .3s cubic-bezier(.16,1,.3,1);}
.cci-header{display:flex;gap:7px;align-items:center;margin-bottom:3px;}
.ccih-avatar{width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;border:1px solid;flex-shrink:0;}
.ccih-name{font-family:var(--fm);font-size:6px;font-weight:700;letter-spacing:.07em;flex:1;}
.ccih-faction{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.ccih-time{font-family:var(--fm);font-size:5px;color:var(--muted);}
.cci-text{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(242,238,230,.5);line-height:1.55;}
/* in-universe flavor */
.cci-text.in-universe{color:rgba(242,238,230,.65);}
/* chat input */
.colo-input{padding:10px 12px;border-top:1px solid rgba(212,160,16,.08);flex-shrink:0;display:flex;gap:6px;}
.ci-field{flex:1;background:rgba(242,238,230,.04);border:1px solid rgba(242,238,230,.1);padding:8px 12px;font-family:var(--fg);font-style:italic;font-size:12px;color:var(--white);outline:none;}
.ci-field:focus{border-color:rgba(212,160,16,.3);}
.ci-field::placeholder{color:rgba(242,238,230,.2);}
.ci-send{font-family:var(--fc);font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:rgba(212,160,16,.1);border:1px solid rgba(212,160,16,.2);color:var(--gold2);padding:8px 16px;cursor:pointer;transition:all .2s;}
.ci-send:hover{background:rgba(212,160,16,.18);}

/* ═══════════════════════════════════════════════
   VIEW 5: THE CODEX
═══════════════════════════════════════════════ */
#view-codex{padding-top:56px;}
.codex-wrap{padding:36px 48px;}
/* codex hero */
.codex-hero{
  background:linear-gradient(135deg,rgba(212,160,16,.07),rgba(192,24,40,.05));
  border:1px solid rgba(212,160,16,.15);
  padding:28px 32px;margin-bottom:4px;
  position:relative;overflow:hidden;
}
.codex-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(to right,var(--gold),var(--gold2),var(--blood2),var(--gold2),var(--gold));}
.ch-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;}
.cht-left{}
.chtl-label{font-family:var(--fm);font-size:6px;letter-spacing:.26em;text-transform:uppercase;color:var(--gold2);margin-bottom:5px;}
.chtl-name{font-family:var(--fb);font-size:clamp(28px,5vw,64px);letter-spacing:.06em;line-height:.88;margin-bottom:4px;background:linear-gradient(to right,var(--white),var(--gold3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.chtl-title{font-family:var(--fg);font-style:italic;font-size:clamp(13px,1.5vw,16px);color:rgba(242,238,230,.45);}
.cht-right{text-align:right;}
.chtr-impact{font-family:var(--fb);font-size:clamp(36px,5vw,64px);letter-spacing:.04em;color:var(--gold2);line-height:1;display:block;}
.chtr-lbl{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
/* codex quick stats */
.codex-quick{display:grid;grid-template-columns:repeat(6,1fr);gap:3px;margin-bottom:4px;}
@media(max-width:1000px){.codex-quick{grid-template-columns:repeat(3,1fr);}}
/* achievement sections */
.codex-sections{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
@media(max-width:900px){.codex-sections{grid-template-columns:1fr;}}
.codex-panel{background:var(--panel);border:1px solid rgba(212,160,16,.07);padding:20px;position:relative;overflow:hidden;}
.codex-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.cp-title{font-family:var(--fc);font-size:16px;font-weight:800;letter-spacing:.07em;margin-bottom:14px;display:flex;align-items:center;gap:7px;}
/* endings tracker */
.endings-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;}
.ending-cell{aspect-ratio:1;background:var(--card);border:1px solid rgba(242,238,230,.05);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;padding:8px;}
.ending-cell.reached{border-color:rgba(212,160,16,.25);background:rgba(212,160,16,.07);}
.ending-cell.unreached{opacity:.35;filter:grayscale(.8);}
.ec-icon{font-size:16px;display:block;margin-bottom:3px;}
.ec-name{font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;text-align:center;line-height:1.3;}
/* crossover nodes */
.node-item{display:flex;gap:9px;align-items:flex-start;padding:7px 0;border-bottom:1px solid rgba(242,238,230,.04);}
.node-item:last-child{border-bottom:none;}
.ni-icon{font-size:14px;flex-shrink:0;margin-top:1px;}
.ni-body{flex:1;}
.nib-name{font-family:var(--fg);font-size:13px;font-weight:600;margin-bottom:1px;}
.nib-projects{font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);}
.ni-status{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:2px 6px;flex-shrink:0;}
.ni-found{border-color:rgba(212,160,16,.3);color:var(--gold2);}
.ni-hidden{border-color:rgba(82,76,100,.2);color:var(--muted);}
/* arena record */
.record-display{display:flex;align-items:center;gap:16px;margin-bottom:14px;}
.rd-wins{text-align:center;}
.rdw-val{font-family:var(--fb);font-size:clamp(36px,5vw,60px);letter-spacing:.04em;color:var(--win);display:block;line-height:1;}
.rdw-lbl{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);}
.rd-sep{font-family:var(--fb);font-size:32px;color:rgba(242,238,230,.1);}
.rd-losses{}
.rdl-val{font-family:var(--fb);font-size:clamp(36px,5vw,60px);letter-spacing:.04em;color:var(--muted);display:block;line-height:1;}
.rdl-lbl{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);}
.rd-history{display:flex;gap:3px;flex-wrap:wrap;}
.rdh-dot{width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-family:var(--fm);font-size:7px;font-weight:700;}
.rdh-dot.w{background:rgba(32,200,112,.15);color:var(--win);}
.rdh-dot.l{background:rgba(82,76,100,.12);color:var(--muted);}
/* season history */
.season-row{display:flex;align-items:center;gap:12px;padding:7px 0;border-bottom:1px solid rgba(242,238,230,.04);}
.season-row:last-child{border-bottom:none;}
.sesr-season{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);min-width:70px;}
.sesr-faction{font-family:var(--fm);font-size:6px;letter-spacing:.08em;text-transform:uppercase;border:1px solid;padding:1px 6px;flex-shrink:0;}
.sesr-impact{font-family:var(--fc);font-size:clamp(16px,2vw,20px);font-weight:900;color:var(--gold2);margin-left:auto;}
.sesr-rank{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
</style>
</head>
