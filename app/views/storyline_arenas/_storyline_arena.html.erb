  {season:'PRE-SEASON',faction:'HOLLOWAY BLOOD',color:'#CC2830',impact:4280,rank:'#7'},
];
const CODEX_QUICK=[
  {val:'7/12',lbl:'ENDINGS REACHED',color:'var(--gold2)'},{val:'8/24',lbl:'CROSSOVER NODES',color:'var(--tbd)'},
  {val:'14W–6L',lbl:'ARENA RECORD',color:'var(--win)'},{val:'#3',lbl:'LEAGUE RANK',color:'var(--gold2)'},
  {val:'2/5',lbl:'THEORIES CONFIRMED',color:'var(--win)'},{val:'Holloway Blood',lbl:'CURRENT FACTION',color:'#CC2830'},
];

// ── RENDER FUNCTIONS ──────────────────────────

let homeRendered=false;
function renderHome(){
  if(homeRendered)return;
  homeRendered=true;
  // stats strip
  const stats=document.getElementById('arena-stats');
  ARENA_STATS.forEach(s=>{
    const d=document.createElement('div');
    d.className='stat-cell';
    d.style.borderTop='2px solid rgba(212,160,16,.15)';
    d.innerHTML=`<span class="sc-val" style="color:${s.color};">${s.val}</span><span class="sc-lbl">${s.lbl}</span>`;
    stats.appendChild(d);
  });
  // standings
  const sg=document.getElementById('standings');
  STANDINGS.forEach(s=>{
    const d=document.createElement('div');
    d.className='standing-row'+(s.rank<=2?' champion':'');
    d.onclick=()=>sw('bracket',null);
    const rankClass=s.rank===1?'gold':s.rank===2?'silver':s.rank===3?'bronze':'';
    const rankColor=s.rank===1?'var(--gold2)':s.rank===2?'rgba(200,195,190,.6)':s.rank===3?'rgba(180,110,60,.6)':'var(--muted)';
    d.innerHTML=`
      ${s.rank===1?'<div class="gold-stripe"></div>':''}
      <div class="sr-rank ${rankClass}" style="color:${rankColor};">${s.rank}</div>
      <div class="sr-info">
        <div class="sri-name" style="color:${s.color};">${s.icon} ${s.name}</div>
        <div class="sri-creator">${s.creator}</div>
      </div>
      <div class="sr-record">
        <div class="srr-wins" style="color:${s.rank<=3?'var(--gold2)':'var(--muted)'};">${s.wins}W — ${s.losses}L</div>
        <div class="srr-pts">${s.pts.toLocaleString()} PTS</div>
      </div>
      ${s.rank===1?'<div class="sr-crown">👑</div>':''}`;
    sg.appendChild(d);
  });
  // faction powers
  const fp=document.getElementById('faction-powers');
  FACTION_POWERS.forEach(f=>{
    const d=document.createElement('div');
    d.className='fp-card';
    d.onclick=()=>{}
    d.innerHTML=`
      <div class="fpc-bar" style="height:${f.pct*.4}%;background:${f.color};opacity:.1;"></div>
      <div class="fpc-top"><div class="fpct-name" style="color:${f.color};">${f.name}</div><div class="fpct-seal">${f.seal}</div></div>
      <div class="fpc-pct" style="color:${f.color};">${f.pct}%</div>
      <div class="fpc-label">POWER INDEX <span style="color:${f.delta.startsWith('+')?'var(--win)':'var(--blood2)'};">${f.delta} THIS WEEK</span></div>`;
    fp.appendChild(d);
  });
  addHoverFX();
}

let bracketRendered=false;
function renderBracket(){
  if(bracketRendered)return;
  bracketRendered=true;
  const container=document.getElementById('bracket-container');
  BRACKET_ROUNDS.forEach(round=>{
    const col=document.createElement('div');
    col.className='bracket-round';
    col.innerHTML=`<div class="br-label">${round.label}</div><div class="br-matches" id="round-${round.label.replace(/\s/g,'_')}"></div>`;
    container.appendChild(col);
    const matchesDiv=col.querySelector('.br-matches');
    round.matches.forEach(m=>{
      if(m.championship){
        const cs=document.createElement('div');
        cs.className='championship-slot';
        cs.innerHTML=`<div class="cs-label">◈ SEASON 1 CHAMPIONSHIP</div><span class="cs-trophy">🏆</span><div class="cs-title">WINNER TO BE DECIDED</div><div class="cs-sub">Semifinals determine the finalists · Week 10 · Canon on the line</div>`;
        matchesDiv.appendChild(cs);
        return;
      }
      const mu=document.createElement('div');
      mu.className='matchup'+(m.featured?' featured':'')+(m.status==='completed'?' completed':'');
      mu.onclick=()=>{if(m.status==='live')sw('colosseum',null);};
      const getScoreClass=(s,opp)=>{
        if(m.status==='completed')return s>opp?'winning':'losing';
        if(m.status==='live')return s>opp?'leading':'';
        return '';
      };
      const getBadge=(status,aScore,bScore)=>{
        if(status==='completed') return `<div class="muc-badge mu-badge-canon">✓ CANON</div>`;
        if(status==='live') return `<div class="muc-badge mu-badge-live">◉ LIVE</div>`;
        return `<div class="muc-badge mu-badge-tbd">TBD</div>`;
      };
      mu.innerHTML=`
        <div class="mu-round-stripe" style="background:${m.featured?'linear-gradient(to right,var(--gold),var(--blood2),var(--gold))':m.status==='completed'?'rgba(32,200,112,.4)':'rgba(212,160,16,.2)'};"></div>
        <div class="mu-competitor ${m.status==='completed'&&m.a.score>m.b.score?'winner':m.status==='completed'?'loser':''}">
          <div class="muc-icon">${m.a.icon}</div>
          <div class="muc-info"><div class="muci-name" style="color:${m.a.color};">${m.a.name}</div><div class="muci-creator">${m.a.creator}</div></div>
          <div class="muc-score ${getScoreClass(m.a.score,m.b.score)}" style="color:${m.status==='tbd'?'var(--muted)':m.a.color};">${m.status==='upcoming'?'—':m.a.score+'%'}</div>
          ${m.status==='completed'&&m.a.score>m.b.score?getBadge(m.status,m.a.score,m.b.score):''}
        </div>
        <div class="mu-competitor ${m.status==='completed'&&m.b.score>m.a.score?'winner':m.status==='completed'?'loser':''}">
          <div class="muc-icon">${m.b.icon}</div>
          <div class="muc-info"><div class="muci-name" style="color:${m.b.color};">${m.b.name}</div><div class="muci-creator">${m.b.creator}</div></div>
          <div class="muc-score ${getScoreClass(m.b.score,m.a.score)}" style="color:${m.status==='tbd'?'var(--muted)':m.b.color};">${m.status==='upcoming'?'—':m.b.score+'%'}</div>
          ${m.status==='completed'&&m.b.score>m.a.score?getBadge(m.status,m.a.score,m.b.score):''}
        </div>
        ${m.status!=='upcoming'?`<div class="mu-vote-bar"><div class="muvb-a" style="width:${m.a.score||50}%;background:${m.a.color};opacity:.7;"></div><div class="muvb-b" style="width:${m.b.score||50}%;background:${m.b.color};opacity:.7;"></div></div>`:''}`;
      matchesDiv.appendChild(mu);
    });
  });
  addHoverFX();
}

let draftRendered=false;
function renderDraft(){
  if(draftRendered)return;
  draftRendered=true;
  // roster
  const rs=document.getElementById('roster-slots');
  MY_ROSTER.forEach(c=>{
    const d=document.createElement('div');
    d.className='roster-slot'+(c.filled?' filled':' empty');
    d.innerHTML=c.filled?`
      <span class="rs-icon">${c.icon}</span>
      <div class="rs-name" style="color:${c.color};">${c.name}</div>
      <span class="rs-pts" style="color:${c.color};">${c.pts}</span>
      <span class="rs-pts-lbl">PTS</span>
      <span class="rs-trend" style="color:${c.trend.startsWith('+')&&c.trend!==''?'var(--win)':'var(--muted)'};">${c.trend}</span>`
      :`<span class="rs-icon" style="opacity:.3;">➕</span><div class="rs-name" style="color:var(--muted);">DRAFT A CHARACTER</div>`;
    rs.appendChild(d);
  });
  // draft board
  const dl=document.getElementById('draft-board-list');
  DRAFT_CHARS.forEach(c=>{
    const d=document.createElement('div');
    d.className='char-draft-card'+(c.drafted?' drafted':'');
    d.innerHTML=`
      <div class="cdc-icon">${c.icon}</div>
      <div class="cdc-info">
        <div class="cdci-name" style="color:${c.color};">${c.name}</div>
        <div class="cdci-role">${c.role}</div>
        <div class="cdci-projects">${c.projects}</div>
      </div>
      <div class="cdc-stats">
        <div class="cdcs-pts">${c.pts}</div>
        <div class="cdcs-rank">RANK #${c.rank}</div>
      </div>
      <button class="cdc-draft-btn" onclick="draftChar(this,'${c.name}')" ${c.drafted?'disabled':''} style="${c.drafted?'opacity:.3;pointer-events:none;':''}">
        ${c.drafted?'ON ROSTER':'DRAFT →'}
      </button>`;
    dl.appendChild(d);
  });
  // league standings
  const ls=document.getElementById('league-standings');
  LEAGUE_STANDINGS.forEach(r=>{
    const d=document.createElement('div');
    d.className='league-row';
    const rankColor=r.rank===1?'var(--gold2)':r.rank<=3?'var(--off)':'var(--muted)';
    d.innerHTML=`
      <div class="lr-rank" style="color:${rankColor};">${r.rank}</div>
      <div class="lr-info"><div class="lri-name" style="color:${r.me?'var(--gold2)':'rgba(242,238,230,.6)'};">${r.name}</div><div class="lri-roster">${r.roster}</div></div>
      <div class="lr-score" style="color:${r.me?'var(--gold2)':'rgba(242,238,230,.5)'};">${r.score.toLocaleString()}</div>
      ${r.me?'<div class="lr-me">YOU</div>':''}`;
    ls.appendChild(d);
  });
  // weekly scoring
  const ws=document.getElementById('weekly-scoring');
  WEEKLY_SCORING.forEach(w=>{
    const d=document.createElement('div');
    d.style.cssText='padding:5px 0;border-bottom:1px solid rgba(212,160,16,.06);display:flex;justify-content:space-between;align-items:center;';
    d.innerHTML=`<div><div style="font-family:var(--fb);font-size:13px;letter-spacing:.05em;">${w.char}</div><div style="font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);">${w.reason}</div></div><div style="font-family:var(--fc);font-size:20px;font-weight:900;color:var(--gold2);">+${w.pts}</div>`;
    ws.appendChild(d);
  });
  // hot pickups
  const hp=document.getElementById('hot-pickups');
  HOT_PICKUPS.forEach(h=>{
    const d=document.createElement('div');
    d.style.cssText='padding:5px 0;border-bottom:1px solid rgba(212,160,16,.06);display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:background .15s;';
    d.innerHTML=`<div><div style="font-family:var(--fb);font-size:13px;letter-spacing:.05em;">${h.name}</div><div style="font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);">${h.reason}</div></div><div style="font-family:var(--fc);font-size:20px;font-weight:900;color:var(--win);">${h.pts}</div>`;
    hp.appendChild(d);
  });
  addHoverFX();
}

let coloRendered=false;
function renderColosseum(){
  if(coloRendered)return;
  coloRendered=true;
  // waveform
  const wf=document.getElementById('colo-waveform');
  for(let i=0;i<100;i++){
    const b=document.createElement('div');
    b.className='cspw-bar';
    const h=Math.max(12,Math.random()*100);
    const isLive=i>=40&&i<=70;
    b.style.height=h+'%';
    b.style.background=isLive?`rgba(224,32,48,${.4+Math.random()*.5})`:`rgba(242,238,230,${.06+Math.random()*.08})`;
    if(isLive){b.style.animation=`waveBar ${.4+Math.random()*.6}s ease-in-out ${Math.random()*.8}s infinite`;}
    wf.appendChild(b);
  }
  // choices
  const cc=document.getElementById('colo-choices');
  let voted=null;
  COLO_CHOICES.forEach(c=>{
    const d=document.createElement('div');
    d.className='cspbc-btn'+(c.pct>50?' leading':'');
    d.innerHTML=`
      <div class="cspbcb-fill" style="width:${c.pct}%;background:${c.color}20;"></div>
      <div class="cspbcb-content">
        <div class="cspbcbc-choice">${c.choice}</div>
        <span class="cspbcbc-pct" style="color:${c.color};">${c.pct}%</span>
        <div class="cspbcbc-votes">${c.votes.toLocaleString()} votes</div>
      </div>`;
    d.onclick=()=>{
      if(voted)return;voted=c;
      document.querySelectorAll('.cspbc-btn').forEach(b=>b.classList.remove('voted'));
      d.classList.add('voted');
    };
    cc.appendChild(d);
  });
  // chat
  const chat=document.getElementById('colo-chat');
  CHAT_MESSAGES.forEach((msg,i)=>{
    const d=document.createElement('div');
    d.className='cc-item';
    d.style.animationDelay=(i*.05)+'s';
    d.innerHTML=`
      <div class="cci-header">
        <div class="ccih-avatar" style="border-color:${msg.fColor}40;background:${msg.fColor}12;">${msg.avatar}</div>
        <div class="ccih-name" style="color:${msg.fColor};">${msg.name}</div>
        <div class="ccih-faction">${msg.faction}</div>
        <div class="ccih-time">${msg.time}</div>
      </div>
      <div class="cci-text${msg.inUniverse?' in-universe':''}">${msg.text}</div>`;
    chat.appendChild(d);
  });
  addHoverFX();
}

let codexRendered=false;
function renderCodex(){
  if(codexRendered)return;
  codexRendered=true;
  // quick stats
  const cq=document.getElementById('codex-quick');
  CODEX_QUICK.forEach(s=>{
    const d=document.createElement('div');
    d.className='stat-cell';
    d.innerHTML=`<div style="position:absolute;bottom:0;left:0;right:0;height:2px;background:${s.color};opacity:.6;"></div><span class="sc-val" style="color:${s.color};">${s.val}</span><span class="sc-lbl">${s.lbl}</span>`;
    cq.appendChild(d);
  });
  // endings
  const eg=document.getElementById('endings-grid');
  ENDINGS.forEach(e=>{
    const d=document.createElement('div');
    d.className='ending-cell'+(e.reached?' reached':' unreached');
    d.innerHTML=`<span class="ec-icon">${e.icon}</span><div class="ec-name" style="color:${e.reached?'var(--gold2)':'var(--muted)'};">${e.name}</div>`;
    eg.appendChild(d);
  });
  // crossover nodes
  const cn=document.getElementById('codex-nodes');
  CODEX_NODES.forEach(n=>{
    const d=document.createElement('div');
    d.className='node-item';
    d.innerHTML=`
      <div class="ni-icon">${n.found?'◆':'◇'}</div>
      <div class="ni-body">
        <div class="nib-name" style="color:${n.found?'var(--gold2)':'rgba(242,238,230,.45)'};">${n.name}</div>
        <div class="nib-projects">${n.projects}</div>
      </div>
      <div class="ni-status ${n.found?'ni-found':'ni-hidden'}">${n.found?'FOUND':'HIDDEN'}</div>`;
    cn.appendChild(d);
  });
  // arena record history dots
  const rh=document.getElementById('rd-history');
  ARENA_RECORD.forEach(r=>{
    const d=document.createElement('div');
    d.className=`rdh-dot ${r}`;
    d.textContent=r.toUpperCase();
    rh.appendChild(d);
  });
  // season history
  const sh=document.getElementById('season-history');
  SEASON_HISTORY.forEach(s=>{
    const d=document.createElement('div');
    d.className='season-row';
    d.innerHTML=`
      <div class="sesr-season">${s.season}</div>
      <div class="sesr-faction" style="border-color:${s.color}40;color:${s.color};">${s.faction}</div>
      <div class="sesr-impact" style="margin-left:auto;">${s.impact.toLocaleString()}</div>
      <div class="sesr-rank">${s.rank}</div>`;
    sh.appendChild(d);
  });
  addHoverFX();
}

// ── INTERACTIONS ─────────────────────────────
function draftChar(btn,name){
  btn.textContent='✓ DRAFTED';
  btn.style.background='rgba(32,200,112,.1)';
  btn.style.borderColor='rgba(32,200,112,.3)';
  btn.style.color='var(--win)';
  btn.disabled=true;
  const score=parseInt(document.getElementById('roster-total-score').textContent.replace(/[^0-9]/g,''));
  document.getElementById('roster-total-score').textContent=(score+200).toLocaleString()+' PTS';
}

function filterDraft(btn,filter){
  document.querySelectorAll('.dbaf-pill').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  const cards=document.querySelectorAll('.char-draft-card');
  cards.forEach(c=>{
    if(filter==='all'||filter==='high'){c.style.display='grid';return;}
    const project=c.querySelector('.cdci-projects').textContent.toLowerCase();
    c.style.display=project.includes(filter)?'grid':'none';
  });
}

function sendChat(){
  const input=document.getElementById('chat-input');
  if(!input.value.trim())return;
  const chat=document.getElementById('colo-chat');
  const d=document.createElement('div');
  d.className='cc-item';
  d.style.background='rgba(212,160,16,.04)';
  d.style.borderLeft='2px solid rgba(212,160,16,.3)';
  d.innerHTML=`
    <div class="cci-header">
      <div class="ccih-avatar" style="border-color:rgba(212,160,16,.3);background:rgba(212,160,16,.1);">✦</div>
      <div class="ccih-name" style="color:var(--gold2);">YOU</div>
      <div class="ccih-faction">HOLLOWAY BLOOD</div>
      <div class="ccih-time">just now</div>
    </div>
    <div class="cci-text in-universe">${input.value}</div>`;
  chat.insertBefore(d,chat.firstChild);
  input.value='';
}

function addHoverFX(){
  document.querySelectorAll('button,.standing-row,.matchup,.char-draft-card,.league-row,.roster-slot,.fp-card,.ending-cell,.node-item,.cspbc-btn').forEach(el=>{
    if(!el._hb){
      el.addEventListener('mouseenter',bigCur);
      el.addEventListener('mouseleave',normCur);
      el._hb=true;
    }
  });
}

function initReveal(){
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.04});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
}

// ── LIVE VOTE FLICKER ────────────────────────
let voteA=52,voteB=48;
setInterval(()=>{
  const shift=Math.random()>.5?1:-1;
  voteA=Math.max(45,Math.min(55,voteA+shift));
  voteB=100-voteA;
  const pa=document.getElementById('hero-pct-a');
  const pb=document.getElementById('hero-pct-b');
  if(pa)pa.textContent=voteA+'%';
  if(pb)pb.textContent=voteB+'%';
},3000);

// ── INIT ────────────────────────────────────
renderHome();
initReveal();
</script>
</body>
</html>
