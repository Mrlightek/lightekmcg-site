    d.addEventListener('mouseleave',()=>{d.querySelector('.fo-hover-bg').style.opacity='0';normCur();});
    grid.appendChild(d);
  });
}

function joinFaction(id){
  selectedFaction=FACTIONS.find(f=>f.id===id);
  const f=selectedFaction;
  // update CSS vars
  document.documentElement.style.setProperty('--fac',f.color);
  document.documentElement.style.setProperty('--fac2',f.color2);
  document.documentElement.style.setProperty('--fac3',f.color3);
  // update nav badge
  document.getElementById('tnfb-name').textContent=f.name;
  document.querySelector('.tnfb-dot').style.background=f.color2;
  document.querySelector('.tn-faction-badge').style.borderColor=f.color+'50';
  document.querySelector('.tn-faction-badge').style.color=f.color2;
  document.querySelector('.topnav::after');
  // update cursor
  cur.style.background=f.color2;
  cur.style.boxShadow=`0 0 14px ${f.color}`;
  cur2.style.borderColor=f.color2+'30';
  // show hub
  document.getElementById('faction-onboard').style.display='none';
  const hub=document.getElementById('faction-hub');
  hub.style.display='block';
  renderFactionHub(f);
}

