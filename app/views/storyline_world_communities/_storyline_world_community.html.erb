        <div class="qc-mark">"</div>
        <div class="qc-text">"${q.text}"</div>
        <div class="qc-source">
          <div class="qcs-dot" style="background:${q.color};"></div>
          <div class="qcs-project" style="color:${q.color};">${q.project}</div>
          <div class="qcs-sep"></div>
          <div class="qcs-ep">${q.ep}</div>
          <div class="qcs-sep"></div>
          <div class="qcs-char">${q.char}</div>
        </div>
        <div class="qc-annotations">
