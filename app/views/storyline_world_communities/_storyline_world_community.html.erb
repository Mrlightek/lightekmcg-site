<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STORYLINE — World Communities</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Barlow+Condensed:wght@300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;cursor:none;}
:root{
  --void:#030208;--deep:#06050E;--mid:#0A0818;--panel:#0F0C1C;--card:#131020;--lift:#181428;
  --white:#F0ECE4;--off:#C0B8B0;--muted:#5A5468;--dim:#1C1830;
  /* faction colors — bleed into UI when faction selected */
  --fac-blood:#CC2830;--fac-blood2:#F03040;--fac-blood3:#FF5060;
  --fac-heights:#2858C8;--fac-heights2:#4878F0;--fac-heights3:#70A0FF;
  --fac-meridian:#18A860;--fac-meridian2:#20D078;--fac-meridian3:#40F090;
  --fac-archive:#9820C8;--fac-archive2:#C030F8;--fac-archive3:#E060FF;
  /* active faction (JS override) */
  --fac:#CC2830;--fac2:#F03040;--fac3:#FF5060;
  --gold:#C8980C;--gold2:#E0B020;--gold3:#F8C838;
  --canon-yes:#20C870;--canon-no:#CC2030;
  --fb:'Bebas Neue',sans-serif;
  --fg:'EB Garamond',serif;
  --fc:'Barlow Condensed',sans-serif;
  --fp:'Playfair Display',serif;
  --fm:'Space Mono',monospace;
}
html{scroll-behavior:smooth;}
body{background:var(--void);color:var(--white);font-family:var(--fg);overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");background-size:200px;pointer-events:none;z-index:0;opacity:.8;}

#cur{width:8px;height:8px;background:var(--fac2);border-radius:50%;position:fixed;z-index:9999;pointer-events:none;transform:translate(-50%,-50%);box-shadow:0 0 14px var(--fac);transition:all .15s;}
#cur2{width:32px;height:32px;border:1px solid rgba(204,40,48,.2);border-radius:50%;position:fixed;z-index:9998;pointer-events:none;transform:translate(-50%,-50%);transition:left .1s cubic-bezier(.16,1,.3,1),top .1s,width .18s,height .18s;}

@keyframes blink{0%,100%{opacity:1}50%{opacity:.08}}
@keyframes pulse{0%,100%{opacity:.5}50%{opacity:1}}
@keyframes liveIn{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:none}}
@keyframes voteBar{from{width:0}to{width:var(--target-w)}}
@keyframes eventCountdown{from{stroke-dashoffset:0}to{stroke-dashoffset:440}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
@keyframes glow{0%,100%{box-shadow:0 0 8px var(--fac)}50%{box-shadow:0 0 24px var(--fac),0 0 48px var(--fac2)}}
@keyframes slideUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}
.fade-up{opacity:0;transform:translateY(20px);transition:opacity .85s cubic-bezier(.16,1,.3,1),transform .85s cubic-bezier(.16,1,.3,1);}
.fade-up.vis{opacity:1;transform:none;}

/* VIEWS */
.view{display:none;}.view.active{display:block;}

/* ═══════════════════════════════════════════
   TOP NAV
═══════════════════════════════════════════ */
.topnav{position:fixed;top:0;left:0;right:0;z-index:400;height:56px;background:rgba(3,2,8,.97);border-bottom:1px solid rgba(204,40,48,.08);display:flex;align-items:center;justify-content:space-between;padding:0 28px;}
.topnav::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--fac),var(--fac2),var(--fac),transparent);opacity:.4;}
.tn-left{display:flex;align-items:center;gap:14px;}
.tn-logo{font-family:var(--fb);font-size:20px;letter-spacing:.14em;cursor:pointer;color:var(--white);}
.tn-logo span{color:var(--fac2);}
.tn-sep{width:1px;height:18px;background:rgba(204,40,48,.12);}
.tn-world{display:flex;align-items:center;gap:8px;}
.tnw-icon{font-size:14px;}
.tnw-name{font-family:var(--fb);font-size:15px;letter-spacing:.08em;color:var(--fac2);}
.tnw-community{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:rgba(204,40,48,.55);border:1px solid rgba(204,40,48,.2);padding:2px 7px;}
.tn-center{display:flex;gap:0;}
.tn-tab{font-family:var(--fm);font-size:7px;letter-spacing:.14em;text-transform:uppercase;color:rgba(240,236,228,.3);padding:0 16px;height:56px;display:flex;align-items:center;border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;}
.tn-tab:hover{color:rgba(240,236,228,.7);}
.tn-tab.on{color:var(--white);border-bottom-color:var(--fac2);}
.tn-right{display:flex;align-items:center;gap:10px;}
/* faction badge in nav */
.tn-faction-badge{display:flex;align-items:center;gap:7px;padding:5px 12px;border:1px solid;cursor:pointer;transition:all .2s;}
.tnfb-dot{width:6px;height:6px;border-radius:50%;animation:pulse 1.5s infinite;}
.tnfb-name{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;}
.tn-live-event{display:flex;align-items:center;gap:6px;padding:5px 12px;background:rgba(240,48,64,.1);border:1px solid rgba(240,48,64,.3);cursor:pointer;transition:all .2s;animation:glow 3s infinite;}
.tnle-dot{width:5px;height:5px;border-radius:50%;background:var(--fac2);animation:blink .6s infinite;}
.tnle-text{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--fac2);}

/* ═══════════════════════════════════════════
   LIVE ALERT BAR (when event active)
═══════════════════════════════════════════ */
.live-bar{height:30px;background:linear-gradient(to right,rgba(204,40,48,.15),rgba(200,144,12,.1),rgba(204,40,48,.15));border-bottom:1px solid rgba(204,40,48,.2);display:flex;align-items:center;justify-content:center;gap:12px;flex-shrink:0;}
.lb-dot{width:6px;height:6px;border-radius:50%;background:var(--fac2);animation:blink .5s infinite;}
.lb-text{font-family:var(--fm);font-size:7px;letter-spacing:.18em;text-transform:uppercase;color:var(--fac2);}
.lb-action{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;border:1px solid rgba(204,40,48,.35);color:var(--fac2);padding:3px 10px;cursor:pointer;background:transparent;transition:all .18s;}
.lb-action:hover{background:rgba(204,40,48,.1);}

/* ═══════════════════════════════════════════
   SHARED COMPONENTS
═══════════════════════════════════════════ */
.page-wrap{padding-top:86px;}/* 56 topnav + 30 live bar */
.two-col{display:grid;grid-template-columns:1fr 320px;gap:0;min-height:calc(100vh - 86px);}
@media(max-width:1000px){.two-col{grid-template-columns:1fr;}}
.main-col{padding:28px 36px;overflow-y:auto;}
.side-col{background:rgba(6,5,14,.98);border-left:1px solid rgba(204,40,48,.06);overflow-y:auto;padding:16px;}
.side-col::-webkit-scrollbar{width:0;}

/* section header */
.sec-hdr{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:16px;}
.sh-title{font-family:var(--fc);font-size:clamp(20px,2.5vw,28px);font-weight:800;letter-spacing:.06em;display:flex;align-items:center;gap:8px;}
.sh-action{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);cursor:pointer;background:none;border:none;transition:color .2s;}
.sh-action:hover{color:var(--fac2);}

/* sidebar section */
.ss-section{margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid rgba(204,40,48,.06);}
.ss-section:last-child{border-bottom:none;}
.sss-title{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:9px;display:flex;align-items:center;gap:5px;}
.sss-title::before{content:'◈';color:var(--fac2);}

/* faction pill */
.fac-pill{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;border:1px solid;padding:2px 7px;display:inline-block;}

/* user row */
.user-row{display:flex;align-items:center;gap:8px;margin-bottom:7px;}
.ur-avatar{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;border:1.5px solid;flex-shrink:0;}
.ur-name{font-family:var(--fm);font-size:7px;letter-spacing:.08em;flex:1;color:rgba(240,236,228,.5);}
.ur-fac{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}

/* ═══════════════════════════════════════════
   VIEW 1: FACTION HUB
═══════════════════════════════════════════ */
#view-factions{padding-top:86px;}
/* faction onboarding — shown if no faction selected */
.faction-onboard{min-height:calc(100vh - 86px);display:flex;flex-direction:column;justify-content:center;align-items:center;padding:48px;text-align:center;position:relative;overflow:hidden;}
.fo-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(204,40,48,.06) 0%,transparent 60%);pointer-events:none;}
.fo-eyebrow{font-family:var(--fm);font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
.fo-title{font-family:var(--fb);font-size:clamp(48px,10vw,130px);letter-spacing:.06em;line-height:.84;margin-bottom:10px;}
.fo-sub{font-family:var(--fg);font-style:italic;font-size:clamp(14px,1.6vw,18px);color:rgba(240,236,228,.42);max-width:520px;line-height:2;margin-bottom:36px;}
/* faction choice grid */
.fo-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;width:100%;max-width:1000px;}
@media(max-width:900px){.fo-grid{grid-template-columns:repeat(2,1fr);}}
.fo-card{background:var(--panel);border:1px solid rgba(240,236,228,.06);padding:24px 18px;cursor:pointer;transition:all .28s;position:relative;overflow:hidden;text-align:left;}
.fo-card:hover{transform:translateY(-3px);}
.fo-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.fo-card::after{content:'';position:absolute;inset:0;opacity:0;transition:opacity .28s;}
.fo-card:hover::after{opacity:.05;}
.foc-seal{font-size:32px;display:block;margin-bottom:12px;position:relative;z-index:1;}
.foc-name{font-family:var(--fb);font-size:clamp(18px,2.5vw,28px);letter-spacing:.06em;line-height:1;margin-bottom:4px;position:relative;z-index:1;}
.foc-motto{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(240,236,228,.42);margin-bottom:10px;line-height:1.6;position:relative;z-index:1;}
.foc-members{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;position:relative;z-index:1;}
.foc-btn{font-family:var(--fc);font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:8px 16px;cursor:pointer;background:transparent;transition:all .2s;position:relative;z-index:1;display:inline-block;}
/* faction hub (post-selection) */
.faction-hub{display:none;}
.fh-hero{padding:32px 36px;border-bottom:1px solid rgba(204,40,48,.07);position:relative;overflow:hidden;}
.fhh-bg{position:absolute;inset:0;pointer-events:none;}
.fhh-content{position:relative;z-index:1;}
.fhh-status{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.fhhs-dot{width:6px;height:6px;border-radius:50%;animation:pulse 1.5s infinite;}
.fhhs-text{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;}
.fhh-name{font-family:var(--fb);font-size:clamp(40px,7vw,90px);letter-spacing:.06em;line-height:.86;margin-bottom:6px;}
.fhh-motto{font-family:var(--fg);font-style:italic;font-size:clamp(14px,1.5vw,17px);color:rgba(240,236,228,.45);margin-bottom:14px;}
/* faction stats */
.fh-stats{display:flex;gap:0;border-bottom:1px solid rgba(204,40,48,.07);}
.fhs-cell{flex:1;padding:14px 24px;border-right:1px solid rgba(204,40,48,.07);}
.fhs-cell:last-child{border-right:none;}
.fhsc-val{font-family:var(--fb);font-size:clamp(24px,3.5vw,44px);letter-spacing:.04em;display:block;line-height:1;}
.fhsc-lbl{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);display:block;margin-top:3px;}
/* faction feed */
.faction-feed{padding:24px 36px;}
.ff-item{padding:14px 0;border-bottom:1px solid rgba(240,236,228,.04);cursor:pointer;transition:background .15s;}
.ff-item:hover{background:rgba(204,40,48,.03);}
.ffi-header{display:flex;gap:9px;align-items:flex-start;margin-bottom:6px;}
.ffih-avatar{width:28px;height:28px;border-radius:50%;border:1.5px solid;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;}
.ffih-meta{}
.ffihm-name{font-family:var(--fm);font-size:7px;font-weight:700;letter-spacing:.08em;margin-bottom:1px;}
.ffihm-time{font-family:var(--fm);font-size:6px;letter-spacing:.08em;color:var(--muted);}
.ffi-content{font-family:var(--fg);font-size:clamp(13px,1.4vw,15px);color:rgba(240,236,228,.65);line-height:1.75;margin-bottom:6px;}
.ffi-reactions{display:flex;gap:6px;flex-wrap:wrap;}
.ffir-btn{font-family:var(--fm);font-size:6px;letter-spacing:.08em;text-transform:uppercase;border:1px solid rgba(240,236,228,.1);background:transparent;color:rgba(240,236,228,.35);padding:3px 9px;cursor:pointer;transition:all .18s;display:flex;align-items:center;gap:4px;}
.ffir-btn:hover{border-color:var(--fac);color:var(--fac2);}
.ffir-btn.active{border-color:var(--fac);color:var(--fac2);background:rgba(204,40,48,.06);}
/* faction challenge */
.faction-challenge{background:var(--panel);border:1px solid rgba(204,40,48,.15);padding:20px 24px;margin:0 36px 20px;position:relative;overflow:hidden;}
.faction-challenge::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--fac),var(--fac2));}
.fcha-label{font-family:var(--fm);font-size:6px;letter-spacing:.22em;text-transform:uppercase;color:var(--fac2);margin-bottom:5px;display:flex;align-items:center;gap:6px;}
.fcha-label::before{content:'⬡';}
.fcha-title{font-family:var(--fc);font-size:clamp(18px,2.5vw,26px);font-weight:800;letter-spacing:.06em;margin-bottom:5px;}
.fcha-desc{font-family:var(--fg);font-style:italic;font-size:13px;color:rgba(240,236,228,.5);line-height:1.75;margin-bottom:12px;}
.fcha-progress{margin-bottom:10px;}
.fchap-label{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;display:flex;justify-content:space-between;}
.fchap-bar{height:5px;background:rgba(240,236,228,.06);}
.fchap-fill{height:100%;transition:width .8s ease;}

/* ═══════════════════════════════════════════
   VIEW 2: THE WITNESS WALL
═══════════════════════════════════════════ */
#view-witness{padding-top:86px;}
.witness-layout{display:grid;grid-template-columns:1fr 300px;min-height:calc(100vh - 86px);}
.witness-main{padding:28px 36px;}
.wm-intro{margin-bottom:24px;}
.wmi-title{font-family:var(--fb);font-size:clamp(36px,6vw,80px);letter-spacing:.05em;line-height:.86;margin-bottom:6px;}
.wmi-sub{font-family:var(--fg);font-style:italic;font-size:clamp(13px,1.4vw,16px);color:rgba(240,236,228,.38);max-width:560px;line-height:2;}
/* quote card */
.quote-card{background:var(--panel);border:1px solid rgba(240,236,228,.06);margin-bottom:4px;position:relative;overflow:hidden;transition:all .22s;cursor:pointer;}
.quote-card:hover{border-color:rgba(240,236,228,.16);}
.quote-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.qc-body{padding:20px 22px;}
/* the quote itself */
.qc-mark{font-family:var(--fb);font-size:80px;color:rgba(240,236,228,.04);position:absolute;top:-10px;left:14px;line-height:1;pointer-events:none;}"
.qc-text{font-family:var(--fg);font-style:italic;font-size:clamp(17px,2vw,22px);color:rgba(240,236,228,.82);line-height:1.85;margin-bottom:12px;position:relative;z-index:1;}
.qc-source{display:flex;gap:10px;align-items:center;margin-bottom:12px;}
.qcs-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.qcs-project{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);}
.qcs-sep{width:1px;height:10px;background:rgba(240,236,228,.1);}
.qcs-ep{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:rgba(240,236,228,.3);}
.qcs-char{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(240,236,228,.45);}
/* annotation layer */
.qc-annotations{border-top:1px solid rgba(240,236,228,.05);padding-top:12px;}
.qca-label{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
.qca-item{display:flex;gap:9px;align-items:flex-start;padding:6px 0;border-bottom:1px solid rgba(240,236,228,.03);}
.qca-item:last-child{border-bottom:none;}
.qcai-avatar{width:18px;height:18px;border-radius:50%;border:1.5px solid;display:flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0;margin-top:1px;}
.qcai-body{}
.qcaib-name{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:2px;}
.qcaib-text{font-family:var(--fg);font-size:12px;color:rgba(240,236,228,.5);line-height:1.6;}
/* actions row */
.qc-actions{display:flex;gap:6px;padding:10px 22px;border-top:1px solid rgba(240,236,228,.04);background:rgba(240,236,228,.02);}
.qca-btn{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(240,236,228,.08);background:transparent;color:rgba(240,236,228,.3);padding:4px 10px;cursor:pointer;transition:all .18s;display:flex;align-items:center;gap:4px;}
.qca-btn:hover{border-color:rgba(240,236,228,.25);color:rgba(240,236,228,.65);}
.qca-btn.elevated{border-color:var(--fac);color:var(--fac2);background:rgba(204,40,48,.05);}
/* witness sidebar */
.witness-sidebar{background:rgba(6,5,14,.98);border-left:1px solid rgba(240,236,228,.05);padding:16px;overflow-y:auto;}
.witness-sidebar::-webkit-scrollbar{width:0;}

/* ═══════════════════════════════════════════
   VIEW 3: CANON DEBATES
═══════════════════════════════════════════ */
#view-debates{padding-top:86px;}
.debates-layout{display:grid;grid-template-columns:1fr 300px;min-height:calc(100vh - 86px);}
.debates-main{padding:28px 36px;}
/* debate card */
.debate-card{background:var(--panel);border:1px solid rgba(240,236,228,.06);margin-bottom:4px;overflow:hidden;position:relative;transition:all .22s;}
.debate-card.featured::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(to right,var(--fac),var(--gold));}
.dc-header{padding:18px 20px;border-bottom:1px solid rgba(240,236,228,.04);}
.dch-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.dcht-badges{display:flex;gap:5px;}
.dcht-badge{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;border:1px solid;padding:2px 7px;}
.dcht-badge.open{border-color:rgba(204,40,48,.3);color:var(--fac2);}
.dcht-badge.creator{border-color:rgba(200,144,12,.3);color:var(--gold2);}
.dcht-badge.resolved{border-color:rgba(32,200,112,.3);color:var(--canon-yes);}
.dcht-badge.hot{border-color:rgba(240,96,32,.3);color:#F06020;animation:blink .9s infinite;}
.dcht-voters{font-family:var(--fm);font-size:7px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);}
.dch-question{font-family:var(--fg);font-size:clamp(17px,2vw,22px);color:rgba(240,236,228,.88);line-height:1.7;margin-bottom:8px;}
.dch-context{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(240,236,228,.42);line-height:1.65;}
/* vote bar */
.dc-vote{padding:14px 20px;border-bottom:1px solid rgba(240,236,228,.04);}
.dcv-bars{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.dcvb-yes,.dcvb-no{height:8px;transition:width 1s cubic-bezier(.16,1,.3,1);}
.dcvb-yes{background:linear-gradient(to right,var(--canon-yes),rgba(32,200,112,.6));border-radius:2px 0 0 2px;}
.dcvb-no{background:linear-gradient(to left,var(--canon-no),rgba(204,32,48,.6));border-radius:0 2px 2px 0;}
.dcvb-pcts{display:flex;justify-content:space-between;margin-bottom:12px;}
.dcvb-yes-pct{font-family:var(--fc);font-size:clamp(20px,2.5vw,28px);font-weight:900;color:var(--canon-yes);}
.dcvb-no-pct{font-family:var(--fc);font-size:clamp(20px,2.5vw,28px);font-weight:900;color:var(--canon-no);}
.dcvb-mid{font-family:var(--fm);font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);text-align:center;flex:1;}
/* vote buttons */
.dcv-btns{display:grid;grid-template-columns:1fr 1fr;gap:4px;}
.dcvb-btn{font-family:var(--fc);font-size:16px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:11px;cursor:pointer;background:transparent;transition:all .22s;position:relative;overflow:hidden;}
.dcvb-btn::before{content:'';position:absolute;inset:0;background:currentColor;opacity:0;transition:opacity .22s;}
.dcvb-btn:hover::before{opacity:.08;}
.dcvb-yes-btn{border-color:rgba(32,200,112,.3);color:var(--canon-yes);}
.dcvb-yes-btn:hover{border-color:var(--canon-yes);}
.dcvb-yes-btn.voted{background:rgba(32,200,112,.1);border-color:var(--canon-yes);}
.dcvb-no-btn{border-color:rgba(204,32,48,.3);color:var(--canon-no);}
.dcvb-no-btn:hover{border-color:var(--canon-no);}
.dcvb-no-btn.voted{background:rgba(204,32,48,.1);border-color:var(--canon-no);}
/* creator response */
.dc-creator-response{padding:14px 20px;background:rgba(200,144,12,.04);border-top:1px solid rgba(200,144,12,.1);}
.dccr-label{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold2);margin-bottom:5px;display:flex;align-items:center;gap:5px;}
.dccr-label::before{content:'✍';}
.dccr-text{font-family:var(--fg);font-style:italic;font-size:13px;color:rgba(240,236,228,.6);line-height:1.75;}
/* resolved verdict */
.dc-verdict{padding:14px 20px;border-top:1px solid rgba(240,236,228,.05);}
.dcv-label{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
.dcv-result{display:flex;gap:10px;align-items:center;}
.dcvr-icon{font-size:20px;}
.dcvr-text{font-family:var(--fg);font-size:14px;font-weight:600;color:rgba(240,236,228,.72);}
.dcvr-pct{font-family:var(--fc);font-size:22px;font-weight:900;}

/* ═══════════════════════════════════════════
   VIEW 4: THEORY BOARD
═══════════════════════════════════════════ */
#view-theories{padding-top:86px;}
.theory-layout{display:grid;grid-template-columns:1fr 300px;min-height:calc(100vh - 86px);}
.theory-main{padding:28px 36px;}
/* theory card */
.theory-card{background:var(--panel);border:1px solid rgba(240,236,228,.06);margin-bottom:4px;overflow:hidden;position:relative;transition:all .22s;cursor:pointer;}
.theory-card:hover{border-color:rgba(240,236,228,.14);}
.theory-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.theory-card.confirmed{border-color:rgba(32,200,112,.2);}
.theory-card.confirmed::before{background:var(--canon-yes);}
.theory-card.debunked{border-color:rgba(204,32,48,.2);opacity:.7;}
.theory-card.debunked::before{background:var(--canon-no);}
.tc-body{padding:18px 20px;}
.tc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.tc-verdict{display:flex;align-items:center;gap:5px;font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;border:1px solid;padding:3px 9px;}
.tc-verdict.confirmed{border-color:rgba(32,200,112,.3);color:var(--canon-yes);}
.tc-verdict.debunked{border-color:rgba(204,32,48,.3);color:var(--canon-no);}
.tc-verdict.pending{border-color:rgba(240,236,228,.12);color:rgba(240,236,228,.4);}
.tc-support{font-family:var(--fm);font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.tc-title{font-family:var(--fg);font-size:clamp(16px,1.8vw,20px);font-weight:600;color:rgba(240,236,228,.85);margin-bottom:6px;line-height:1.5;}
.tc-because{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(240,236,228,.45);line-height:1.65;margin-bottom:10px;}
/* evidence chain */
.tc-evidence{display:flex;flex-direction:column;gap:3px;margin-bottom:10px;}
.tce-item{display:flex;gap:8px;align-items:flex-start;font-family:var(--fm);font-size:6px;letter-spacing:.06em;color:rgba(240,236,228,.4);line-height:1.5;}
.tce-ref{min-width:70px;text-align:right;color:rgba(240,236,228,.25);}
.tce-fact::before{content:'→ ';color:rgba(240,236,228,.2);}
/* resolution box */
.tc-resolution{background:rgba(32,200,112,.06);border:1px solid rgba(32,200,112,.15);padding:11px 14px;margin-top:8px;}
.tc-resolution.debunked-box{background:rgba(204,32,48,.06);border-color:rgba(204,32,48,.15);}
.tcres-label{font-family:var(--fm);font-size:5px;letter-spacing:.18em;text-transform:uppercase;margin-bottom:3px;}
.tcres-text{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(240,236,228,.55);line-height:1.65;}
/* vote row */
.tc-vote-row{display:flex;gap:6px;align-items:center;padding:9px 20px;border-top:1px solid rgba(240,236,228,.04);background:rgba(240,236,228,.015);}
.tcvr-label{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);flex:1;}
.tcvr-up{font-family:var(--fm);font-size:8px;font-weight:700;color:var(--canon-yes);border:1px solid rgba(32,200,112,.2);padding:3px 11px;cursor:pointer;background:transparent;transition:all .18s;}
.tcvr-up:hover,.tcvr-up.on{background:rgba(32,200,112,.08);border-color:var(--canon-yes);}
.tcvr-down{font-family:var(--fm);font-size:8px;font-weight:700;color:var(--canon-no);border:1px solid rgba(204,32,48,.2);padding:3px 11px;cursor:pointer;background:transparent;transition:all .18s;}
.tcvr-down:hover,.tcvr-down.on{background:rgba(204,32,48,.08);border-color:var(--canon-no);}
.tcvr-count{font-family:var(--fm);font-size:7px;font-weight:700;color:rgba(240,236,228,.35);}

/* ═══════════════════════════════════════════
   VIEW 5: FIELD DISPATCHES
═══════════════════════════════════════════ */
#view-dispatches{padding-top:86px;}
.dispatch-layout{display:grid;grid-template-columns:1fr 300px;min-height:calc(100vh - 86px);}
.dispatch-main{padding:28px 36px;}
/* dispatch card */
.dispatch-card{background:var(--panel);border:1px solid rgba(240,236,228,.06);margin-bottom:4px;overflow:hidden;cursor:pointer;transition:all .22s;}
.dispatch-card:hover{border-color:rgba(240,236,228,.16);}
.dispatch-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.dpc-masthead{padding:14px 20px 10px;border-bottom:1px solid rgba(240,236,228,.04);}
.dpcm-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;}
.dpcmt-pub{font-family:var(--fb);font-size:16px;letter-spacing:.08em;}
.dpcmt-date{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
.dpcm-byline{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:rgba(240,236,228,.35);display:flex;align-items:center;gap:8px;}
.dpcmb-author{color:rgba(240,236,228,.5);}
.dpcmb-faction{border:1px solid;padding:1px 5px;}
.dpc-article{padding:14px 20px;}
.dpca-kicker{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;color:var(--fac2);margin-bottom:5px;}
.dpca-headline{font-family:var(--fp);font-style:italic;font-size:clamp(18px,2.5vw,26px);font-weight:700;line-height:1.2;margin-bottom:8px;}
.dpca-deck{font-family:var(--fg);font-style:italic;font-size:13px;color:rgba(240,236,228,.5);line-height:1.7;margin-bottom:10px;}
.dpca-body{font-family:var(--fg);font-size:13px;color:rgba(240,236,228,.55);line-height:1.85;}
.dpca-body::first-letter{font-size:2.5em;font-style:italic;font-weight:700;float:left;line-height:.75;margin-right:5px;margin-top:4px;}
/* dispatch metadata */
.dpc-meta{padding:9px 20px;border-top:1px solid rgba(240,236,228,.04);display:flex;gap:10px;align-items:center;background:rgba(240,236,228,.015);}
.dpcm-tags{display:flex;gap:4px;flex:1;}
.dpcmt-tag{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(240,236,228,.1);padding:2px 6px;color:rgba(240,236,228,.3);}
.dpcm-featured{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold2);border:1px solid rgba(200,144,12,.25);padding:2px 7px;}

/* ═══════════════════════════════════════════
   VIEW 6: LIVE WORLD EVENT
═══════════════════════════════════════════ */
#view-event{padding-top:56px;min-height:100vh;display:flex;flex-direction:column;}
.event-full{flex:1;display:grid;grid-template-columns:1fr 360px;}
/* event main */
.event-main{position:relative;overflow:hidden;display:flex;flex-direction:column;}
/* dramatic event bg */
.em-bg{position:absolute;inset:0;z-index:0;}
.em-vignette{position:absolute;inset:0;background:linear-gradient(to top,rgba(3,2,8,1) 0%,rgba(3,2,8,.5) 60%,rgba(3,2,8,.2) 100%);z-index:1;}
.em-scan{position:absolute;left:0;right:0;height:2px;background:linear-gradient(to right,transparent,rgba(204,40,48,.04),transparent);animation:scanLine 10s linear infinite;pointer-events:none;z-index:2;}
@keyframes scanLine{from{top:-2%}to{top:102%}}
.em-content{position:relative;z-index:3;padding:48px;flex:1;display:flex;flex-direction:column;justify-content:flex-end;}
/* live badge */
.em-live-badge{display:flex;align-items:center;gap:8px;margin-bottom:16px;}
.emlb-dot{width:8px;height:8px;border-radius:50%;background:var(--fac2);animation:blink .5s infinite;}
.emlb-text{font-family:var(--fm);font-size:7px;letter-spacing:.24em;text-transform:uppercase;color:var(--fac2);}
.emlb-count{font-family:var(--fm);font-size:7px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
/* countdown ring */
.em-countdown{position:absolute;top:40px;right:48px;text-align:center;z-index:3;}
.emc-svg{width:80px;height:80px;}
.emc-track{fill:none;stroke:rgba(240,236,228,.06);stroke-width:4;}
.emc-fill{fill:none;stroke:var(--fac2);stroke-width:4;stroke-linecap:round;transform:rotate(-90deg);transform-origin:center;transition:stroke-dashoffset 1s linear;}
.emc-label{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.emc-time{font-family:var(--fb);font-size:18px;letter-spacing:.04em;color:var(--fac2);}
.emc-unit{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
/* event title */
.em-title{font-family:var(--fb);font-size:clamp(40px,7vw,96px);letter-spacing:.05em;line-height:.86;margin-bottom:8px;}
.em-premise{font-family:var(--fg);font-style:italic;font-size:clamp(14px,1.6vw,18px);color:rgba(240,236,228,.55);max-width:640px;line-height:1.95;margin-bottom:20px;}
/* the collective choice */
.em-collective-choice{background:rgba(3,2,8,.8);border:1px solid rgba(204,40,48,.25);padding:20px 22px;backdrop-filter:blur(8px);max-width:700px;}
.emcc-label{font-family:var(--fm);font-size:7px;letter-spacing:.24em;text-transform:uppercase;color:var(--fac2);margin-bottom:5px;display:flex;align-items:center;gap:6px;}
.emcc-label::before{content:'⬡';}
.emcc-question{font-family:var(--fg);font-style:italic;font-size:clamp(15px,1.8vw,19px);color:rgba(240,236,228,.82);line-height:1.8;margin-bottom:14px;}
/* vote options */
.emcc-options{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-bottom:12px;}
.emcco-btn{padding:14px 16px;background:rgba(240,236,228,.03);border:1px solid rgba(240,236,228,.08);cursor:pointer;text-align:left;transition:all .22s;position:relative;overflow:hidden;}
.emcco-btn:hover{border-color:var(--fac);background:rgba(204,40,48,.07);}
.emcco-btn.leading{border-color:rgba(204,40,48,.35);background:rgba(204,40,48,.08);}
.emcco-btn.voted{border-color:var(--fac2);}
/* live vote fill bar */
.emcco-fill{position:absolute;top:0;left:0;bottom:0;background:rgba(204,40,48,.1);transition:width 1s ease;pointer-events:none;}
.emcco-content{position:relative;z-index:1;}
.emccoc-option{font-family:var(--fg);font-style:italic;font-size:14px;color:rgba(240,236,228,.75);margin-bottom:4px;line-height:1.5;}
.emccoc-pct{font-family:var(--fc);font-size:22px;font-weight:900;display:block;line-height:1;}
.emccoc-votes{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
/* live consequence */
.emcc-consequence{font-family:var(--fm);font-size:7px;letter-spacing:.12em;text-transform:uppercase;color:rgba(204,40,48,.6);display:flex;align-items:center;gap:6px;}
/* event sidebar */
.event-sidebar{background:rgba(6,5,14,.98);border-left:1px solid rgba(204,40,48,.08);overflow-y:auto;display:flex;flex-direction:column;}
.event-sidebar::-webkit-scrollbar{width:0;}
.es-header{padding:16px;border-bottom:1px solid rgba(204,40,48,.07);}
.esh-title{font-family:var(--fc);font-size:16px;font-weight:800;letter-spacing:.07em;margin-bottom:4px;}
.esh-sub{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
/* live signal feed */
.es-feed{flex:1;overflow-y:auto;padding:0;}
.es-feed::-webkit-scrollbar{width:0;}
.esf-item{padding:10px 14px;border-bottom:1px solid rgba(240,236,228,.04);animation:liveIn .4s cubic-bezier(.16,1,.3,1) both;}
.esfi-header{display:flex;gap:8px;align-items:center;margin-bottom:4px;}
.esfih-avatar{width:20px;height:20px;border-radius:50%;border:1.5px solid;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;}
.esfih-name{font-family:var(--fm);font-size:6px;font-weight:700;letter-spacing:.08em;flex:1;}
.esfih-time{font-family:var(--fm);font-size:5px;letter-spacing:.06em;color:var(--muted);}
.esfi-text{font-family:var(--fg);font-size:12px;color:rgba(240,236,228,.5);line-height:1.55;}
.esfi-vote{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:1px 5px;margin-top:4px;display:inline-block;}
/* vote totals bar */
.es-totals{padding:12px 14px;border-bottom:1px solid rgba(204,40,48,.08);}
.est-label{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
.est-bar{display:flex;height:10px;overflow:hidden;}
.estb-a{background:var(--fac2);transition:width 1s ease;}
.estb-b{background:var(--fac-heights2);transition:width 1s ease;}
.estb-c{background:var(--fac-meridian2);transition:width 1s ease;}
.estb-d{background:var(--fac-archive2);transition:width 1s ease;}
.est-legend{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px;}
.estl-item{display:flex;align-items:center;gap:4px;font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);}
.estl-dot{width:6px;height:6px;border-radius:50%;}
</style>
</head>
