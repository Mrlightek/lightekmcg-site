      <div class="fcha-progress">
        <div class="fchap-label"><span>FACTION PARTICIPATION</span><span style="color:${f.color2};">1,204 of ${f.members} voted</span></div>
        <div class="fchap-bar"><div class="fchap-fill" style="width:47%;background:${f.color};"></div></div>
      </div>
      <button style="font-family:var(--fc);font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border:1px solid ${f.color};color:${f.color2};background:rgba(${hexToRgb(f.color)},0.08);padding:9px 22px;cursor:pointer;transition:all .2s;" onclick="sw('event',null)">CAST YOUR FACTION VOTE →</button>
    </div>`;
  // feed
  const feed=document.getElementById('faction-feed');
  feed.innerHTML='';
  f.feed.forEach((item,i)=>{
    const d=document.createElement('div');
    d.className='ff-item';
    d.style.animationDelay=(i*.08)+'s';
    d.innerHTML=`
      <div class="ffi-header">
        <div class="ffih-avatar" style="border-color:${f.color}40;background:${f.color}12;">${item.avatar}</div>
        <div class="ffih-meta">
          <div class="ffihm-name" style="color:${f.color2};">${item.user}</div>
          <div class="ffihm-time">${item.time}</div>
        </div>
      </div>
      <div class="ffi-content">${item.text}</div>
      <div class="ffi-reactions">${item.reactions.map(r=>`<button class="ffir-btn" onclick="reactFeed(this)">${r.emoji} <span>${r.count}</span></button>`).join('')}</div>`;
    feed.appendChild(d);
  });
  addHoverFX();
}

function reactFeed(btn){
  btn.classList.toggle('active');
  const span=btn.querySelector('span');
  const n=parseInt(span.textContent);
  span.textContent=btn.classList.contains('active')?n+1:n-1;
}

