function renderFactionOnboard(){
  const grid=document.getElementById('fo-grid');
  if(grid.children.length)return;
  FACTIONS.forEach(f=>{
    const d=document.createElement('div');
    d.className='fo-card';
    d.style.setProperty('--fac',f.color);
    d.innerHTML=`
      <div style="position:absolute;top:0;left:0;right:0;height:3px;background:${f.color};"></div>
      <div style="position:absolute;inset:0;background:${f.color};pointer-events:none;opacity:0;transition:opacity .28s;" class="fo-hover-bg"></div>
      <span class="foc-seal">${f.seal}</span>
      <div class="foc-name" style="color:${f.color};">${f.name}</div>
      <div class="foc-motto">${f.motto}</div>
      <div class="foc-members">${f.members} citizens aligned</div>
      <div class="foc-desc" style="font-family:var(--fg);font-size:12px;color:rgba(240,236,228,.4);line-height:1.65;margin-bottom:10px;">${f.desc}</div>
      <button class="foc-btn" style="border-color:${f.color};color:${f.color};" onclick="joinFaction('${f.id}')">ALIGN WITH ${f.name.split(' ').slice(-1)[0]} →</button>`;
