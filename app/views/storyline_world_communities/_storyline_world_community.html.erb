  addHoverFX();initScrollReveal();
}

// ── CANON DEBATES ────────────────────────────
function renderDebates(){
  const list=document.getElementById('debates-list');
  if(list.children.length)return;
  DEBATES.forEach(db=>{
    const voted=votedDebates[db.question];
    const d=document.createElement('div');
    d.className='debate-card fade-up'+(db.featured?' featured':'');
    const yPct=db.yesVotes;const nPct=db.noVotes;
    const isResolved=db.status==='resolved';
    d.innerHTML=`
      <div class="dc-header">
        <div class="dch-top">
          <div class="dcht-badges">
            <div class="dcht-badge ${isResolved?'resolved':'open'}">${isResolved?'✓ RESOLVED':'◉ OPEN DEBATE'}</div>
            ${db.hot?'<div class="dcht-badge hot">🔥 HOT</div>':''}
            ${db.creatorResponse?'<div class="dcht-badge creator">✍ CREATOR RESPONDED</div>':''}
          </div>
          <div class="dcht-voters">${db.totalVoters.toLocaleString()} CITIZENS VOTED</div>
        </div>
        <div class="dch-question">${db.question}</div>
        <div class="dch-context">${db.context}</div>
      </div>
      <div class="dc-vote">
        <div class="dcvb-pcts">
          <div class="dcvb-yes-pct">${yPct}% YES</div>
          <div class="dcvb-mid">${db.totalVoters.toLocaleString()} votes</div>
          <div class="dcvb-no-pct">${nPct}% NO</div>
        </div>
        <div class="dcvb-bars" style="width:100%;">
          <div class="dcvb-yes" style="width:${yPct*.7}%;"></div>
          <div style="flex:1;height:8px;background:rgba(240,236,228,.03);"></div>
          <div class="dcvb-no" style="width:${nPct*.7}%;"></div>
        </div>
        ${!isResolved?`<div class="dcv-btns" style="margin-top:10px;">
          <button class="dcvb-btn dcvb-yes-btn${voted==='yes'?' voted':''}" onclick="voteDebate(this,'${db.question}','yes')">✓ YES — IT HAPPENED</button>
          <button class="dcvb-btn dcvb-no-btn${voted==='no'?' voted':''}" onclick="voteDebate(this,'${db.question}','no')">✗ NO — IT DIDN'T</button>
        </div>`:''}
      </div>
      ${db.creatorResponse?`<div class="dc-creator-response"><div class="dccr-label">CREATOR RESPONSE — ${db.creatorResponse.creator.toUpperCase()}</div><div class="dccr-text">"${db.creatorResponse.text}"</div></div>`:''}
      ${isResolved&&db.resolution?`<div class="dc-verdict"><div class="dcv-label">◈ COMMUNITY VERDICT</div><div class="dcv-result"><div class="dcvr-icon">${db.resolution.verdict==='CONFIRMED'?'✓':'✗'}</div><div class="dcvr-text">${db.resolution.text}</div><div class="dcvr-pct" style="color:${db.resolution.color};">${db.resolution.pct}%</div></div></div>`:''}`;
    list.appendChild(d);
  });
  // sidebar
  const mvs=document.getElementById('my-votes-sidebar');
  if(!mvs.children.length){
    mvs.innerHTML=`<div style="font-family:var(--fg);font-style:italic;font-size:11px;color:rgba(240,236,228,.28);line-height:1.65;">You've voted on 8 debates. 3 have been resolved: 2 aligned with your vote, 1 didn't.</div>`;
  }
  const crs=document.getElementById('creator-responses-sidebar');
  if(!crs.children.length){
    DEBATES.filter(d=>d.creatorResponse).forEach(d=>{
      const el=document.createElement('div');
      el.className='bs-item';
      el.innerHTML=`<div style="font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold2);margin-bottom:2px;">✍ ${d.creatorResponse.creator.toUpperCase()}</div><div style="font-family:var(--fg);font-style:italic;font-size:11px;color:rgba(240,236,228,.5);line-height:1.5;">"${d.creatorResponse.text.slice(0,70)}…"</div>`;
      crs.appendChild(el);
    });
  }
  addHoverFX();initScrollReveal();
}

function voteDebate(btn,question,vote){
  votedDebates[question]=vote;
  const card=btn.closest('.debate-card');
  card.querySelectorAll('.dcvb-btn').forEach(b=>{b.classList.remove('voted');});
  btn.classList.add('voted');
  btn.textContent=vote==='yes'?'✓ YOU VOTED YES':'✗ YOU VOTED NO';
}

// ── THEORIES ─────────────────────────────────
function renderTheories(){
  const list=document.getElementById('theories-list');
  if(list.children.length)return;
  THEORIES.forEach(t=>{
    const d=document.createElement('div');
    d.className=`theory-card fade-up ${t.status}`;
    d.innerHTML=`
      <div style="position:absolute;top:0;left:0;right:0;height:2px;background:${t.color};"></div>
      <div class="tc-body">
        <div class="tc-top">
          <div class="tc-verdict ${t.status}">${t.status==='pending'?'⬡ PENDING RESOLUTION':t.status==='confirmed'?'✓ CONFIRMED':'✗ DEBUNKED'}</div>
          <div class="tc-support" style="color:${t.status==='debunked'?'var(--canon-no)':t.status==='confirmed'?'var(--canon-yes)':'rgba(240,236,228,.3)'};">${t.support.toLocaleString()} SUPPORT · ${t.oppose.toLocaleString()} DOUBT</div>
        </div>
        <div class="tc-title" style="color:rgba(240,236,228,${t.status==='debunked'?.5:.88});">${t.title}</div>
        <div class="tc-because">Because: ${t.because}</div>
        <div class="tc-evidence">
          ${t.evidence.map(e=>`<div class="tce-item"><div class="tce-ref">${e.ref}</div><div class="tce-fact">${e.fact}</div></div>`).join('')}
        </div>
        ${t.resolution?`<div class="tc-resolution${t.status==='debunked'?' debunked-box':''}"><div class="tcres-label" style="color:${t.status==='confirmed'?'var(--canon-yes)':'var(--canon-no)'};">◈ ${t.status==='confirmed'?'THEORY CONFIRMED':'THEORY DEBUNKED'}</div><div class="tcres-text">"${t.resolution.text}"</div></div>`:''}
      </div>
      <div class="tc-vote-row">
        <div class="tcvr-label">Do you support this theory?</div>
        <button class="tcvr-up" onclick="this.classList.toggle('on')">▲ ${t.support.toLocaleString()}</button>
        <button class="tcvr-down" onclick="this.classList.toggle('on')">▼ ${t.oppose.toLocaleString()}</button>
      </div>`;
    list.appendChild(d);
  });
  // leaderboard sidebar
  const tl=document.getElementById('theory-leaderboard');
  if(!tl.children.length){
    [['BloodlineTrue','4 confirmed theories','#CC2830'],['FrequencyMapper','3 confirmed, 1 debunked','#18A860'],['DynastyChronicles','2 confirmed, 0 debunked','#CC2830'],['SignalListener','1 confirmed, 2 pending','#18A860']].forEach(([n,s,c])=>{
      const d=document.createElement('div');
      d.className='bs-item';
      d.innerHTML=`<div style="font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:${c};margin-bottom:2px;">${s}</div><div class="bsi-name">${n}</div>`;
      tl.appendChild(d);
    });
  }
  addHoverFX();initScrollReveal();
}

// ── DISPATCHES ───────────────────────────────
function renderDispatches(){
  const list=document.getElementById('dispatches-list');
  if(list.children.length)return;
  DISPATCHES.forEach(dp=>{
    const fac=FACTIONS.find(f=>f.id===dp.facId)||FACTIONS[0];
    const d=document.createElement('div');
    d.className='dispatch-card fade-up';
    d.style.position='relative';
    d.innerHTML=`
      <div style="position:absolute;top:0;left:0;right:0;height:2px;background:${fac.color};"></div>
      <div class="dpc-masthead">
        <div class="dpcm-top"><div class="dpcmt-pub" style="color:${fac.color2};">${dp.pub}</div><div class="dpcmt-date">${dp.date}</div></div>
        <div class="dpcm-byline">FILED BY <span class="dpcmb-author" style="color:${fac.color2};">${dp.author}</span> <div class="dpcmb-faction" style="border-color:${fac.color}40;color:${fac.color2};">${fac.name}</div></div>
      </div>
      <div class="dpc-article">
        <div class="dpca-kicker" style="color:${fac.color2};">${dp.kicker}</div>
        <div class="dpca-headline">${dp.headline}</div>
        <div class="dpca-deck">${dp.deck}</div>
        <div class="dpca-body">${dp.body}</div>
      </div>
      <div class="dpc-meta">
        <div class="dpcm-tags">${dp.tags.map(t=>`<div class="dpcmt-tag">${t}</div>`).join('')}</div>
        ${dp.featured?`<div class="dpcm-featured">◉ FEATURED</div>`:''}
        ${dp.citations>0?`<div style="font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold2);border:1px solid rgba(200,144,12,.2);padding:2px 7px;">✍ CITED BY ${dp.citations} CREATOR${dp.citations>1?'S':''}</div>`:''}
      </div>`;
    list.appendChild(d);
  });
  const fd=document.getElementById('featured-dispatches');
  if(!fd.children.length){fd.innerHTML=`<div style="font-family:var(--fg);font-style:italic;font-size:11px;color:rgba(240,236,228,.28);line-height:1.65;">2 dispatches currently featured on the Ironbell City World page. Yours could be next — file a dispatch that changes the conversation.</div>`;}
  addHoverFX();initScrollReveal();
}

// ── LIVE EVENT ───────────────────────────────
function renderEvent(){
  const opts=document.getElementById('event-options');
  if(!opts.children.length){
    const total=EVENT_OPTIONS.reduce((s,o)=>s+o.votes,0);
    EVENT_OPTIONS.forEach(o=>{
      const d=document.createElement('div');
      d.className='emcco-btn'+(o.pct===44?' leading':'');
      d.innerHTML=`<div class="emcco-fill" style="width:${o.pct}%;background:${o.color}30;"></div><div class="emcco-content"><div class="emccoc-option">${o.label}</div><span class="emccoc-pct" style="color:${o.color};">${o.pct}%</span><div class="emccoc-votes">${o.votes.toLocaleString()} votes</div></div>`;
      d.onclick=()=>{if(votedEvent)return;votedEvent=o;document.querySelectorAll('.emcco-btn').forEach(b=>b.classList.remove('voted'));d.classList.add('voted');document.getElementById('event-consequence').textContent=`→ You voted: "${o.label.slice(0,40)}…" Your vote has been recorded.`;};
      opts.appendChild(d);
    });
  }
  // Signal feed
  const feed=document.getElementById('es-feed');
  if(!feed.children.length){
    SIGNAL_FEED.forEach((item,i)=>{
      const d=document.createElement('div');
      d.className='esf-item';
      d.style.animationDelay=(i*.06)+'s';
      d.innerHTML=`
        <div class="esfi-header">
          <div class="esfih-avatar" style="border-color:${item.fColor}40;background:${item.fColor}12;">${item.avatar}</div>
          <div class="esfih-name" style="color:${item.fColor};">${item.user}</div>
          <div class="esfih-time">${item.time}</div>
        </div>
        <div class="esfi-text">${item.text}</div>
        <div class="esfi-vote" style="border-color:${item.fColor}40;color:${item.fColor};">${item.vote}</div>`;
      feed.appendChild(d);
    });
  }
  // Countdown
  if(!timerInterval){
    timerInterval=setInterval(()=>{
      timerVal--;
      if(timerVal<0){clearInterval(timerInterval);timerVal=0;}
      const m=Math.floor(timerVal/60),s=timerVal%60;
      const el=document.getElementById('event-time');
      if(el)el.textContent=m+':'+(s<10?'0':'')+s;
      const circle=document.getElementById('countdown-circle');
      if(circle){
        const maxDash=214,elapsed=(14*60+32-timerVal)/(14*60+32);
        circle.setAttribute('stroke-dashoffset',maxDash*elapsed);
      }
    },1000);
  }
  addHoverFX();
}

// ── UTILS ────────────────────────────────────
function hexToRgb(hex){try{const r=/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);return r?`${parseInt(r[1],16)},${parseInt(r[2],16)},${parseInt(r[3],16)}`:'0,0,0';}catch(e){return'0,0,0';}}
function bigCur(){cur.style.width='12px';cur.style.height='12px';cur2.style.width='42px';cur2.style.height='42px';}
function normCur(){cur.style.width='8px';cur.style.height='8px';cur2.style.width='32px';cur2.style.height='32px';}
function addHoverFX(){
  document.querySelectorAll('button,.ff-item,.quote-card,.debate-card,.theory-card,.dispatch-card,.fo-card,.emcco-btn,.bs-item,.upcoming-node').forEach(el=>{
    if(!el._hb){el.addEventListener('mouseenter',bigCur);el.addEventListener('mouseleave',normCur);el._hb=true;}
  });
}
function initScrollReveal(){
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.04});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
}

// ── INIT ────────────────────────────────────
renderFactionOnboard();
addHoverFX();
</script>
</body>
</html>
