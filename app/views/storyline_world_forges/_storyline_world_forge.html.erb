<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STORYLINE — World Forge</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Barlow+Condensed:wght@300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;cursor:none;}
:root{
  --void:#030208;--deep:#06050E;--mid:#0A0818;--panel:#0F0C1C;--card:#131020;--lift:#181428;
  --white:#F0ECE4;--off:#C0B8B0;--muted:#5A5468;--dim:#1C1830;
  --world:#D04820;--world2:#F06030;--world3:#FF8050;
  --gold:#C8980C;--gold2:#E0B020;--gold3:#F8C838;
  --fac-a:#CC2830;--fac-b:#2858C8;--fac-c:#18A860;--fac-d:#9820C8;
  --canon:#28C088;--canon2:#40E0A0;
  --fb:'Bebas Neue',sans-serif;
  --fg:'EB Garamond',serif;
  --fc:'Barlow Condensed',sans-serif;
  --fp:'Playfair Display',serif;
  --fm:'Space Mono',monospace;
}
html{scroll-behavior:smooth;}
body{background:var(--void);color:var(--white);font-family:var(--fg);overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");background-size:200px;pointer-events:none;z-index:0;opacity:.8;}

#cur{width:8px;height:8px;background:var(--world2);position:fixed;z-index:9999;pointer-events:none;transform:translate(-50%,-50%);border-radius:50%;box-shadow:0 0 16px var(--world);transition:all .15s;}
#cur2{width:32px;height:32px;border:1px solid rgba(240,96,48,.2);border-radius:50%;position:fixed;z-index:9998;pointer-events:none;transform:translate(-50%,-50%);transition:left .1s cubic-bezier(.16,1,.3,1),top .1s,width .2s,height .2s;}

@keyframes blink{0%,100%{opacity:1}50%{opacity:.1}}
@keyframes float{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-6px) rotate(.5deg)}}
@keyframes pulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.02)}}
@keyframes scanLine{from{top:-5%}to{top:105%}}
@keyframes mapPulse{0%,100%{box-shadow:0 0 0 0 var(--world)}60%{box-shadow:0 0 0 12px transparent}100%{box-shadow:0 0 0 0 transparent}}
@keyframes shimmer{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes timelineIn{from{opacity:0;transform:scaleX(0)}to{opacity:1;transform:scaleX(1)}}
.fade-up{opacity:0;transform:translateY(22px);transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1);}
.fade-up.vis{opacity:1;transform:none;}

/* VIEWS */
.view{display:none;}
.view.active{display:block;}

/* ═══════════════════════════════════════════
   TOPNAV
═══════════════════════════════════════════ */
.topnav{position:fixed;top:0;left:0;right:0;z-index:400;height:56px;background:rgba(3,2,8,.97);border-bottom:1px solid rgba(240,96,48,.08);display:flex;align-items:center;justify-content:space-between;padding:0 28px;}
.topnav::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(240,96,48,.35),rgba(240,96,48,.55),rgba(240,96,48,.35),transparent);}
.tn-left{display:flex;align-items:center;gap:14px;}
.tn-logo{font-family:var(--fb);font-size:20px;letter-spacing:.14em;cursor:pointer;color:var(--white);}
.tn-logo span{color:var(--world2);}
.tn-sep{width:1px;height:18px;background:rgba(240,96,48,.12);}
.tn-world{display:flex;align-items:center;gap:7px;}
.tnw-icon{font-size:14px;}
.tnw-name{font-family:var(--fb);font-size:15px;letter-spacing:.08em;color:var(--world2);}
.tnw-status{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:rgba(240,96,48,.55);border:1px solid rgba(240,96,48,.2);padding:2px 7px;}
.tn-tabs{display:flex;gap:0;}
.tn-tab{font-family:var(--fm);font-size:7px;letter-spacing:.16em;text-transform:uppercase;color:rgba(240,236,228,.3);padding:0 16px;height:56px;display:flex;align-items:center;border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;}
.tn-tab:hover{color:rgba(240,236,228,.7);}
.tn-tab.on{color:var(--white);border-bottom-color:var(--world2);}
.tn-right{display:flex;align-items:center;gap:8px;}
.tn-btn{font-family:var(--fc);font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:7px 16px;cursor:pointer;transition:all .2s;background:transparent;}
.tn-btn.outline{border-color:rgba(240,236,228,.12);color:rgba(240,236,228,.38);}
.tn-btn.outline:hover{border-color:rgba(240,236,228,.3);color:rgba(240,236,228,.7);}
.tn-btn.primary{border-color:var(--world);color:var(--world2);background:rgba(208,72,32,.08);}
.tn-btn.primary:hover{background:rgba(208,72,32,.16);}
.tn-collab{display:flex;align-items:center;gap:-2px;}
.tnc-avatar{width:24px;height:24px;border-radius:50%;border:2px solid var(--void);display:flex;align-items:center;justify-content:center;font-size:10px;margin-left:-4px;transition:transform .2s;}
.tnc-avatar:hover{transform:scale(1.2);z-index:5;}
.tnc-avatar:first-child{margin-left:0;}

/* ═══════════════════════════════════════════
   VIEW 1: THE WORLD MAP
═══════════════════════════════════════════ */
#view-map{padding-top:56px;}
.map-layout{display:grid;grid-template-columns:1fr 300px;height:calc(100vh - 56px);}
/* map canvas */
.map-canvas{position:relative;overflow:hidden;background:var(--mid);}
/* atmospheric background */
.mc-atmosphere{position:absolute;inset:0;background:radial-gradient(ellipse at 40% 45%,rgba(208,72,32,.08) 0%,rgba(40,30,60,.3) 50%,rgba(3,2,8,.9) 100%);}
/* map grid */
.mc-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(240,236,228,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(240,236,228,.018) 1px,transparent 1px);background-size:48px 48px;}
/* map districts — SVG territories */
.mc-svg{position:absolute;inset:0;}
/* location pins */
.map-pin{position:absolute;transform:translate(-50%,-100%);cursor:pointer;transition:transform .2s;}
.map-pin:hover{transform:translate(-50%,-100%) scale(1.15);}
.mp-dot{width:12px;height:12px;border-radius:50%;border:2px solid;margin:0 auto;position:relative;z-index:1;}
.mp-dot::after{content:'';position:absolute;inset:-4px;border-radius:50%;border:1px solid;opacity:.3;animation:mapPulse 2s infinite;}
.mp-stem{width:2px;height:14px;margin:0 auto;background:linear-gradient(to bottom,rgba(240,236,228,.4),transparent);}
.mp-label{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;text-align:center;white-space:nowrap;margin-top:3px;padding:2px 6px;background:rgba(3,2,8,.8);}
/* map controls */
.map-controls{position:absolute;top:16px;left:16px;z-index:10;display:flex;flex-direction:column;gap:3px;}
.mc-btn{width:32px;height:32px;background:rgba(3,2,8,.85);border:1px solid rgba(240,236,228,.1);color:rgba(240,236,228,.5);font-family:var(--fb);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.mc-btn:hover{border-color:var(--world);color:var(--world2);}
/* layer toggles */
.map-layers{position:absolute;top:16px;right:16px;z-index:10;display:flex;flex-direction:column;gap:4px;}
.ml-item{display:flex;align-items:center;gap:7px;padding:5px 10px;background:rgba(3,2,8,.85);border:1px solid rgba(240,236,228,.08);cursor:pointer;transition:all .2s;}
.ml-item.on{border-color:rgba(240,236,228,.2);}
.ml-dot{width:8px;height:8px;border-radius:50%;}
.ml-label{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:rgba(240,236,228,.45);}
/* map sidebar */
.map-sidebar{background:rgba(6,5,14,.98);border-left:1px solid rgba(240,96,48,.07);overflow-y:auto;display:flex;flex-direction:column;}
.map-sidebar::-webkit-scrollbar{width:0;}
.ms-location-card{border-bottom:1px solid rgba(240,96,48,.07);}
.mslc-header{padding:14px 16px;cursor:pointer;transition:background .15s;}
.mslc-header:hover{background:rgba(240,96,48,.04);}
.mslch-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:5px;}
.mslcht-name{font-family:var(--fb);font-size:16px;letter-spacing:.07em;}
.mslcht-type{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;border:1px solid;padding:2px 6px;}
.mslch-desc{font-family:var(--fg);font-style:italic;font-size:11px;color:rgba(240,236,228,.42);line-height:1.6;}
.mslc-stories{padding:0 16px 12px;display:flex;flex-wrap:wrap;gap:4px;}
.mslcs-tag{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(240,96,48,.2);padding:2px 7px;color:rgba(208,72,32,.7);}
/* selected location detail */
.ms-detail{padding:14px 16px;flex:1;}
.msd-label{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--world2);margin-bottom:10px;display:flex;align-items:center;gap:5px;}
.msd-label::before{content:'◈';}
.msd-name{font-family:var(--fb);font-size:26px;letter-spacing:.06em;margin-bottom:4px;}
.msd-lore{font-family:var(--fg);font-style:italic;font-size:13px;color:rgba(240,236,228,.55);line-height:1.8;margin-bottom:14px;}
.msd-appears{margin-bottom:12px;}
.msda-label{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
.msda-item{display:flex;gap:7px;align-items:center;padding:5px 0;border-bottom:1px solid rgba(240,236,228,.04);}
.msda-item:last-child{border-bottom:none;}
.msdai-ep{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);min-width:60px;}
.msdai-title{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(240,236,228,.6);}
.msd-faction{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;}
.msdf-label{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);width:100%;margin-bottom:2px;}
.msdf-tag{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:3px 9px;}

/* ═══════════════════════════════════════════
   VIEW 2: WORLD BIBLE
═══════════════════════════════════════════ */
#view-bible{padding-top:56px;}
.bible-layout{display:grid;grid-template-columns:220px 1fr 260px;min-height:calc(100vh - 56px);}
/* bible nav */
.bible-nav{background:rgba(6,5,14,.98);border-right:1px solid rgba(240,96,48,.07);overflow-y:auto;padding:14px 0;}
.bible-nav::-webkit-scrollbar{width:0;}
.bn-section{padding:8px 0 4px;}
.bn-hdr{font-family:var(--fm);font-size:6px;letter-spacing:.24em;text-transform:uppercase;color:rgba(90,84,104,.9);padding:0 14px;margin-bottom:5px;}
.bn-item{display:flex;align-items:center;gap:7px;padding:7px 12px;border-left:2px solid transparent;cursor:pointer;transition:all .15s;}
.bn-item:hover{background:rgba(240,96,48,.04);}
.bn-item.on{background:rgba(240,96,48,.06);border-left-color:var(--world2);}
.bn-item.on .bn-label{color:var(--world2);}
.bn-icon{font-size:12px;flex-shrink:0;}
.bn-label{font-family:var(--fg);font-size:12px;color:rgba(240,236,228,.42);}
.bn-count{font-family:var(--fm);font-size:6px;font-weight:700;color:rgba(240,236,228,.2);}
.bn-divider{height:1px;background:rgba(240,96,48,.05);margin:6px 0;}
/* bible main */
.bible-main{padding:28px 36px;overflow-y:auto;}
.bible-main::-webkit-scrollbar{width:3px;}
.bible-main::-webkit-scrollbar-thumb{background:rgba(240,96,48,.15);}
/* lore entry */
.lore-hdr{margin-bottom:24px;}
.lh-category{font-family:var(--fm);font-size:7px;letter-spacing:.26em;text-transform:uppercase;color:var(--world2);margin-bottom:5px;display:flex;align-items:center;gap:6px;}
.lh-category::before{content:'◈';}
.lh-title{font-family:var(--fb);font-size:clamp(36px,5vw,68px);letter-spacing:.05em;line-height:.88;margin-bottom:8px;}
.lh-canon-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(40,192,136,.08);border:1px solid rgba(40,192,136,.25);padding:4px 12px;margin-bottom:10px;}
.lhcb-dot{width:5px;height:5px;border-radius:50%;background:var(--canon);animation:blink .9s infinite;}
.lhcb-text{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;color:var(--canon2);}
.lh-summary{font-family:var(--fg);font-size:clamp(15px,1.6vw,18px);color:rgba(240,236,228,.68);line-height:2;margin-bottom:16px;}
/* lore sections */
.lore-section{margin-bottom:24px;padding-bottom:24px;border-bottom:1px solid rgba(240,236,228,.05);}
.lore-section:last-child{border-bottom:none;}
.ls-title{font-family:var(--fc);font-size:18px;font-weight:800;letter-spacing:.08em;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.ls-title::before{content:'';display:block;width:3px;height:17px;background:var(--world2);}
.ls-text{font-family:var(--fg);font-size:clamp(13px,1.35vw,15px);color:rgba(240,236,228,.55);line-height:2;}
.ls-text em{color:var(--world3);font-style:italic;}
.ls-text strong{color:rgba(240,236,228,.8);font-style:normal;font-weight:600;}
/* disputed badge */
.disputed{background:rgba(200,144,12,.06);border:1px solid rgba(200,144,12,.2);padding:10px 14px;display:flex;gap:9px;align-items:flex-start;margin:12px 0;}
.dis-icon{font-size:14px;flex-shrink:0;}
.dis-body{}
.disb-label{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold2);margin-bottom:3px;}
.disb-text{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(240,236,228,.45);line-height:1.6;}
/* appearances table */
.appearances-table{width:100%;}
.at-head{display:grid;grid-template-columns:1fr 1.5fr 1fr 1fr;gap:8px;padding:6px 0;border-bottom:1px solid rgba(240,96,48,.12);}
.at-th{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);}
.at-row{display:grid;grid-template-columns:1fr 1.5fr 1fr 1fr;gap:8px;padding:7px 0;border-bottom:1px solid rgba(240,236,228,.04);align-items:center;cursor:pointer;transition:background .15s;}
.at-row:hover{background:rgba(240,96,48,.03);}
.at-cell{font-family:var(--fg);font-size:12px;color:rgba(240,236,228,.5);}
.at-cell.strong{color:rgba(240,236,228,.8);font-weight:600;}
.at-cell.ep{font-family:var(--fm);font-size:7px;letter-spacing:.06em;color:var(--muted);}
.at-canon{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:1px 5px;}
.at-canon.confirmed{border-color:rgba(40,192,136,.3);color:var(--canon);}
.at-canon.disputed{border-color:rgba(200,144,12,.3);color:var(--gold2);}
/* bible sidebar */
.bible-sidebar{background:rgba(6,5,14,.98);border-left:1px solid rgba(240,96,48,.07);padding:14px;overflow-y:auto;}
.bible-sidebar::-webkit-scrollbar{width:0;}
.bs-section{margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid rgba(240,96,48,.06);}
.bs-section:last-child{border-bottom:none;}
.bss-title{font-family:var(--fm);font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:9px;display:flex;align-items:center;gap:5px;}
.bss-title::before{content:'◈';color:var(--world2);}
.bs-item{padding:7px 9px;background:var(--panel);border:1px solid rgba(240,236,228,.04);margin-bottom:3px;cursor:pointer;transition:all .18s;}
.bs-item:hover{border-color:rgba(240,96,48,.2);}
.bsi-label{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:2px;}
.bsi-name{font-family:var(--fg);font-size:13px;font-style:italic;color:rgba(240,236,228,.65);}
/* edit controls */
.bs-edit-btn{display:block;width:100%;font-family:var(--fc);font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(240,96,48,.22);color:var(--world2);background:rgba(208,72,32,.06);padding:10px;cursor:pointer;transition:all .2s;text-align:center;margin-bottom:5px;}
.bs-edit-btn:hover{background:rgba(208,72,32,.12);}

/* ═══════════════════════════════════════════
   VIEW 3: CHARACTER NETWORK
═══════════════════════════════════════════ */
#view-characters{padding-top:56px;}
.char-layout{display:grid;grid-template-columns:1fr 320px;min-height:calc(100vh - 56px);}
/* character network visualization */
.char-network{background:var(--mid);position:relative;overflow:hidden;}
.cn-title{position:absolute;top:20px;left:20px;z-index:5;}
.cnt-label{font-family:var(--fm);font-size:6px;letter-spacing:.24em;text-transform:uppercase;color:var(--world2);margin-bottom:4px;}
.cnt-name{font-family:var(--fb);font-size:22px;letter-spacing:.07em;}
/* character nodes — CSS only */
.cn-canvas{position:absolute;inset:0;}
.cn-svg{position:absolute;inset:0;}
/* character node */
.char-node{position:absolute;cursor:pointer;transform:translate(-50%,-50%);transition:transform .2s;}
.char-node:hover,.char-node.selected{transform:translate(-50%,-50%) scale(1.12);}
.chn-ring{border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;font-size:22px;position:relative;background:rgba(3,2,8,.6);transition:all .2s;}
.char-node.selected .chn-ring,.char-node:hover .chn-ring{border-width:3px;box-shadow:0 0 24px rgba(208,72,32,.4);}
.chn-name{font-family:var(--fm);font-size:6px;letter-spacing:.08em;text-transform:uppercase;text-align:center;margin-top:5px;white-space:nowrap;}
.chn-role{font-family:var(--fm);font-size:5px;letter-spacing:.06em;text-transform:uppercase;text-align:center;color:var(--muted);white-space:nowrap;}
/* char filter bar */
.char-filters{position:absolute;bottom:20px;left:20px;z-index:5;display:flex;gap:5px;}
.cf-btn{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;border:1px solid rgba(240,236,228,.1);background:rgba(3,2,8,.8);color:rgba(240,236,228,.35);padding:5px 11px;cursor:pointer;transition:all .2s;}
.cf-btn.on{border-color:var(--world);color:var(--world2);background:rgba(208,72,32,.1);}
/* char sidebar */
.char-sidebar{background:rgba(6,5,14,.98);border-left:1px solid rgba(240,96,48,.07);overflow-y:auto;padding:0;}
.char-sidebar::-webkit-scrollbar{width:0;}
/* character card */
.char-card{padding:20px 18px;border-bottom:1px solid rgba(240,96,48,.07);}
.cc-header{display:flex;gap:14px;align-items:flex-start;margin-bottom:12px;}
.cch-avatar{width:56px;height:56px;border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.cch-info{}
.cchi-name{font-family:var(--fb);font-size:20px;letter-spacing:.07em;line-height:1;margin-bottom:3px;}
.cchi-role{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;margin-bottom:3px;}
.cchi-faction{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:2px 7px;display:inline-block;}
.cc-desc{font-family:var(--fg);font-style:italic;font-size:13px;color:rgba(240,236,228,.5);line-height:1.75;margin-bottom:12px;}
/* appearances */
.cc-appearances{margin-bottom:12px;}
.cca-label{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:7px;}
.cca-item{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid rgba(240,236,228,.04);}
.cca-item:last-child{border-bottom:none;}
.ccai-project{font-family:var(--fg);font-size:12px;font-style:italic;color:rgba(240,236,228,.55);}
.ccai-eps{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
/* relationships */
.cc-rels{margin-bottom:12px;}
.ccr-label{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:7px;}
.ccr-item{display:flex;gap:9px;align-items:center;padding:5px 0;border-bottom:1px solid rgba(240,236,228,.04);}
.ccr-item:last-child{border-bottom:none;}
.ccri-avatar{width:22px;height:22px;border-radius:50%;border:1px solid rgba(240,236,228,.15);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;}
.ccri-name{font-family:var(--fg);font-size:12px;flex:1;}
.ccri-rel{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}

/* ═══════════════════════════════════════════
   VIEW 4: CANON TIMELINE
═══════════════════════════════════════════ */
#view-timeline{padding-top:56px;padding-bottom:60px;}
.timeline-wrap{padding:36px 48px;}
.tl-header{text-align:center;margin-bottom:36px;}
.tlh-title{font-family:var(--fb);font-size:clamp(36px,7vw,88px);letter-spacing:.06em;line-height:.86;margin-bottom:8px;}
.tlh-sub{font-family:var(--fg);font-style:italic;font-size:clamp(13px,1.4vw,16px);color:rgba(240,236,228,.38);max-width:560px;margin:0 auto;line-height:2;}
/* project filter */
.tl-filters{display:flex;gap:5px;justify-content:center;flex-wrap:wrap;margin-bottom:32px;}
.tlf-pill{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;border:1px solid rgba(240,236,228,.1);background:rgba(240,236,228,.03);color:rgba(240,236,228,.35);padding:6px 14px;cursor:pointer;transition:all .18s;}
.tlf-pill.on{border-color:var(--world);color:var(--world2);background:rgba(208,72,32,.08);}
/* the timeline axis */
.timeline-axis{position:relative;margin-bottom:20px;}
.ta-track{height:3px;background:linear-gradient(to right,transparent,rgba(240,96,48,.3),rgba(240,96,48,.6),rgba(240,96,48,.3),transparent);margin-bottom:0;position:relative;}
.ta-year-markers{display:flex;justify-content:space-between;padding:0 40px;}
.ta-year{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
/* event rows per project */
.tl-rows{position:relative;}
.tl-row{display:flex;align-items:center;gap:0;margin-bottom:4px;position:relative;}
.tlr-label{width:140px;flex-shrink:0;text-align:right;padding-right:16px;}
.tlrl-name{font-family:var(--fm);font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:rgba(240,236,228,.5);}
.tlrl-format{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.tlr-track{flex:1;height:36px;position:relative;border-top:1px solid rgba(240,236,228,.04);}
/* event marker */
.tl-event{position:absolute;top:50%;transform:translateY(-50%);cursor:pointer;}
.tle-dot{width:10px;height:10px;border-radius:50%;border:2px solid;background:var(--void);transform:translateX(-50%);position:relative;transition:transform .2s;}
.tl-event:hover .tle-dot{transform:translateX(-50%) scale(1.4);}
.tle-dot::after{content:'';position:absolute;inset:-4px;border-radius:50%;border:1px solid;opacity:.3;}
.tle-tooltip{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);background:rgba(3,2,8,.95);border:1px solid rgba(240,96,48,.2);padding:7px 10px;white-space:nowrap;z-index:10;pointer-events:none;opacity:0;transition:opacity .18s;min-width:160px;}
.tl-event:hover .tle-tooltip{opacity:1;}
.tlet-project{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:var(--world2);margin-bottom:2px;}
.tlet-title{font-family:var(--fg);font-size:12px;font-style:italic;}
.tlet-type{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:2px;}
/* crossover moment */
.tl-crossover-marker{position:absolute;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent,var(--gold),transparent);opacity:.5;pointer-events:none;}
.tl-crossover-label{position:absolute;top:-22px;transform:translateX(-50%);font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold2);background:rgba(3,2,8,.9);padding:2px 6px;white-space:nowrap;}

/* ═══════════════════════════════════════════
   VIEW 5: FACTION MAP
═══════════════════════════════════════════ */
#view-factions{padding-top:56px;}
.factions-wrap{padding:36px 48px;}
.factions-hdr{text-align:center;margin-bottom:32px;}
.fh-title{font-family:var(--fb);font-size:clamp(36px,7vw,88px);letter-spacing:.06em;line-height:.86;margin-bottom:8px;}
.fh-sub{font-family:var(--fg);font-style:italic;font-size:clamp(13px,1.4vw,16px);color:rgba(240,236,228,.38);max-width:520px;margin:0 auto;line-height:2;}
/* faction cards grid */
.factions-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:4px;margin-bottom:28px;}
@media(max-width:900px){.factions-grid{grid-template-columns:1fr;}}
.faction-card{background:var(--panel);border:1px solid rgba(240,236,228,.06);padding:28px 26px;position:relative;overflow:hidden;cursor:pointer;transition:all .28s;}
.faction-card:hover{border-color:rgba(240,236,228,.18);transform:translateY(-2px);}
.faction-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
/* bg pattern */
.faction-card::after{content:'';position:absolute;inset:0;opacity:.04;background-image:repeating-linear-gradient(45deg,currentColor 0,currentColor 1px,transparent 1px,transparent 12px);}
.fc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;}
.fc-seal{font-size:36px;position:relative;z-index:1;}
.fc-strength{position:relative;z-index:1;text-align:right;}
.fcs-val{font-family:var(--fb);font-size:28px;letter-spacing:.04em;display:block;line-height:1;}
.fcs-lbl{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);}
.fc-name{font-family:var(--fb);font-size:clamp(24px,4vw,40px);letter-spacing:.06em;line-height:1;margin-bottom:4px;position:relative;z-index:1;}
.fc-motto{font-family:var(--fg);font-style:italic;font-size:14px;color:rgba(240,236,228,.45);margin-bottom:12px;position:relative;z-index:1;}
.fc-desc{font-family:var(--fg);font-size:12px;color:rgba(240,236,228,.4);line-height:1.7;margin-bottom:14px;position:relative;z-index:1;}
.fc-territory{position:relative;z-index:1;margin-bottom:10px;}
.fct-label{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
.fct-districts{display:flex;flex-wrap:wrap;gap:4px;}
.fctd{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:2px 7px;}
.fc-appears-in{position:relative;z-index:1;}
.fcai-label{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
.fcai-projects{display:flex;flex-wrap:wrap;gap:4px;}
.fcaip{font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;border:1px solid rgba(240,96,48,.2);padding:2px 7px;color:rgba(208,72,32,.7);}
.fc-join-btn{position:relative;z-index:1;display:inline-block;margin-top:12px;font-family:var(--fc);font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border:1px solid;padding:8px 20px;cursor:pointer;background:transparent;transition:all .22s;}
/* faction conflict map */
.faction-conflict{background:var(--panel);border:1px solid rgba(240,236,228,.06);padding:24px;margin-bottom:28px;}
.fc-conflict-title{font-family:var(--fc);font-size:20px;font-weight:800;letter-spacing:.07em;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.fc-conflict-title::before{content:'⚔';font-size:14px;}
.conflict-row{display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid rgba(240,236,228,.04);}
.conflict-row:last-child{border-bottom:none;}
.cr-fac-a,.cr-fac-b{font-family:var(--fm);font-size:8px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;min-width:100px;}
.cr-fac-b{text-align:right;}
.cr-bar-wrap{flex:1;display:flex;align-items:center;gap:0;}
.cr-bar-a,.cr-bar-b{height:8px;transition:width .8s ease;}
.cr-center{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding:0 8px;white-space:nowrap;}
</style>
</head>
