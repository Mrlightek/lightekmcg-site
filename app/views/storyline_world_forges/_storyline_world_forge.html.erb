      d.innerHTML=`
        <div style="position:absolute;top:0;left:0;right:0;height:3px;background:${f.color};"></div>
        <div class="fc-top"><div class="fc-seal">${f.seal}</div><div class="fc-strength"><span class="fcs-val" style="color:${f.color};">${f.strength}%</span><span class="fcs-lbl">POWER INDEX</span></div></div>
        <div class="fc-name" style="color:${f.color};">${f.name}</div>
        <div class="fc-motto">${f.motto}</div>
        <div class="fc-desc" style="color:rgba(240,236,228,.45);">${f.desc}</div>
        <div class="fc-territory"><div class="fct-label">CONTROLS</div><div class="fct-districts">${f.territory.map(t=>`<div class="fctd" style="border-color:${f.color}40;color:${f.color};">${t}</div>`).join('')}</div></div>
        <div class="fc-appears-in"><div class="fcai-label">FEATURED IN</div><div class="fcai-projects">${f.projects.map(p=>`<div class="fcaip">${p}</div>`).join('')}</div></div>
        <button class="fc-join-btn" style="border-color:${f.color};color:${f.color};" onclick="this.textContent='✓ ALIGNED';">${f.join} →</button>`;
      grid.appendChild(d);
    });
  }
  const cr=document.getElementById('conflict-rows');
  if(!cr.children.length){
    CONFLICTS.forEach(c=>{
      const d=document.createElement('div');
      d.className='conflict-row';
      d.innerHTML=`
        <div class="cr-fac-a" style="color:${c.aColor};">${c.a.split(' ').slice(-1)[0]}</div>
        <div class="cr-bar-wrap">
          <div class="cr-bar-a" style="width:${c.aPct/2}%;background:${c.aColor};opacity:.7;"></div>
          <div class="cr-center">${c.label}</div>
          <div class="cr-bar-b" style="width:${c.bPct/2}%;background:${c.bColor};opacity:.7;"></div>
        </div>
        <div class="cr-fac-b" style="color:${c.bColor};">${c.b.split(' ').slice(-1)[0]}</div>`;
      cr.appendChild(d);
    });
  }
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.04});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
  addHoverFX();
}

function addHoverFX(){
  document.querySelectorAll('button,.faction-card,.char-node,.map-pin,.tl-event,.bs-item,.bn-item,.at-row,.bstoc-item,.ms-location-card').forEach(el=>{
    if(!el._hb){
      el.addEventListener('mouseenter',()=>{cur.style.width='12px';cur.style.height='12px';cur2.style.width='40px';cur2.style.height='40px';});
      el.addEventListener('mouseleave',()=>{cur.style.width='8px';cur.style.height='8px';cur2.style.width='32px';cur2.style.height='32px';});
      el._hb=true;
    }
  });
}

// Init
renderMap();
</script>
</body>
</html>
