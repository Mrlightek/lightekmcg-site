function renderCharacters(){
  const canvas=document.getElementById('cn-canvas');
  const svg=document.getElementById('cn-svg');
  if(canvas.children.length>0)return;
  const w=canvas.parentElement.clientWidth||900;
  const h=canvas.parentElement.clientHeight||560;
  svg.setAttribute('viewBox',`0 0 ${w} ${h}`);
  // Draw connections
  const nodePos={};
  CHARACTERS.forEach(c=>{nodePos[c.id]={x:c.x/100*w,y:c.y/100*h};});
  CHAR_CONNECTIONS.forEach(conn=>{
    const a=nodePos[conn.a],b=nodePos[conn.b];
    if(!a||!b)return;
    const line=document.createElementNS('http://www.w3.org/2000/svg','line');
    line.setAttribute('x1',a.x);line.setAttribute('y1',a.y);
    line.setAttribute('x2',b.x);line.setAttribute('y2',b.y);
    const typeColors={adversary:'rgba(204,40,48,.3)',ally:'rgba(40,192,136,.3)',employer:'rgba(40,160,240,.3)',surveillance:'rgba(152,32,200,.25)',source:'rgba(200,144,12,.25)',editor:'rgba(200,96,16,.25)',unknown:'rgba(240,236,228,.08)'};
    line.setAttribute('stroke',typeColors[conn.type]||'rgba(240,236,228,.1)');
    line.setAttribute('stroke-width',conn.strength+1);
    svg.appendChild(line);
  });
  // Draw nodes
  CHARACTERS.forEach(c=>{
    const d=document.createElement('div');
    d.className='char-node';
    d.id='node-'+c.id;
    d.style.left=c.x+'%';d.style.top=c.y+'%';
    d.onclick=()=>selectChar(c);
    d.innerHTML=`<div class="chn-ring" style="width:${c.size}px;height:${c.size}px;border-color:${c.color};color:${c.color};">${c.icon}<div style="position:absolute;inset:-6px;border-radius:50%;border:1px solid ${c.color};opacity:.25;"></div></div><div class="chn-name" style="color:${c.color};">${c.name.split(' ').join('\n')}</div><div class="chn-role">${c.role.split(' ').slice(0,2).join(' ')}</div>`;
    canvas.appendChild(d);
  });
  // Default select first char
  selectChar(CHARACTERS[0]);
  addHoverFX();
}

function selectChar(c){
  document.querySelectorAll('.char-node').forEach(n=>n.classList.remove('selected'));
  const node=document.getElementById('node-'+c.id);
  if(node)node.classList.add('selected');
  const sb=document.getElementById('char-sidebar');
  sb.innerHTML=`<div class="char-card">
    <div class="cc-header">
      <div class="cch-avatar" style="border-color:${c.color};background:${c.color}20;">${c.icon}</div>
      <div class="cch-info">
        <div class="cchi-name" style="color:${c.color};">${c.name}</div>
        <div class="cchi-role" style="color:${c.factionColor};">${c.role}</div>
        <div class="cchi-faction" style="border-color:${c.factionColor}40;color:${c.factionColor};">${c.faction}</div>
      </div>
    </div>
    <div class="cc-desc">${c.desc}</div>
    <div class="cc-appearances">
      <div class="cca-label">APPEARS IN</div>
      ${c.projects.map(p=>`<div class="cca-item"><div class="ccai-project">${p.split('(')[0].trim()}</div><div class="ccai-eps">${p.includes('(')?p.match(/\(([^)]+)\)/)[1]:''}</div></div>`).join('')}
    </div>
    <div class="cc-rels">
      <div class="ccr-label">RELATIONSHIPS</div>
      ${c.rels.map(r=>`<div class="ccr-item"><div class="ccri-avatar" style="border-color:rgba(240,236,228,.15);">${r.icon}</div><div class="ccri-name">${r.name}</div><div class="ccri-rel">${r.rel}</div></div>`).join('')}
    </div>
  </div>`;
}

function filterChars(btn,filter){
  document.querySelectorAll('.cf-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  // Filter logic would fade nodes — simplified here
  document.querySelectorAll('.char-node').forEach(n=>{n.style.opacity=filter==='all'?'1':'0.3';});
  if(filter==='all')return;
  CHARACTERS.forEach(c=>{
    if(c.projects.some(p=>p.toLowerCase().includes(filter))){
      const node=document.getElementById('node-'+c.id);
      if(node)node.style.opacity='1';
    }
  });
}

function renderTimeline(){
  // Filters
  const tf=document.getElementById('tl-filters');
  if(!tf.children.length){
    const allBtn=document.createElement('button');
    allBtn.className='tlf-pill on';allBtn.textContent='ALL PROJECTS';
    allBtn.onclick=()=>{document.querySelectorAll('.tlf-pill').forEach(b=>b.classList.remove('on'));allBtn.classList.add('on');};
    tf.appendChild(allBtn);
    TIMELINE_PROJECTS.forEach(p=>{
      const b=document.createElement('button');
      b.className='tlf-pill';b.textContent=p.name;
      b.style.setProperty('--pc',p.color);
      b.onclick=()=>{document.querySelectorAll('.tlf-pill').forEach(x=>x.classList.remove('on'));b.classList.add('on');};
      tf.appendChild(b);
    });
  }
  // Timeline rows
  const rows=document.getElementById('tl-rows');
  if(!rows.children.length){
    TIMELINE_PROJECTS.forEach(proj=>{
      const row=document.createElement('div');
      row.className='tl-row';
      row.innerHTML=`<div class="tlr-label"><div class="tlrl-name" style="color:${proj.color};">${proj.name}</div><div class="tlrl-format">${proj.format}</div></div><div class="tlr-track" id="track-${proj.id}"></div>`;
      rows.appendChild(row);
    });
    // Add crossover markers
    const firstTrack=document.querySelector('.tlr-track');
    if(firstTrack){
      CROSSOVER_MARKERS.forEach(m=>{
        const marker=document.createElement('div');
        marker.className='tl-crossover-marker';
        marker.style.left=m.pct+'%';
        marker.innerHTML=`<div class="tl-crossover-label">${m.label}</div>`;
        firstTrack.style.position='relative';
        firstTrack.parentElement.appendChild(marker);
      });
    }
    // Add events
    TIMELINE_EVENTS.forEach(ev=>{
      const track=document.getElementById('track-'+ev.project);
      if(!track)return;
      const d=document.createElement('div');
      d.className='tl-event';
      d.style.left=ev.pct+'%';
      const proj=TIMELINE_PROJECTS.find(p=>p.id===ev.project);
      const isCrossover=ev.type==='CROSSOVER';
      d.innerHTML=`<div class="tle-dot" style="border-color:${isCrossover?'var(--gold)':proj.color};${isCrossover?'background:rgba(200,144,12,.15)':''}"></div><div class="tle-tooltip"><div class="tlet-project" style="color:${proj.color};">${proj.name}</div><div class="tlet-title">${ev.title}</div><div class="tlet-type" style="${isCrossover?'color:var(--gold2);':''}">${ev.type}</div></div>`;
      track.appendChild(d);
    });
  }
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.04});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
  addHoverFX();
}

