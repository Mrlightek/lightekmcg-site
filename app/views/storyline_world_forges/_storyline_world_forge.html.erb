function renderMap(){
  // Pins
  const container=document.querySelector('.map-canvas');
  if(!document.getElementById('map-pins').children.length){
    MAP_PINS.forEach(p=>{
      const d=document.createElement('div');
      d.className='map-pin';
      d.style.left=p.x+'%';d.style.top=p.y+'%';
      d.onclick=()=>selectLocation(p);
      d.innerHTML=`<div class="mp-dot" style="background:${p.color}20;border-color:${p.color};"></div><div class="mp-stem" style="background:linear-gradient(to bottom,${p.color},transparent);"></div><div class="mp-label" style="color:${p.color};">${p.label}</div>`;
      document.getElementById('map-pins').appendChild(d);
    });
  }
  // Layers
  const ml=document.getElementById('map-layers');
  if(!ml.children.length){
    LAYERS.forEach(l=>{
      const d=document.createElement('div');
      d.className='ml-item'+(l.on?' on':'');
      d.onclick=()=>d.classList.toggle('on');
      d.innerHTML=`<div class="ml-dot" style="background:${l.color};"></div><div class="ml-label">${l.label}</div>`;
      ml.appendChild(d);
    });
  }
  // Location list
  const ll=document.getElementById('location-list');
  if(!ll.children.length){
    LOCATIONS.forEach(l=>{
      const d=document.createElement('div');
      d.className='ms-location-card';
      d.innerHTML=`
        <div class="mslc-header" onclick="this.nextElementSibling.style.display='flex'">
          <div class="mslch-top">
            <div class="mslcht-name" style="color:${l.color};">${l.label}</div>
            <div class="mslcht-type" style="border-color:${l.color}40;color:${l.color};">${l.type}</div>
          </div>
          <div class="mslch-desc">${l.desc}</div>
        </div>
        <div class="mslc-stories" style="display:none;">${l.stories.map(s=>`<div class="mslcs-tag">${s}</div>`).join('')}</div>`;
      ll.appendChild(d);
    });
  }
  addHoverFX();
}

