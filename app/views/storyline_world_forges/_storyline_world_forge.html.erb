<script>
// ── CURSOR ──────────────────────────────────
const cur=document.getElementById('cur'),cur2=document.getElementById('cur2');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function l(){rx+=(mx-rx)*.11;ry+=(my-ry)*.11;cur2.style.left=rx+'px';cur2.style.top=ry+'px';requestAnimationFrame(l);})();

// ── VIEW SWITCH ──────────────────────────────
function sw(id,btn){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+id).classList.add('active');
  document.querySelectorAll('.tn-tab').forEach(t=>t.classList.remove('on'));
  if(btn)btn.classList.add('on');
  window.scrollTo(0,0);
  if(id==='map')renderMap();
  if(id==='bible')renderBible();
  if(id==='characters')renderCharacters();
  if(id==='timeline')renderTimeline();
  if(id==='factions')renderFactions();
}

// ── DATA ─────────────────────────────────────
const MAP_PINS=[
  {label:'COLDWATER DOCKS',type:'DISTRICT',desc:'The oldest part of the city. Where the Holloway family made their first money and their first enemies.',x:14,y:68,color:'#4878D0',stories:['DYNASTY PROTOCOLS EP.1','COLDWATER ARCHIVES EP.1-6']},
  {label:'THE HEIGHTS',type:'DISTRICT',desc:'New money. Old grudges. The glass tower district where the second Holloway generation tried to go legitimate.',x:48,y:20,color:'#28A0F0',stories:['THE HEIGHTS EP.1-14','DYNASTY PROTOCOLS EP.7']},
  {label:'MERIDIAN QUARTER',type:'DISTRICT',desc:'The tech corridor. Where Devon Ross\'s signal was broadcast from, and where no one is quite who they say they are.',x:67,y:52,color:'#20C0A0',stories:['MERIDIAN SIGNAL EP.1-10','COLD DISPATCH VOL.I']},
  {label:'OLD QUARTER',type:'DISTRICT',desc:'The Holloway dynasty\'s original territory. Every family secret begins and ends here.',x:33,y:42,color:'#D06020',stories:['DYNASTY PROTOCOLS EP.1-4','NEON GOSPEL EP.2']},
  {label:'RUST BELT',type:'DISTRICT',desc:'Where things go to die — or to hide. Devon Ross\'s lab was here. So was Marcus before the Holloway name found him.',x:14,y:38,color:'#CC4010',stories:['RUST & RUIN EP.1-6','MERIDIAN SIGNAL EP.3']},
  {label:'THE IRON GATE',type:'LANDMARK',desc:'The original Holloway compound. Burned down in Year 2. Or did it? Three projects tell three different stories.',x:28,y:58,color:'#E03050',stories:['DYNASTY PROTOCOLS EP.2,7,11']},
  {label:'COLDWATER STATION',type:'LANDMARK',desc:'The crossover point. This is where the Dynasty and Coldwater timelines physically intersect in Year 3.',x:22,y:52,color:'#C8980C',stories:['CROSSOVER: COLDWATER NIGHT']},
];
const BIBLE_ENTRIES=[
  {id:'ironbell',cat:'WORLD OVERVIEW',title:'IRONBELL CITY',canon:true,summary:'A fictional American metropolis spanning four generations of wealth, crime, faith, and technology. Home to eight active narrative universes. Every story that takes place here eventually touches every other story.',sections:[
    {title:'Geography & Districts',text:'Ironbell City is divided into five primary districts: the Coldwater Docks (oldest, working class, criminal history), The Heights (new money, corporate, glass towers), Meridian Quarter (tech corridor, surveillance, signals), Old Quarter (Holloway territory, political corruption, legacy crime), and the Rust Belt (abandoned industrial, secrets, laboratories).'},
    {title:'The Holloway Family',text:'The Holloway family built Ironbell City — or at least, they built the version of it that everyone talks about. <em>Three generations</em> of power, each with its own origin story that contradicts the previous one. <strong>Marcus Holloway</strong> is the current heir. Whether he wants the inheritance is the central question of The Dynasty Protocols.'},
    {title:'The Coldwater Connection',text:'The Coldwater Docks were named for a company that no longer exists. What the company did — and why it stopped — is the central mystery of The Coldwater Archives, and a secret that crossover listeners of both series are the only ones who can fully reconstruct.'},
  ],disputed:{label:'DISPUTED CANON',text:'Whether the Iron Gate actually burned in Year 2 is disputed across three projects. The Dynasty Protocols says yes. Neon Gospel says no. The Coldwater Archives refuses to say. The community is currently 54% / 46% split.'}},
  {id:'signal',cat:'TECHNOLOGY',title:'THE MERIDIAN SIGNAL',canon:true,summary:'An unauthorized broadcast that has been running on an unlicensed frequency for three years. Nobody knows who is sending it. It contains information that should not exist. Every project in the Meridian universe is, in some way, about this signal.',sections:[
    {title:'What It Broadcasts',text:'The Signal transmits fragments of <strong>documented conversations</strong> that appear to have been recorded in private locations, at private moments, years before the recording technology required to capture them existed. The Signal does not explain this. It simply broadcasts.'},
    {title:'Who Is Listening',text:'By Year 3, an estimated 40% of Ironbell City residents have heard the Signal. Most dismiss it as interference. A small number — including Devon Ross and a journalist named Lena Park — have been actively trying to trace it for years.'},
  ]},
];
const BIBLE_NAV=[
  {icon:'🌍',label:'World Overview',count:1},{icon:'🏙',label:'Districts & Locations',count:8},
  {icon:'👥',label:'Characters',count:24},{icon:'⚔',label:'Factions',count:4},
  {icon:'📅',label:'Timeline',count:47},{icon:'🔮',label:'Technology & Systems',count:6},
  {icon:'📜',label:'Laws & Politics',count:9},{icon:'💰',label:'Economy & Crime',count:11},
  {icon:'⬡',label:'Disputed Canon',count:8},{icon:'◆',label:'Crossover Events',count:3},
];
