}

function renderUniverse(){
  const container=document.getElementById('umap-nodes');
  const svg=document.getElementById('umap-svg');
  if(!container||!svg)return;
  if(container.children.length>0)return;

  // Draw connection lines
  const cW=container.parentElement.clientWidth||900;
  const cH=500;
  svg.setAttribute('viewBox',`0 0 ${cW} ${cH}`);

  const nodePos={};
  UNIVERSE_NODES.forEach(n=>{nodePos[n.id]={x:n.x/100*cW,y:n.y/100*cH};});

  UNIVERSE_CONNECTIONS.forEach(c=>{
    const a=nodePos[c.a],b=nodePos[c.b];
    if(!a||!b)return;
    const line=document.createElementNS('http://www.w3.org/2000/svg','line');
    line.setAttribute('x1',a.x);line.setAttribute('y1',a.y);
    line.setAttribute('x2',b.x);line.setAttribute('y2',b.y);
    line.setAttribute('stroke',`rgba(212,160,32,${c.strength*.1+.06})`);
    line.setAttribute('stroke-width',c.strength);
    line.setAttribute('stroke-dasharray','4 6');
    svg.appendChild(line);
  });

  // Render nodes
  UNIVERSE_NODES.forEach(n=>{
    const d=document.createElement('div');
    d.className='umap-node';
    d.style.left=(n.x)+'%';
    d.style.top=(n.y)+'%';
    d.style.transform='translate(-50%,-50%)';
    d.onclick=()=>switchView('project');
    d.innerHTML=`
      <div class="umn-circle" style="width:${n.size}px;height:${n.size}px;background:radial-gradient(circle,${n.color}40,${n.color}15);border-color:${n.color}50;">
        <div style="font-size:${n.size*.35}px;">${n.icon}</div>
        <div style="position:absolute;inset:-8px;border-radius:50%;border:1px solid ${n.color};opacity:.2;"></div>
      </div>
      <div class="umn-label" style="color:${n.color};">${n.label.replace('\n','<br>')}</div>
      <div class="umn-format">${n.format}</div>`;
    container.appendChild(d);
  });

  // Crossover nodes
  UNIVERSE_CROSSOVER_NODES.forEach(n=>{
    const d=document.createElement('div');
    d.className='umap-crossover';
    d.style.left=n.x+'%';d.style.top=n.y+'%';
    d.innerHTML=`<div class="umc-diamond"></div><div class="umc-label">${n.label.replace('\n','<br>')}</div>`;
    container.appendChild(d);
  });

  // crossover cards
  const cc=document.getElementById('co-cards');
  if(cc&&!cc.children.length){
    CROSSOVERS.forEach(c=>{
      const d=document.createElement('div');
      d.className='co-card';
      d.innerHTML=`
        <div class="coc-label">◆ ACTIVE CROSSOVER</div>
        <div class="coc-title">${c.title}</div>
        <div class="coc-projects">${c.projects.map(p=>`<div class="cocp">${p}</div>`).join('')}</div>
        <div class="coc-desc">${c.desc}</div>
        <div class="coc-unlock" style="margin-top:6px;">🔑 ${c.unlock}</div>`;
      cc.appendChild(d);
    });
  }
  addHoverListeners();
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.04});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
}

function renderStudio(){
  // project cards
  const sp=document.getElementById('studio-projects');
  if(sp&&!sp.children.length){
    STUDIO_PROJ.forEach(p=>{
      const d=document.createElement('div');
      d.className='sp-card';
      d.innerHTML=`
        <div style="position:absolute;top:0;left:0;right:0;height:3px;background:${p.color};"></div>
        <div class="spc-header">
          <div class="spch-icon">${p.icon}</div>
          <div class="spch-format" style="border-color:${p.color}40;color:${p.color};">${p.format}</div>
        </div>
        <div class="spc-name" style="color:${p.color};">${p.name}</div>
        <div class="spc-status">
          <div class="spc-status-dot" style="background:${p.status==='LIVE'?'#28C070':p.color};${p.status==='LIVE'?'animation:blink .9s infinite':''}"></div>
          <span style="font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:${p.status==='LIVE'?'#28C070':p.color};">${p.status}</span>
        </div>
        <div class="spc-metrics">
          <div class="spcm-item"><span class="spcmi-val" style="color:${p.color};">${p.listeners}</span><span class="spcmi-lbl">LISTENERS</span></div>
          <div class="spcm-item"><span class="spcmi-val" style="color:${p.color};">${p.eps}</span><span class="spcmi-lbl">EPISODES</span></div>
          <div class="spcm-item"><span class="spcmi-val" style="color:${p.color};">${p.branches}</span><span class="spcmi-lbl">BRANCH PTS</span></div>
          <div class="spcm-item"><span class="spcmi-val" style="color:${p.color};">${p.endings}</span><span class="spcmi-lbl">ENDINGS</span></div>
        </div>`;
      sp.appendChild(d);
    });
    // new project button
    const newCard=document.createElement('div');
    newCard.innerHTML=`<div class="sp-card" style="display:flex;align-items:center;justify-content:center;flex-direction:column;gap:10px;min-height:180px;border-style:dashed;border-color:rgba(242,238,232,.1);" onclick="this.style.opacity='.5'">
      <div style="font-size:28px;opacity:.3;">＋</div>
      <div style="font-family:var(--fc);font-size:16px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(242,238,232,.3);">NEW PROJECT</div>
      <div style="font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(242,238,232,.2);">Album · Book · Magazine</div>
    </div>`;
    sp.appendChild(newCard.firstElementChild);
  }
  // path distribution
  const pd=document.getElementById('path-dist');
  if(pd&&!pd.children.length){
    PATH_STATS_DATA.forEach(p=>{
      const d=document.createElement('div');
      d.className='pd-item';
      d.innerHTML=`
        <div class="pdi-label">${p.label}</div>
        <div class="pdi-bar"><div class="pdi-fill" style="width:${p.pct}%;background:${p.color};"></div></div>
        <div class="pdi-pct" style="color:${p.color};">${p.pct}%</div>`;
      pd.appendChild(d);
    });
  }
  addHoverListeners();
}

function initBranch(){
  // waveform
  const wf=document.getElementById('waveform');
  if(wf&&wf.querySelectorAll('.bpp-wave-bar').length<2){
    for(let i=0;i<80;i++){
      const b=document.createElement('div');
      b.className='bpp-wave-bar';
      const h=Math.max(15,Math.random()*100);
      const isPlayed=i<31;
      b.style.height=h+'%';
      b.style.background=isPlayed?`rgba(224,48,80,${.5+Math.random()*.5})`:`rgba(242,238,232,${.08+Math.random()*.1})`;
      b.style.minHeight='4px';
      wf.insertBefore(b,document.getElementById('playhead'));
    }
  }
  // path tree
  const pt=document.getElementById('path-tree');
  if(pt&&!pt.children.length){
    PATH_TREE_DATA.forEach(n=>{
      const d=document.createElement('div');
      d.className='pt-node';
      d.innerHTML=`
        <div class="ptn-dot" style="border-color:${n.color};background:${n.done?n.color:'transparent'};"></div>
        <div class="ptn-content">
          <div class="ptnc-ep">${n.ep}</div>
          <div class="ptnc-choice" style="color:${n.done?'rgba(242,238,232,.65)':n.color};">${n.choice}</div>
        </div>`;
      pt.appendChild(d);
    });
  }
  // path stats
  const ps=document.getElementById('path-stats');
  if(ps&&!ps.children.length){
    PATH_STATS_DATA.forEach(p=>{
      const d=document.createElement('div');
      d.innerHTML=`
        <div class="path-stat"><div class="ps-label">${p.label}</div><div class="ps-val" style="color:${p.color};">${p.pct}%</div></div>
        <div class="ps-bar"><div class="ps-bar-fill" style="width:${p.pct}%;background:${p.color};"></div></div>`;
      ps.appendChild(d);
    });
  }
  // timer
  startTimer();
  addHoverListeners();
}

// ── BRANCH TIMER ────────────────────────────
let timerVal=45,timerInt=null;
function startTimer(){
  clearInterval(timerInt);
  timerVal=45;
  const fill=document.getElementById('timer-fill');
  const val=document.getElementById('timer-val');
  timerInt=setInterval(()=>{
    timerVal--;
    const pct=timerVal/45*100;
    if(fill)fill.style.width=pct+'%';
    if(fill)fill.style.background=pct>40?'var(--album-a)':pct>20?'var(--gold)':'var(--red2)';
    if(val)val.textContent='0:'+String(timerVal).padStart(2,'0');
    if(timerVal<=0){clearInterval(timerInt);autoChoose();}
  },1000);
}
function autoChoose(){makeChoice(document.getElementById('choice-C'),'C');}

function makeChoice(btn,letter){
  clearInterval(timerInt);
  document.querySelectorAll('.choice-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
  const fill=document.getElementById('timer-fill');
  if(fill){fill.style.width='100%';fill.style.background='var(--green)';}
  const tv=document.getElementById('timer-val');
  if(tv)tv.textContent='CHOSEN: '+letter;
  // update path tree
  const nodes=document.querySelectorAll('.pt-node');
  if(nodes.length>0){
    const last=nodes[nodes.length-1];
    const choice=last.querySelector('.ptnc-choice');
    if(choice){choice.textContent=`Chose: Path ${letter}`;choice.style.color='rgba(242,238,232,.65)';}
    const dot=last.querySelector('.ptn-dot');
    if(dot){dot.style.background='var(--album-a)';}
  }
}

// ── PLAYER CONTROLS ──────────────────────────
let playing=false,speed=1,seekPos=38;
const SPEEDS=[1.0,1.25,1.5,1.75,2.0];let speedI=0;
function togglePlay(btn){
  playing=!playing;
  btn.textContent=playing?'⏸':'▶';
  if(playing){cur.style.background='var(--green)';setTimeout(()=>{cur.style.background='var(--accent)';},500);}
}
function cycleSpeed(btn){speedI=(speedI+1)%SPEEDS.length;btn.textContent=SPEEDS[speedI]+'×';}
function seekProgress(e,bar){
  const pct=e.offsetX/bar.offsetWidth*100;
  seekPos=pct;
  document.getElementById('progress-fill').style.width=pct+'%';
  document.getElementById('progress-dot').style.left=pct+'%';
}
function seekWave(e,el){
  const pct=e.offsetX/el.offsetWidth;
  const bars=el.querySelectorAll('.bpp-wave-bar');
  const played=Math.floor(pct*bars.length);
  bars.forEach((b,i)=>{b.style.background=i<played?`rgba(224,48,80,${.5+Math.random()*.5})`:`rgba(242,238,232,${.08+Math.random()*.1})`;});
  document.getElementById('playhead').style.left=(pct*100)+'%';
}

// ── UTILS ────────────────────────────────────
function addHoverListeners(){
  document.querySelectorAll('button,.card-album,.card-book,.card-mag,.choice-btn,.sp-card,.co-card,.bstoc-item,.umap-node,.co-new-btn').forEach(el=>{
    if(!el._hoverBound){
      el.addEventListener('mouseenter',bigCursor);
      el.addEventListener('mouseleave',normCursor);
      el._hoverBound=true;
    }
  });
}
function initScrollReveal(){
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.04});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
}

// ── INIT ────────────────────────────────────
renderDiscover();
renderTracklist();
renderTOC();
initScrollReveal();
</script>
</body>
</html>
