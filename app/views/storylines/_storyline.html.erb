  const tl=document.getElementById('toc-list');
  if(!tl||tl.children.length)return;
  TOC.forEach(t=>{
    const d=document.createElement('div');
    d.className='bstoc-item';
    d.onclick=()=>switchView('branch');
    d.innerHTML=`
      <div class="bsti-num">${t.num}</div>
      <div class="bsti-title" style="font-style:italic;">${t.title}</div>
