function renderDiscover(){
  // albums
  const ar=document.getElementById('albums-row');
  if(ar&&!ar.children.length){
    ALBUM_PROJECTS.forEach(p=>{
      const d=document.createElement('div');
      d.className='card-album';
      d.onclick=()=>switchView('project');
      d.innerHTML=`
        <div class="ca-art">
          <div class="ca-art-inner" style="background:${p.bg};"></div>
          <div class="ca-art-overlay"></div>
          <div class="ca-format-tag" style="border-color:${p.color}40;color:${p.color};">💿 ALBUM</div>
          ${p.crossovers>0?`<div class="ca-crossover">◆ ${p.crossovers} XOVER</div>`:''}
          <div class="ca-play-icon">▶</div>
        </div>
        <div class="ca-title" style="color:${p.color};">${p.title}</div>
        <div class="ca-creator">${p.creator}</div>
        <div class="ca-meta">
          <div class="ca-eps">${p.eps} EPISODES</div>
          <div class="ca-branch">⬡ ${p.branches} BRANCHES</div>
        </div>`;
      ar.appendChild(d);
    });
  }
  // books
  const br=document.getElementById('books-row');
  if(br&&!br.children.length){
    BOOK_PROJECTS.forEach(p=>{
      const d=document.createElement('div');
      d.className='card-book';
      d.onclick=()=>switchView('project');
      d.innerHTML=`
        <div class="cb-spine-wrap">
          <div class="cb-spine" style="background:${p.color}40;"><div class="cb-spine-text" style="color:${p.color};">${p.title.slice(0,16)}</div></div>
          <div class="cb-cover" style="background:${p.bg};">
            <div class="cb-vol">${p.vol}</div>
            <div class="cb-title" style="color:rgba(242,238,232,.92);">${p.title}</div>
            <div class="cb-author">${p.author}</div>
          </div>
        </div>
        <div class="cb-meta"><div class="cb-genre">${p.genre}</div></div>`;
      br.appendChild(d);
    });
  }
  // mags
  const mr=document.getElementById('mags-row');
  if(mr&&!mr.children.length){
    MAG_PROJECTS.forEach(p=>{
      const d=document.createElement('div');
      d.className='card-mag';
      d.onclick=()=>switchView('project');
      d.innerHTML=`
        <div class="cm-cover" style="background:${p.bg};">
          <div class="cm-masthead">
            <div class="cmm-title" style="color:${p.color};">${p.title}</div>
            <div class="cmm-issue">${p.issue}</div>
          </div>
          <div class="cm-headline">
            <div class="cmh-kicker" style="color:${p.color};">${p.kicker}</div>
            <div class="cmh-text">${p.headline}</div>
          </div>
        </div>
        <div class="cm-meta"><div class="cm-meta-row"><div class="cmm-label" style="color:${p.color};">📰 MAGAZINE</div><div class="cmm-label">⬡ BRANCHES</div></div></div>`;
      mr.appendChild(d);
    });
  }
  // crossover previews
  const cp=document.getElementById('crossovers-preview');
  if(cp&&!cp.children.length){
    CROSSOVERS.forEach(c=>{
      const d=document.createElement('div');
      d.className='co-card';
      d.onclick=()=>switchView('universe');
      d.innerHTML=`
        <div class="coc-label">◆ UNIVERSE CROSSOVER · LIVE</div>
        <div class="coc-title">${c.title}</div>
        <div class="coc-projects">${c.projects.map(p=>`<div class="cocp">${p}</div>`).join('')}</div>
        <div class="coc-desc">${c.desc}</div>
        <div class="coc-unlock">🔑 UNLOCK: ${c.unlock}</div>`;
      cp.appendChild(d);
    });
  }
  addHoverListeners();
  // scroll reveal
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.04});
  document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
}

function renderTracklist(){
  const tl=document.getElementById('tracklist');
  if(!tl||tl.children.length)return;
  TRACKS.forEach(t=>{
    const d=document.createElement('div');
    d.className='as-track'+(t.playing?' playing':'');
    d.onclick=()=>switchView('branch');
    const bars=t.playing?`<div class="at-waveform">${[1,2,3,4,5].map(()=>`<div class="at-bar" style="height:${40+Math.random()*60}%;background:var(--album-a);animation-delay:${Math.random()*.8}s;animation-duration:${.6+Math.random()*.6}s;"></div>`).join('')}</div>`:'';
    d.innerHTML=`
      <div class="at-num">${t.num}</div>
      <div class="at-info">
        <div class="at-title">${t.title}</div>
        <div class="at-subtitle">${t.sub}</div>
      </div>
      <div>${t.branch?`<div class="at-branch">⬡ BRANCH</div>`:''}</div>
      <div class="at-dur">${t.dur}</div>
      <div>${bars}</div>`;
    tl.appendChild(d);
  });
}

