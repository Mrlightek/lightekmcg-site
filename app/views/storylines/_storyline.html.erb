const cur=document.getElementById('cur'),cur2=document.getElementById('cur2');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function l(){rx+=(mx-rx)*.11;ry+=(my-ry)*.11;cur2.style.left=rx+'px';cur2.style.top=ry+'px';requestAnimationFrame(l);})();
function bigCursor(){cur.style.width='12px';cur.style.height='12px';cur2.style.width='44px';cur2.style.height='44px';}
function normCursor(){cur.style.width='8px';cur.style.height='8px';cur2.style.width='32px';cur2.style.height='32px';}
document.querySelectorAll('button,.card-album,.card-book,.card-mag,.choice-btn,.cat-card').forEach(el=>{
  el.addEventListener('mouseenter',bigCursor);
  el.addEventListener('mouseleave',normCursor);
});

// ── VIEW & TAB MANAGER ──────────────────────
function switchView(id){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+id)?.classList.add('active');
  window.scrollTo(0,0);
  if(id==='discover')renderDiscover();
  if(id==='universe')renderUniverse();
  if(id==='studio')renderStudio();
  if(id==='branch')initBranch();
}
function switchTab(btn,id){
  document.querySelectorAll('.gn-tab').forEach(t=>t.classList.remove('on'));
  btn.classList.add('on');
  switchView(id);
}

// ── FORMAT SKIN SWITCHER ────────────────────
function switchSkin(skin,btn){
  document.querySelectorAll('.fs-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.skin-panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('skin-'+skin)?.classList.add('active');
}

