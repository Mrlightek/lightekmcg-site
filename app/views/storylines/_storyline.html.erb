<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>STORYLINE — The Narrative Universe Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Barlow+Condensed:wght@200;300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;cursor:none;}
:root{
  --void:#040308;--deep:#070510;--mid:#0C0818;--panel:#100C1E;--lift:#161228;
  --white:#F2EEE8;--off:#C8C0B8;--muted:#6A6070;--dim:#1C1628;
  --gold:#D4A020;--gold2:#ECC030;
  /* format colors */
  --album-a:#E03050;--album-b:#FF5070;
  --book-a:#2858A8;--book-b:#4878D0;
  --mag-a:#C84010;--mag-b:#F06030;
  /* project accent vars (overridden per project) */
  --accent:#E03050;--accent2:#FF5070;--accent3:#FF8090;
  --bg-glow:rgba(224,48,80,.12);
  /* fonts */
  --fb:'Bebas Neue',sans-serif;
  --fg:'EB Garamond',serif;
  --fc:'Barlow Condensed',sans-serif;
  --fp:'Playfair Display',serif;
  --fm:'Space Mono',monospace;
}
html{scroll-behavior:smooth;}
body{background:var(--void);color:var(--white);font-family:var(--fg);overflow-x:hidden;}

/* grain */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");background-size:200px;pointer-events:none;z-index:0;opacity:.7;}

/* cursor */
#cur{width:8px;height:8px;background:var(--accent);position:fixed;z-index:9999;pointer-events:none;transform:translate(-50%,-50%);border-radius:50%;box-shadow:0 0 16px var(--accent);transition:width .15s,height .15s,background .3s,box-shadow .3s;}
#cur2{width:32px;height:32px;border:1px solid rgba(242,238,232,.15);border-radius:50%;position:fixed;z-index:9998;pointer-events:none;transform:translate(-50%,-50%);transition:left .1s cubic-bezier(.16,1,.3,1),top .1s,width .2s,height .2s;}

@keyframes shimmer{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes breathe{0%,100%{opacity:.7;transform:scale(1)}50%{opacity:1;transform:scale(1.015)}}
@keyframes branchPulse{0%{box-shadow:0 0 0 0 var(--accent)}70%{box-shadow:0 0 0 12px transparent}100%{box-shadow:0 0 0 0 transparent}}
@keyframes scanLine{from{top:-5%}to{top:105%}}
@keyframes waveBar{0%,100%{transform:scaleY(.3)}50%{transform:scaleY(1)}}
@keyframes slideIn{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:none}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
.fade-up{opacity:0;transform:translateY(20px);transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1);}
.fade-up.vis{opacity:1;transform:none;}

/* VIEWS */
.view{display:none;}
.view.active{display:block;}

/* ════════════════════════════════════════════
   GLOBAL NAV
════════════════════════════════════════════ */
.global-nav{
  position:fixed;top:0;left:0;right:0;z-index:400;
  height:58px;
  background:rgba(4,3,8,.96);
  border-bottom:1px solid rgba(242,238,232,.05);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 32px;
}
.gn-logo{font-family:var(--fb);font-size:22px;letter-spacing:.14em;cursor:pointer;background:linear-gradient(to right,var(--white),var(--off));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.gn-logo span{background:linear-gradient(to right,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.gn-tabs{display:flex;gap:0;}
.gn-tab{font-family:var(--fm);font-size:7px;letter-spacing:.18em;text-transform:uppercase;color:rgba(242,238,232,.32);padding:0 18px;height:58px;display:flex;align-items:center;border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;}
.gn-tab:hover{color:rgba(242,238,232,.7);}
.gn-tab.on{color:var(--white);border-bottom-color:var(--accent);}
.gn-right{display:flex;align-items:center;gap:10px;}
.gn-search{background:rgba(242,238,232,.06);border:1px solid rgba(242,238,232,.08);padding:7px 14px;font-family:var(--fm);font-size:7px;letter-spacing:.1em;color:rgba(242,238,232,.4);width:180px;outline:none;transition:all .2s;}
.gn-search:focus{border-color:rgba(242,238,232,.2);background:rgba(242,238,232,.09);}
.gn-search::placeholder{color:rgba(242,238,232,.22);}
.gn-create-btn{font-family:var(--fc);font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:var(--accent);color:var(--void);border:none;padding:8px 20px;cursor:pointer;transition:background .2s;}
.gn-create-btn:hover{background:var(--accent2);}
.gn-avatar{width:30px;height:30px;border-radius:50%;border:1.5px solid var(--accent);background:var(--panel);display:flex;align-items:center;justify-content:center;font-size:13px;cursor:pointer;}

/* ════════════════════════════════════════════
   VIEW 1: DISCOVERY FEED
════════════════════════════════════════════ */
#view-discover{padding-top:58px;}

/* hero — featured universe */
.discover-hero{
  min-height:88vh;
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:60px 48px;
  position:relative;overflow:hidden;
}
/* animated cover art bleed */
.dh-bg{
  position:absolute;inset:0;
  background:linear-gradient(135deg,#1A0808 0%,#2A0518 30%,#08082A 70%,#0A1A08 100%);
  z-index:0;
}
.dh-cover-art{
  position:absolute;right:0;top:0;bottom:0;
  width:55%;
  background:linear-gradient(135deg,#E03050,#8820C0,#0040E0);
  z-index:1;
  clip-path:polygon(15% 0,100% 0,100% 100%,0% 100%);
  opacity:.45;
  animation:breathe 8s ease-in-out infinite;
}
.dh-cover-art::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 60% 40%,rgba(255,80,120,.3),transparent 60%);}
.dh-vignette{position:absolute;inset:0;background:radial-gradient(ellipse 120% 100% at 30% 100%,rgba(4,3,8,.95) 30%,rgba(4,3,8,.5) 70%,transparent 100%);z-index:2;}
.dh-scan{position:absolute;left:0;right:0;height:2px;background:linear-gradient(to right,transparent,rgba(242,238,232,.04),transparent);animation:scanLine 16s linear infinite;pointer-events:none;z-index:3;}
.dh-content{position:relative;z-index:4;max-width:700px;}
.dh-format-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(224,48,80,.15);border:1px solid rgba(224,48,80,.3);padding:4px 14px;margin-bottom:16px;}
.dhfb-icon{font-size:12px;}
.dhfb-text{font-family:var(--fm);font-size:6px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent2);}
.dhfb-dot{width:4px;height:4px;border-radius:50%;background:var(--accent2);animation:blink .9s infinite;}
.dh-title{font-family:var(--fb);font-size:clamp(52px,10vw,140px);letter-spacing:.04em;line-height:.84;margin-bottom:10px;background:linear-gradient(160deg,var(--white),var(--off),var(--white));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.dh-creator{font-family:var(--fm);font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:rgba(242,238,232,.4);margin-bottom:8px;}
.dh-logline{font-family:var(--fg);font-style:italic;font-size:clamp(15px,1.6vw,20px);color:rgba(242,238,232,.6);max-width:560px;line-height:1.9;margin-bottom:20px;}
.dh-meta{display:flex;gap:16px;align-items:center;margin-bottom:24px;flex-wrap:wrap;}
.dh-meta-item{font-family:var(--fm);font-size:7px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:5px;}
.dh-meta-item span{color:rgba(242,238,232,.5);}
.dh-actions{display:flex;gap:8px;}
.dh-play-btn{font-family:var(--fc);font-size:16px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;background:var(--accent);color:var(--void);border:none;padding:13px 32px;cursor:pointer;transition:all .22s;display:flex;align-items:center;gap:8px;}
.dh-play-btn:hover{background:var(--accent2);}
.dh-detail-btn{font-family:var(--fc);font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:transparent;color:rgba(242,238,232,.55);border:1px solid rgba(242,238,232,.15);padding:13px 24px;cursor:pointer;transition:all .22s;}
.dh-detail-btn:hover{border-color:rgba(242,238,232,.4);color:var(--white);}
/* universe strip — crossovers */
.dh-universe-strip{position:absolute;bottom:24px;right:48px;z-index:4;display:flex;align-items:center;gap:8px;}
.dus-label{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:rgba(242,238,232,.3);}
.dus-links{display:flex;gap:-4px;}
.dus-link{width:28px;height:28px;border-radius:50%;border:2px solid var(--void);display:flex;align-items:center;justify-content:center;font-size:12px;margin-left:-6px;cursor:pointer;transition:transform .2s;}
.dus-link:hover{transform:scale(1.2);z-index:5;}
.dus-link:first-child{margin-left:0;}

/* section */
.section{padding:48px;position:relative;z-index:1;}
.section-hdr{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:20px;}
.sh-title{font-family:var(--fc);font-size:clamp(22px,3vw,36px);font-weight:800;letter-spacing:.06em;}
.sh-action{font-family:var(--fm);font-size:7px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);cursor:pointer;transition:color .2s;background:none;border:none;}
.sh-action:hover{color:var(--accent);}

/* project cards — three display modes */
.cards-row{display:flex;gap:12px;overflow-x:auto;padding-bottom:8px;}
.cards-row::-webkit-scrollbar{height:2px;}
.cards-row::-webkit-scrollbar-track{background:rgba(242,238,232,.04);}
.cards-row::-webkit-scrollbar-thumb{background:rgba(242,238,232,.15);}

/* ALBUM card */
.card-album{width:200px;flex-shrink:0;cursor:pointer;transition:transform .25s;}
.card-album:hover{transform:translateY(-4px);}
.ca-art{width:200px;height:200px;border-radius:2px;position:relative;overflow:hidden;margin-bottom:9px;}
.ca-art-inner{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;}
.ca-art-inner::before{content:'';position:absolute;inset:0;opacity:.5;}
.ca-art-overlay{position:absolute;inset:0;background:rgba(4,3,8,.2);}
.ca-play-icon{position:absolute;bottom:10px;right:10px;width:36px;height:36px;border-radius:50%;background:rgba(4,3,8,.7);display:flex;align-items:center;justify-content:center;font-size:14px;opacity:0;transition:opacity .2s;}
.card-album:hover .ca-play-icon{opacity:1;}
.ca-format-tag{position:absolute;top:8px;left:8px;font-family:var(--fm);font-size:5px;letter-spacing:.16em;text-transform:uppercase;border:1px solid;padding:2px 7px;}
.ca-crossover{position:absolute;top:8px;right:8px;font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;background:rgba(212,160,32,.2);border:1px solid rgba(212,160,32,.4);color:var(--gold2);padding:2px 6px;}
.ca-title{font-family:var(--fb);font-size:17px;letter-spacing:.06em;line-height:1.1;margin-bottom:3px;}
.ca-creator{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.ca-meta{display:flex;gap:8px;margin-top:5px;align-items:center;}
.ca-eps{font-family:var(--fm);font-size:6px;letter-spacing:.08em;text-transform:uppercase;color:rgba(242,238,232,.3);}
.ca-branch{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(242,238,232,.12);padding:2px 6px;color:rgba(242,238,232,.35);}

/* BOOK card */
.card-book{width:140px;flex-shrink:0;cursor:pointer;transition:transform .25s;}
.card-book:hover{transform:translateY(-4px) rotate(1deg);}
.cb-spine-wrap{display:flex;height:210px;box-shadow:4px 4px 20px rgba(0,0,0,.6);}
.cb-spine{width:18px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.cb-spine-text{font-family:var(--fb);font-size:9px;letter-spacing:.12em;writing-mode:vertical-rl;transform:rotate(180deg);color:rgba(242,238,232,.6);}
.cb-cover{flex:1;position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end;padding:12px 10px;}
.cb-cover::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(4,3,8,.8),rgba(4,3,8,.1));}
.cb-title{font-family:var(--fp);font-size:clamp(14px,2vw,18px);font-style:italic;font-weight:700;line-height:1.2;position:relative;z-index:1;margin-bottom:4px;}
.cb-author{font-family:var(--fg);font-size:10px;font-style:italic;color:rgba(242,238,232,.55);position:relative;z-index:1;}
.cb-vol{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(242,238,232,.35);position:relative;z-index:1;margin-bottom:3px;}
.cb-meta{margin-top:8px;}
.cb-genre{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}

/* MAGAZINE card */
.card-mag{width:170px;flex-shrink:0;cursor:pointer;transition:transform .25s;}
.card-mag:hover{transform:translateY(-4px);}
.cm-cover{height:230px;position:relative;overflow:hidden;}
.cm-cover::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(4,3,8,.85) 0%,rgba(4,3,8,.1) 60%);}
.cm-masthead{position:absolute;top:0;left:0;right:0;z-index:2;padding:10px 10px 0;}
.cmm-title{font-family:var(--fc);font-size:clamp(18px,2.5vw,24px);font-weight:900;letter-spacing:.08em;line-height:.9;}
.cmm-issue{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(242,238,232,.5);margin-top:2px;}
.cm-headline{position:absolute;bottom:0;left:0;right:0;z-index:2;padding:10px;}
.cmh-kicker{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(242,238,232,.5);margin-bottom:3px;}
.cmh-text{font-family:var(--fc);font-size:clamp(13px,1.8vw,16px);font-weight:700;letter-spacing:.04em;line-height:1.2;}
.cm-meta{padding:8px 0 0;}
.cm-meta-row{display:flex;justify-content:space-between;align-items:center;}
.cmm-label{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}

/* grid of cards */
.cards-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
@media(max-width:1100px){.cards-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:800px){.cards-grid{grid-template-columns:repeat(2,1fr);}}

/* ════════════════════════════════════════════
   VIEW 2: PROJECT DETAIL + FORMAT SKINS
════════════════════════════════════════════ */
#view-project{padding-top:58px;}
.project-hero{
  min-height:70vh;
  display:flex;align-items:flex-end;
  padding:48px;
  position:relative;overflow:hidden;
}
.ph-bg{position:absolute;inset:0;z-index:0;}
.ph-vignette{position:absolute;inset:0;background:linear-gradient(to top,rgba(4,3,8,1) 0%,rgba(4,3,8,.6) 60%,rgba(4,3,8,.2) 100%);z-index:1;}
.ph-content{position:relative;z-index:2;max-width:760px;}
/* format skin switcher */
.format-switcher{display:flex;gap:3px;margin-bottom:20px;}
.fs-btn{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;border:1px solid;padding:7px 16px;cursor:pointer;background:transparent;transition:all .22s;display:flex;align-items:center;gap:6px;}
.fs-btn .fs-icon{font-size:12px;}
.fs-btn.album{border-color:rgba(224,48,80,.3);color:rgba(224,48,80,.6);}
.fs-btn.album.active,.fs-btn.album:hover{border-color:var(--album-a);color:var(--album-b);background:rgba(224,48,80,.1);}
.fs-btn.book{border-color:rgba(40,88,168,.3);color:rgba(40,88,168,.6);}
.fs-btn.book.active,.fs-btn.book:hover{border-color:var(--book-a);color:var(--book-b);background:rgba(40,88,168,.1);}
.fs-btn.magazine{border-color:rgba(200,64,16,.3);color:rgba(200,64,16,.6);}
.fs-btn.magazine.active,.fs-btn.magazine:hover{border-color:var(--mag-a);color:var(--mag-b);background:rgba(200,64,16,.1);}

/* SKIN PANELS */
.skin-panel{display:none;}
.skin-panel.active{display:block;}

/* ─── ALBUM SKIN ─── */
.album-skin{padding:0 48px 48px;}
.as-header{display:flex;gap:28px;align-items:flex-start;margin-bottom:32px;}
.as-art{width:200px;height:200px;flex-shrink:0;position:relative;box-shadow:0 20px 60px rgba(0,0,0,.8);animation:float 6s ease-in-out infinite;}
.as-art-inner{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:60px;}
.as-art::after{content:'';position:absolute;inset:0;border:1px solid rgba(242,238,232,.1);}
.as-info{}
.as-format-label{font-family:var(--fm);font-size:6px;letter-spacing:.22em;text-transform:uppercase;color:var(--album-b);margin-bottom:5px;display:flex;align-items:center;gap:5px;}
.as-format-label::before{content:'◉';color:var(--album-a);}
.as-title{font-family:var(--fb);font-size:clamp(40px,7vw,88px);letter-spacing:.04em;line-height:.86;margin-bottom:8px;}
.as-creator{font-family:var(--fm);font-size:7px;letter-spacing:.16em;text-transform:uppercase;color:rgba(242,238,232,.45);margin-bottom:10px;}
.as-stats{display:flex;gap:16px;margin-bottom:14px;}
.as-stat{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:rgba(242,238,232,.3);}
.as-stat span{color:rgba(242,238,232,.65);font-weight:700;}
.as-actions{display:flex;gap:6px;flex-wrap:wrap;}
.as-btn-play{font-family:var(--fc);font-size:15px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;background:var(--album-a);color:var(--void);border:none;padding:11px 28px;cursor:pointer;transition:background .2s;}
.as-btn-play:hover{background:var(--album-b);}
.as-btn-outline{font-family:var(--fc);font-size:13px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:transparent;color:rgba(242,238,232,.45);border:1px solid rgba(242,238,232,.15);padding:11px 20px;cursor:pointer;transition:all .2s;}
.as-btn-outline:hover{border-color:rgba(242,238,232,.35);color:var(--white);}
/* tracklist */
.as-tracklist{border-top:1px solid rgba(242,238,232,.07);}
.as-track-hdr{display:grid;grid-template-columns:40px 1fr auto auto auto;gap:12px;padding:10px 0;border-bottom:1px solid rgba(242,238,232,.07);}
.ath-cell{font-family:var(--fm);font-size:6px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);}
.as-track{display:grid;grid-template-columns:40px 1fr auto auto auto;gap:12px;padding:11px 0;border-bottom:1px solid rgba(242,238,232,.04);align-items:center;cursor:pointer;transition:background .15s;border-radius:2px;}
.as-track:hover{background:rgba(242,238,232,.04);}
.as-track.playing{background:rgba(224,48,80,.06);}
.at-num{font-family:var(--fm);font-size:11px;font-weight:700;color:rgba(242,238,232,.25);text-align:right;}
.as-track.playing .at-num{color:var(--album-a);}
.at-info{}
.at-title{font-family:var(--fg);font-size:14px;color:rgba(242,238,232,.82);margin-bottom:1px;}
.as-track.playing .at-title{color:var(--white);font-weight:600;}
.at-subtitle{font-family:var(--fm);font-size:6px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);}
.at-branch{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(224,48,80,.3);color:var(--album-a);padding:2px 7px;background:rgba(224,48,80,.06);}
.at-dur{font-family:var(--fm);font-size:9px;font-weight:700;color:rgba(242,238,232,.3);}
.at-waveform{display:flex;align-items:center;gap:1px;width:40px;height:16px;}
.at-bar{width:3px;border-radius:1px 1px 0 0;animation:waveBar 1s ease-in-out infinite;}

/* ─── BOOK SKIN ─── */
.book-skin{padding:0 48px 48px;max-width:1100px;margin:0 auto;}
.bs-layout{display:grid;grid-template-columns:280px 1fr;gap:40px;}
@media(max-width:900px){.bs-layout{grid-template-columns:1fr;}}
.bs-cover{position:sticky;top:80px;height:fit-content;}
.bsc-book{width:240px;height:340px;position:relative;transform:perspective(800px) rotateY(-8deg);box-shadow:-12px 12px 40px rgba(0,0,0,.8),4px 0 12px rgba(0,0,0,.5);animation:float 7s ease-in-out infinite;}
.bsc-front{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:20px;overflow:hidden;}
.bsc-front::before{content:'';position:absolute;inset:0;}
.bsc-spine{position:absolute;left:0;top:0;bottom:0;width:28px;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;}
.bsc-spine-text{font-family:var(--fb);font-size:10px;letter-spacing:.14em;writing-mode:vertical-rl;transform:rotate(180deg);color:rgba(242,238,232,.6);}
.bsc-content{position:relative;z-index:1;}
.bsc-series{font-family:var(--fm);font-size:5px;letter-spacing:.18em;text-transform:uppercase;color:rgba(242,238,232,.5);margin-bottom:5px;}
.bsc-title{font-family:var(--fp);font-size:clamp(16px,2.5vw,22px);font-style:italic;font-weight:900;line-height:1.2;margin-bottom:4px;}
.bsc-author{font-family:var(--fg);font-size:11px;font-style:italic;color:rgba(242,238,232,.55);}
.bs-meta{margin-top:16px;}
.bsm-row{display:flex;justify-content:space-between;font-family:var(--fm);font-size:7px;letter-spacing:.08em;text-transform:uppercase;color:rgba(242,238,232,.3);padding:5px 0;border-bottom:1px solid rgba(242,238,232,.05);}
.bsm-val{color:rgba(242,238,232,.65);}
/* book content */
.bs-content{}
.bsc-header{margin-bottom:24px;}
.bsch-title{font-family:var(--fp);font-size:clamp(28px,4vw,52px);font-style:italic;font-weight:900;line-height:1.1;margin-bottom:8px;}
.bsch-meta{font-family:var(--fm);font-size:7px;letter-spacing:.14em;text-transform:uppercase;color:rgba(242,238,232,.3);}
/* table of contents */
.bs-toc{border:1px solid rgba(40,88,168,.15);background:rgba(40,88,168,.05);padding:20px 24px;margin-bottom:24px;}
.bstoc-title{font-family:var(--fp);font-size:14px;font-style:italic;color:rgba(242,238,232,.5);margin-bottom:12px;text-align:center;}
.bstoc-item{display:flex;align-items:baseline;gap:8px;padding:6px 0;border-bottom:1px solid rgba(242,238,232,.04);cursor:pointer;transition:all .18s;}
.bstoc-item:hover{background:rgba(40,88,168,.06);}
.bstoc-item:last-child{border-bottom:none;}
.bsti-num{font-family:var(--fm);font-size:9px;font-weight:700;color:rgba(40,88,168,.8);min-width:28px;}
.bsti-title{font-family:var(--fg);font-size:14px;font-style:italic;flex:1;}
.bsti-dots{flex:1;border-bottom:1px dotted rgba(242,238,232,.12);margin:0 8px;min-width:20px;}
.bsti-badge{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(40,88,168,.3);color:var(--book-b);padding:2px 6px;}
/* excerpt */
.bs-excerpt{font-family:var(--fg);font-size:clamp(15px,1.6vw,18px);line-height:2.1;color:rgba(242,238,232,.7);margin-bottom:20px;}
.bs-excerpt::first-letter{font-size:3.5em;font-style:italic;font-weight:700;color:var(--book-b);float:left;line-height:.75;margin-right:8px;margin-top:6px;}
.bs-read-btn{font-family:var(--fp);font-size:16px;font-style:italic;font-weight:700;background:var(--book-a);color:var(--white);border:none;padding:12px 28px;cursor:pointer;transition:background .2s;}
.bs-read-btn:hover{background:var(--book-b);}

/* ─── MAGAZINE SKIN ─── */
.magazine-skin{padding:0 48px 48px;}
.ms-masthead{display:flex;justify-content:space-between;align-items:flex-end;padding-bottom:12px;margin-bottom:20px;border-bottom:3px solid var(--mag-a);}
.msm-title{font-family:var(--fc);font-size:clamp(36px,7vw,100px);font-weight:900;letter-spacing:.05em;line-height:.85;}
.msm-right{text-align:right;}
.msmr-issue{font-family:var(--fm);font-size:8px;letter-spacing:.18em;text-transform:uppercase;color:rgba(242,238,232,.4);}
.msmr-tagline{font-family:var(--fg);font-style:italic;font-size:14px;color:rgba(242,238,232,.4);}
/* magazine grid */
.ms-layout{display:grid;grid-template-columns:2fr 1fr;gap:3px;margin-bottom:3px;}
.ms-layout-2{display:grid;grid-template-columns:1fr 1fr 1fr;gap:3px;}
.ms-feature{position:relative;overflow:hidden;height:340px;cursor:pointer;}
.ms-feature::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(4,3,8,.95) 0%,rgba(4,3,8,.2) 60%);}
.ms-feature-bg{position:absolute;inset:0;}
.ms-feature-content{position:absolute;bottom:0;left:0;right:0;padding:20px;z-index:1;}
.msfc-kicker{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;color:var(--mag-b);margin-bottom:5px;}
.msfc-headline{font-family:var(--fc);font-size:clamp(22px,3.5vw,40px);font-weight:900;letter-spacing:.04em;line-height:1;margin-bottom:5px;}
.msfc-deck{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(242,238,232,.55);line-height:1.6;}
.ms-sidebar-article{background:var(--panel);border:1px solid rgba(242,238,232,.05);padding:16px;cursor:pointer;transition:all .2s;height:50%;}
.ms-sidebar-article:hover{background:rgba(242,238,232,.04);}
.mssa-issue{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
.mssa-headline{font-family:var(--fc);font-size:clamp(14px,2vw,18px);font-weight:700;letter-spacing:.04em;line-height:1.2;margin-bottom:5px;}
.mssa-byline{font-family:var(--fg);font-style:italic;font-size:11px;color:rgba(242,238,232,.4);}
.ms-column{background:var(--panel);border:1px solid rgba(242,238,232,.05);padding:16px;cursor:pointer;transition:all .2s;}
.ms-column:hover{background:rgba(242,238,232,.04);}
.msc-rubric{font-family:var(--fm);font-size:5px;letter-spacing:.16em;text-transform:uppercase;margin-bottom:5px;border-bottom:2px solid;display:inline-block;padding-bottom:2px;}
.msc-headline{font-family:var(--fp);font-size:clamp(14px,2vw,18px);font-style:italic;font-weight:700;line-height:1.2;margin-bottom:5px;}
.msc-excerpt{font-family:var(--fg);font-size:11px;color:rgba(242,238,232,.4);line-height:1.55;}

/* ════════════════════════════════════════════
   VIEW 3: THE BRANCH — INTERACTIVE PLAYER
════════════════════════════════════════════ */
#view-branch{padding-top:58px;min-height:100vh;display:flex;flex-direction:column;}
.branch-layout{display:grid;grid-template-columns:1fr 340px;flex:1;overflow:hidden;}
@media(max-width:1000px){.branch-layout{grid-template-columns:1fr;}}
/* player main */
.branch-main{padding:32px 40px;overflow-y:auto;display:flex;flex-direction:column;gap:20px;}
.branch-main::-webkit-scrollbar{width:3px;}
.branch-main::-webkit-scrollbar-thumb{background:rgba(242,238,232,.1);}
/* episode info */
.bp-episode-info{display:flex;gap:16px;align-items:flex-start;}
.bpei-art{width:80px;height:80px;flex-shrink:0;position:relative;overflow:hidden;}
.bpei-text{}
.bpeit-series{font-family:var(--fm);font-size:6px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:3px;}
.bpeit-title{font-family:var(--fb);font-size:clamp(22px,3.5vw,40px);letter-spacing:.05em;line-height:1;margin-bottom:4px;}
.bpeit-meta{font-family:var(--fm);font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:rgba(242,238,232,.35);}
/* waveform player */
.bp-player{background:var(--panel);border:1px solid rgba(242,238,232,.06);padding:18px 20px;}
.bpp-waveform{height:56px;display:flex;align-items:center;gap:2px;margin-bottom:10px;cursor:pointer;position:relative;}
.bpp-wave-bar{flex:1;border-radius:1px;transition:background .3s;min-height:4px;}
.bpp-playhead{position:absolute;top:-4px;bottom:-4px;width:2px;background:var(--accent);left:38%;pointer-events:none;}
.bpp-playhead::after{content:'';position:absolute;top:-3px;left:-4px;width:10px;height:10px;border-radius:50%;background:var(--accent);}
.bpp-controls{display:flex;align-items:center;gap:12px;margin-bottom:8px;}
.bppc-time{font-family:var(--fm);font-size:9px;font-weight:700;color:rgba(242,238,232,.4);min-width:36px;}
.bppc-play{width:44px;height:44px;border-radius:50%;background:var(--accent);border:none;color:var(--void);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;flex-shrink:0;}
.bppc-play:hover{background:var(--accent2);transform:scale(1.05);}
.bppc-btn{background:transparent;border:1px solid rgba(242,238,232,.12);color:rgba(242,238,232,.45);font-family:var(--fm);font-size:8px;font-weight:700;padding:6px 11px;cursor:pointer;transition:all .2s;}
.bppc-btn:hover{border-color:rgba(242,238,232,.3);color:rgba(242,238,232,.8);}
.bppc-speed{color:var(--muted);}
.bpp-progress{height:3px;background:rgba(242,238,232,.08);position:relative;cursor:pointer;}
.bpp-prog-fill{height:100%;background:linear-gradient(to right,var(--accent),var(--accent2));width:38%;}
.bpp-prog-dot{position:absolute;top:-4px;left:38%;width:10px;height:10px;border-radius:50%;background:var(--accent2);transform:translateX(-50%);}
/* THE BRANCH — choice point */
.branch-point{background:rgba(242,238,232,.04);border:1px solid rgba(242,238,232,.1);padding:20px;position:relative;overflow:hidden;}
.branch-point::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--accent),var(--accent2));}
.bp-label{font-family:var(--fm);font-size:7px;letter-spacing:.24em;text-transform:uppercase;color:var(--accent);margin-bottom:5px;display:flex;align-items:center;gap:6px;}
.bp-label::before{content:'⬡';font-size:10px;}
.bp-active-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:branchPulse 1.5s infinite;}
.bp-question{font-family:var(--fg);font-style:italic;font-size:clamp(16px,1.8vw,20px);color:rgba(242,238,248,.75);line-height:1.8;margin-bottom:16px;}
.bp-timer{display:flex;align-items:center;gap:8px;margin-bottom:14px;}
.bpt-label{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);}
.bpt-bar{flex:1;height:3px;background:rgba(242,238,232,.08);}
.bpt-fill{height:100%;background:var(--accent);transition:width 1s linear;}
.bpt-time{font-family:var(--fm);font-size:9px;font-weight:700;color:var(--accent);}
/* choices */
.choices-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
@media(max-width:700px){.choices-grid{grid-template-columns:1fr;}}
.choice-btn{
  padding:14px 16px;
  background:rgba(242,238,232,.04);
  border:1px solid rgba(242,238,232,.1);
  cursor:pointer;
  transition:all .22s;
  text-align:left;
  position:relative;
  overflow:hidden;
}
.choice-btn:hover{border-color:var(--accent);background:rgba(224,48,80,.08);}
.choice-btn.selected{border-color:var(--accent);background:rgba(224,48,80,.12);}
.choice-btn::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent);transform:scaleX(0);transition:transform .22s;}
.choice-btn:hover::before,.choice-btn.selected::before{transform:scaleX(1);}
.cb-letter{font-family:var(--fb);font-size:22px;color:rgba(242,238,232,.18);position:absolute;top:8px;right:12px;line-height:1;}
.cb-path{font-family:var(--fm);font-size:5px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:5px;}
.cb-choice{font-family:var(--fg);font-size:14px;font-style:italic;color:rgba(242,238,248,.75);line-height:1.6;margin-bottom:5px;}
.cb-consequence{font-family:var(--fm);font-size:6px;letter-spacing:.08em;text-transform:uppercase;color:rgba(242,238,232,.3);}
/* crossover unlock */
.crossover-unlock{background:rgba(212,160,32,.06);border:1px solid rgba(212,160,32,.2);padding:14px 16px;display:flex;gap:12px;align-items:flex-start;}
.cu-icon{font-size:20px;flex-shrink:0;}
.cu-body{}
.cub-label{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold2);margin-bottom:3px;}
.cub-title{font-family:var(--fg);font-size:14px;font-weight:600;margin-bottom:3px;}
.cub-desc{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(242,238,232,.45);line-height:1.6;}
.cu-btn{font-family:var(--fm);font-size:6px;letter-spacing:.14em;text-transform:uppercase;background:var(--gold);color:var(--void);border:none;padding:5px 12px;cursor:pointer;margin-top:8px;transition:background .2s;}
.cu-btn:hover{background:var(--gold2);}
/* branch sidebar */
.branch-sidebar{background:rgba(6,5,10,.98);border-left:1px solid rgba(242,238,232,.05);overflow-y:auto;padding:20px;}
.branch-sidebar::-webkit-scrollbar{width:0;}
.brs-section{margin-bottom:20px;}
.brss-title{font-family:var(--fm);font-size:7px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.brss-title::before{content:'⬡';color:var(--accent);font-size:9px;}
/* your path */
.path-tree{display:flex;flex-direction:column;gap:0;}
.pt-node{display:flex;gap:8px;align-items:flex-start;padding:6px 0;position:relative;}
.pt-node::before{content:'';position:absolute;left:6px;top:20px;bottom:-2px;width:1px;background:rgba(242,238,232,.08);}
.pt-node:last-child::before{display:none;}
.ptn-dot{width:13px;height:13px;border-radius:50%;border:1.5px solid;flex-shrink:0;margin-top:2px;}
.ptn-content{}
.ptnc-ep{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
.ptnc-choice{font-family:var(--fg);font-size:11px;font-style:italic;color:rgba(242,238,232,.6);}
/* listener stats */
.path-stat{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid rgba(242,238,232,.04);}
.ps-label{font-family:var(--fb);font-size:12px;letter-spacing:.04em;color:rgba(242,238,232,.5);}
.ps-val{font-family:var(--fm);font-size:8px;font-weight:700;}
.ps-bar{width:100%;height:3px;background:rgba(242,238,232,.06);margin-top:3px;}
.ps-bar-fill{height:100%;}
/* upcoming nodes */
.upcoming-node{padding:8px 10px;background:var(--panel);border:1px solid rgba(242,238,232,.05);margin-bottom:4px;cursor:pointer;transition:all .18s;}
.upcoming-node:hover{border-color:rgba(242,238,232,.12);}
.un-ep{font-family:var(--fm);font-size:5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:2px;}
.un-title{font-family:var(--fg);font-size:12px;font-style:italic;color:rgba(242,238,232,.6);}
.un-branch-badge{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(224,48,80,.25);color:var(--album-a);padding:1px 5px;margin-top:4px;display:inline-block;}

/* ════════════════════════════════════════════
   VIEW 4: UNIVERSE MAP
════════════════════════════════════════════ */
#view-universe{padding-top:58px;}
.universe-wrap{padding:40px 48px;}
.universe-hdr{text-align:center;margin-bottom:40px;}
.uh-title{font-family:var(--fb);font-size:clamp(40px,8vw,100px);letter-spacing:.06em;line-height:.86;margin-bottom:8px;}
.uh-sub{font-family:var(--fg);font-style:italic;font-size:clamp(14px,1.5vw,18px);color:rgba(242,238,232,.4);max-width:560px;margin:0 auto;line-height:2;}
/* universe map canvas */
.umap-container{position:relative;height:520px;background:var(--panel);border:1px solid rgba(242,238,232,.06);overflow:hidden;margin-bottom:28px;}
.umap-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(242,238,232,.02) 0%,transparent 70%);}
/* grid lines */
.umap-bg::after{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,rgba(242,238,232,.015) 0,rgba(242,238,232,.015) 1px,transparent 1px,transparent 60px),repeating-linear-gradient(90deg,rgba(242,238,232,.015) 0,rgba(242,238,232,.015) 1px,transparent 1px,transparent 60px);}
/* project nodes */
.umap-node{position:absolute;cursor:pointer;transition:transform .2s;}
.umap-node:hover{transform:scale(1.08)!important;}
.umn-circle{border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;border:2px solid rgba(242,238,232,.15);position:relative;margin:0 auto;}
.umn-circle::after{content:'';position:absolute;inset:-6px;border-radius:50%;border:1px solid;opacity:.25;animation:branchPulse 2s infinite;}
.umn-label{font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;text-align:center;margin-top:6px;color:rgba(242,238,232,.55);}
.umn-format{font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;text-align:center;color:var(--muted);}
/* crossover lines - SVG */
.umap-svg{position:absolute;inset:0;pointer-events:none;}
/* crossover nodes */
.umap-crossover{position:absolute;transform:translate(-50%,-50%);cursor:pointer;}
.umc-diamond{width:14px;height:14px;background:var(--gold);transform:rotate(45deg);animation:branchPulse 1.8s infinite;}
.umc-label{font-family:var(--fm);font-size:5px;letter-spacing:.08em;text-transform:uppercase;color:var(--gold2);text-align:center;margin-top:8px;white-space:nowrap;}
/* legend */
.umap-legend{display:flex;gap:20px;justify-content:center;flex-wrap:wrap;}
.uml-item{display:flex;align-items:center;gap:6px;font-family:var(--fm);font-size:6px;letter-spacing:.1em;text-transform:uppercase;color:rgba(242,238,232,.4);}
.uml-dot{width:10px;height:10px;border-radius:50%;}
.uml-diamond{width:8px;height:8px;transform:rotate(45deg);}
/* crossover cards */
.crossover-section{margin-top:28px;}
.co-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;}
@media(max-width:900px){.co-cards{grid-template-columns:1fr;}}
.co-card{background:rgba(212,160,32,.05);border:1px solid rgba(212,160,32,.15);padding:20px;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;}
.co-card:hover{border-color:rgba(212,160,32,.3);background:rgba(212,160,32,.09);}
.co-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,var(--gold),var(--gold2));}
.coc-label{font-family:var(--fm);font-size:6px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold2);margin-bottom:6px;display:flex;align-items:center;gap:5px;}
.coc-label::before{content:'◆';font-size:8px;}
.coc-title{font-family:var(--fg);font-size:clamp(16px,2vw,22px);font-weight:600;margin-bottom:5px;}
.coc-projects{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;}
.cocp{font-family:var(--fm);font-size:5px;letter-spacing:.1em;text-transform:uppercase;border:1px solid rgba(212,160,32,.25);padding:2px 7px;color:var(--gold);}
.coc-desc{font-family:var(--fg);font-style:italic;font-size:12px;color:rgba(242,238,232,.4);line-height:1.65;}
.coc-unlock{font-family:var(--fm);font-size:6px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold2);margin-top:8px;}

/* ════════════════════════════════════════════
   VIEW 5: CREATOR STUDIO
════════════════════════════════════════════ */
#view-studio{padding-top:58px;}
.studio-wrap{padding:36px 48px;}
.studio-hdr{margin-bottom:28px;}
.stuh-title{font-family:var(--fb);font-size:clamp(36px,6vw,80px);letter-spacing:.06em;line-height:.86;margin-bottom:6px;}
.stuh-sub{font-family:var(--fg);font-style:italic;font-size:14px;color:rgba(242,238,232,.38);}
/* creator stats */
.studio-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-bottom:24px;}
.sts-card{background:var(--panel);border:1px solid rgba(242,238,232,.06);padding:16px 18px;position:relative;overflow:hidden;}
.sts-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;}
.stsc-val{font-family:var(--fb);font-size:clamp(24px,3.5vw,44px);letter-spacing:.04em;display:block;line-height:1;margin-bottom:4px;}
.stsc-lbl{font-family:var(--fm);font-size:5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);display:block;}
.stsc-delta{font-family:var(--fm);font-size:7px;margin-top:3px;}
/* projects */
.studio-projects{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;margin-bottom:24px;}
@media(max-width:900px){.studio-projects{grid-template-columns:1fr;}}
.sp-card{background:var(--panel);border:1px solid rgba(242,238,232,.06);padding:20px;position:relative;cursor:pointer;transition:all .22s;}
.sp-card:hover{border-color:rgba(242,238,232,.16);}
.sp-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
